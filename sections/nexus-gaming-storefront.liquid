{%- assign target_collection = collection | default: collections.all -%}
{%- assign bg_opacity = section.settings.section_bg_opacity | times: 1.0 | divided_by: 100 -%}

<style>
  :root {
    --ff-primary: {{ section.settings.color_primary }};
    --ff-bg: {{ section.settings.color_bg }};
    --ff-panel: {{ section.settings.color_panel }};
    --ff-border: {{ section.settings.color_border }};
    --ff-bg-opacity: {{ bg_opacity }};

    --ff-hero-title-pc: {{ section.settings.hero_title_pc }}px;
    --ff-hero-title-mb: {{ section.settings.hero_title_mb }}px;
    --ff-card-title-pc: {{ section.settings.card_title_pc }}px;
    --ff-card-title-mb: {{ section.settings.card_title_mb }}px;
    --ff-price-pc: {{ section.settings.price_pc }}px;
    --ff-price-mb: {{ section.settings.price_mb }}px;

    --ff-font-header: 'Impact', 'Teko', 'Bebas Neue', sans-serif;
    --ff-font-body: 'Rajdhani', 'Roboto', sans-serif;
    --transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fn-section-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background-color: var(--ff-bg);
    color: #fff;
    font-family: var(--ff-font-body);
    padding-bottom: 60px;
  }

  /* --- FULL SECTION BACKGROUND IMAGE --- */
  .fn-section-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: var(--ff-bg-opacity);
    z-index: 0;
    pointer-events: none;
  }
  .fn-section-bg-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--ff-bg) 0%, transparent 15%, transparent 85%, var(--ff-bg) 100%);
  }

  .fn-hero, .fn-container, .fn-fire-sparks, .fn-fire-glowline {
    position: relative;
    z-index: 1;
  }

  /* --- HERO BANNER (CARD STYLE) --- */
  .fn-hero-wrapper {
    padding: 30px 5% 10px;
    opacity: 0;
    animation: fnFadeIn 0.6s ease forwards;
  }
  .fn-hero {
    position: relative;
    width: 100%;
    height: 400px;
    background-color: #111;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    padding: 0 5%;
    border-radius: 16px;
    border: 1px solid var(--ff-border);
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .fn-hero:hover {
    border-color: rgba(255,176,0,0.3);
    box-shadow: 0 20px 55px rgba(0,0,0,0.6), 0 0 30px rgba(255,176,0,0.08);
  }
  .fn-hero-noimg { background-image: linear-gradient(135deg, var(--ff-panel) 0%, #000 100%); }
  .fn-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.45) 50%, transparent 100%);
    z-index: 1;
  }
  .fn-hero-shine {
    position: absolute; top: 0; left: -60%;
    width: 35%; height: 100%;
    background: linear-gradient(115deg, transparent, rgba(255,255,255,0.06), transparent);
    transform: skewX(-20deg);
    animation: fnShineOnce 1.6s ease-out 0.4s 1 both;
    z-index: 2;
  }
  @keyframes fnShineOnce { 0% { left: -60%; } 100% { left: 130%; } }

  .fn-hero-content { position: relative; z-index: 3; max-width: 600px; }
  .fn-hero-badge {
    border: 1px solid var(--ff-primary);
    color: var(--ff-primary);
    padding: 4px 12px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 15px;
    border-radius: 4px;
    box-shadow: 0 0 12px rgba(255,176,0,0.2);
    opacity: 0;
    animation: fnFadeInUp 0.5s ease forwards 0.1s;
  }
  .fn-hero h1 {
    font-family: var(--ff-font-header);
    font-size: var(--ff-hero-title-pc);
    line-height: 1;
    margin: 0 0 15px 0;
    text-transform: uppercase;
    text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
    opacity: 0;
    animation: fnFadeInUp 0.5s ease forwards 0.2s;
  }
  .fn-hero h1 span { color: var(--ff-primary); }
  .fn-hero p {
    color: #ccc;
    font-size: 16px;
    line-height: 1.5;
    opacity: 0;
    animation: fnFadeInUp 0.5s ease forwards 0.3s;
  }

  @keyframes fnFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes fnFadeInUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- LAYOUT & GRID --- */
  .fn-container { max-width: 1600px; margin: 0 auto; padding: 30px 20px; display: flex; gap: 30px; }
  .fn-sidebar { width: 280px; flex-shrink: 0; }
  .fn-main { flex-grow: 1; width: 100%; }

  /* --- TOOLBAR --- */
  .fn-toolbar {
    background: var(--ff-panel);
    border: 1px solid var(--ff-border);
    border-radius: 10px;
    padding: 15px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    transition: var(--transition);
  }
  .fn-toolbar:hover { border-color: #3a3a3d; }
  .fn-toolbar-count { color: #aaa; font-size: 14px; text-transform: uppercase; font-weight: 600; }
  .fn-toolbar-actions { display: flex; gap: 20px; align-items: center; }
  .fn-select { background: transparent; color: #fff; border: none; outline: none; font-family: var(--ff-font-body); font-weight: 600; cursor: pointer; }
  .fn-select option { background: var(--ff-panel); }

  /* --- SIDEBAR FILTERS --- */
  .fn-filter-widget {
    background: var(--ff-panel);
    border: 1px solid var(--ff-border);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 20px;
    transition: var(--transition);
  }
  .fn-filter-widget:hover { border-color: #3a3a3d; }
  .fn-filter-title {
    font-size: 14px; color: #fff; text-transform: uppercase; letter-spacing: 1px;
    margin: 0 0 15px 0; padding-bottom: 10px; border-bottom: 1px solid var(--ff-border);
  }
  .fn-filter-list { list-style: none; padding: 0; margin: 0; }
  .fn-filter-list li { margin-bottom: 12px; }
  .fn-filter-label { display: flex; justify-content: space-between; cursor: pointer; color: #bbb; font-size: 14px; transition: var(--transition); }
  .fn-filter-label:hover, .fn-filter-checkbox:checked + span { color: var(--ff-primary); }
  .fn-filter-checkbox { display: none; }
  .fn-color-swatches { display: flex; flex-wrap: wrap; gap: 10px; }
  .fn-color-box { width: 24px; height: 24px; border-radius: 50%; border: 2px solid #333; cursor: pointer; transition: var(--transition); }
  .fn-color-box:hover { transform: scale(1.12); }
  .fn-filter-checkbox:checked + .fn-color-box { border-color: var(--ff-primary); box-shadow: 0 0 10px var(--ff-primary); }
  .fn-size-swatches { display: flex; flex-wrap: wrap; gap: 10px; }
  .fn-size-box { border: 1px solid #444; padding: 5px 12px; color: #ccc; cursor: pointer; border-radius: 4px; font-weight: 600; transition: var(--transition); }
  .fn-size-box:hover { border-color: var(--ff-primary); color: var(--ff-primary); }
  .fn-filter-checkbox:checked + .fn-size-box { border-color: var(--ff-primary); color: var(--ff-primary); background: rgba(255,176,0,0.08); }

  /* ============================================= */
  /* --- UNIQUE GAMING PRODUCT CARD --- */
  /* ============================================= */
  .fn-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }

  .fn-card-frame {
    --cut: 18px;
    clip-path: polygon(var(--cut) 0, 100% 0, 100% calc(100% - var(--cut)), calc(100% - var(--cut)) 100%, 0 100%, 0 var(--cut));
    background: var(--ff-border);
    padding: 1px;
    cursor: pointer;
    transition: background 0.35s ease, transform 0.35s ease;
    opacity: 0;
    transform: translateY(18px);
  }
  .fn-card-frame.is-visible { opacity: 1; transform: translateY(0); transition: opacity 0.5s ease, transform 0.5s ease, background 0.35s ease; }
  .fn-card-frame:hover { background: linear-gradient(135deg, var(--ff-primary), rgba(255,176,0,0.15)); transform: translateY(-6px); }

  .fn-card-inner {
    clip-path: polygon(var(--cut) 0, 100% 0, 100% calc(100% - var(--cut)), calc(100% - var(--cut)) 100%, 0 100%, 0 var(--cut));
    background: var(--ff-panel);
    padding: 14px;
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: background 0.35s ease;
  }

  .fn-card-id {
    position: absolute;
    top: 10px; right: 14px;
    font-size: 10px;
    color: #555;
    letter-spacing: 1px;
    font-weight: 700;
    z-index: 2;
  }

  .fn-card-badge {
    position: absolute;
    top: 12px; left: 0;
    font-size: 10px;
    font-weight: bold;
    padding: 4px 14px 4px 10px;
    z-index: 3;
    text-transform: uppercase;
    clip-path: polygon(0 0, 100% 0, 82% 100%, 0% 100%);
  }
  .bg-purple { background: #8000FF; color: white; }
  .bg-red { background: #FF3333; color: white; }
  .bg-orange { background: #FF6600; color: white; }
  .bg-blue { background: #0055FF; color: white; }

  .fn-card-img-wrap {
    width: 100%;
    aspect-ratio: 1/1;
    margin-bottom: 14px;
    overflow: hidden;
    position: relative;
    background: linear-gradient(135deg, #1c1c1f, #0c0c0d);
  }
  .fn-card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease, filter 0.5s ease;
  }
  .fn-card-frame:hover .fn-card-img { transform: scale(1.06); filter: brightness(0.8) saturate(1.1); }

  .fn-no-image {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #1c1c1f 0%, #0c0c0d 100%);
  }
  .fn-no-image span { color: #555; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }

  .fn-corner { position: absolute; width: 16px; height: 16px; border-color: rgba(255,255,255,0.18); transition: border-color 0.35s ease; z-index: 2; }
  .fn-corner-tl { top: 6px; left: 6px; border-top: 2px solid; border-left: 2px solid; }
  .fn-corner-br { bottom: 6px; right: 6px; border-bottom: 2px solid; border-right: 2px solid; }
  .fn-card-frame:hover .fn-corner { border-color: var(--ff-primary); }

  .fn-scan-line {
    position: absolute;
    left: 0; top: -10%;
    width: 100%; height: 2px;
    background: linear-gradient(90deg, transparent, var(--ff-primary), transparent);
    opacity: 0;
    z-index: 2;
  }
  .fn-card-frame:hover .fn-scan-line {
    animation: fnScan 1.4s linear infinite;
  }
  @keyframes fnScan {
    0% { top: -5%; opacity: 0; }
    10% { opacity: 0.9; }
    90% { opacity: 0.9; }
    100% { top: 100%; opacity: 0; }
  }

  .fn-card-title {
    font-size: var(--ff-card-title-pc);
    color: #fff;
    margin: 0 0 6px 0;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.5px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .fn-card-stars { color: var(--ff-primary); font-size: 12px; margin-bottom: 10px; }
  .fn-card-stars span { color: #666; }

  .fn-card-divider {
    height: 1px;
    width: 30%;
    background: var(--ff-border);
    margin-bottom: 12px;
    position: relative;
    overflow: hidden;
  }
  .fn-card-divider::after {
    content: '';
    position: absolute; top: 0; left: 0;
    height: 100%; width: 0%;
    background: var(--ff-primary);
    transition: width 0.45s ease;
  }
  .fn-card-frame:hover .fn-card-divider::after { width: 100%; }

  .fn-card-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
  .fn-card-price-wrap { display: flex; align-items: center; gap: 8px; }
  .fn-price { font-size: var(--ff-price-pc); font-weight: bold; color: #fff; }
  .fn-compare { font-size: calc(var(--ff-price-pc) * 0.7); color: #666; text-decoration: line-through; }

  .fn-cart-btn {
    width: 42px; height: 42px;
    border: none;
    background: rgba(255,176,0,0.08);
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    color: var(--ff-primary);
    display: flex; justify-content: center; align-items: center;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    z-index: 5;
  }
  .fn-cart-btn:hover { background: var(--ff-primary); color: #111; transform: scale(1.08); }
  .fn-cart-btn:active { transform: scale(0.92); }
  .fn-cart-btn svg { width: 17px; fill: currentColor; }
  .spinner-icon { animation: spin 1s linear infinite; display: none; }
  @keyframes spin { 100% { transform: rotate(360deg); } }

  /* ================= QUICK VIEW MODAL (UNIQUE HUD DESIGN) ================= */
  .fn-modal-overlay {
    position: fixed !important; inset: 0;
    background: rgba(0,0,0,0.82);
    backdrop-filter: blur(8px);
    z-index: 9999;
    display: flex; justify-content: center; align-items: center;
    padding: 20px;
    opacity: 0; visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .fn-modal-overlay.active { opacity: 1; visibility: visible; }

  .fn-modal-frame {
    --mcut: 26px;
    position: relative;
    width: 960px; max-width: 100%;
    clip-path: polygon(var(--mcut) 0, 100% 0, 100% calc(100% - var(--mcut)), calc(100% - var(--mcut)) 100%, 0 100%, 0 var(--mcut));
    background: linear-gradient(135deg, var(--ff-primary), rgba(255,255,255,0.06) 45%, var(--ff-primary) 100%);
    padding: 1.5px;
    transform: scale(0.94) translateY(10px);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), opacity 0.3s ease;
  }
  .fn-modal-overlay.active .fn-modal-frame { transform: scale(1) translateY(0); opacity: 1; }

  .fn-modal-box {
    clip-path: polygon(var(--mcut) 0, 100% 0, 100% calc(100% - var(--mcut)), calc(100% - var(--mcut)) 100%, 0 100%, 0 var(--mcut));
    background: #111113;
    display: flex;
    max-height: 88vh;
    overflow: hidden;
    position: relative;
  }

  .fn-modal-box::before {
    content: '';
    position: absolute; left: 0; top: -8%;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, transparent, var(--ff-primary), transparent);
    opacity: 0;
    z-index: 30;
    pointer-events: none;
  }
  .fn-modal-overlay.active .fn-modal-box::before {
    animation: fnModalScan 0.9s ease-out 0.15s 1;
  }
  @keyframes fnModalScan {
    0% { top: -8%; opacity: 0; }
    15% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  .fn-modal-close {
    position: absolute; top: 16px; right: 16px;
    width: 38px; height: 38px;
    background: rgba(255,255,255,0.06);
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    border: none; color: #fff; font-size: 15px;
    cursor: pointer; z-index: 20;
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition);
  }
  .fn-modal-close:hover { background: var(--ff-primary); color: #111; transform: scale(1.08); }

  .fn-modal-media {
    width: 46%;
    background: #0a0a0b;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .fn-modal-media-frame {
    position: relative;
    flex: 1;
    min-height: 260px;
    overflow: hidden;
    border-radius: 4px;
    background: linear-gradient(135deg, #1c1c1f, #0c0c0d);
  }
  .fn-modal-media-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fn-modal-media-frame .fn-corner { border-color: rgba(255,176,0,0.5); }

  .fn-modal-stock-tag {
    position: absolute; top: 10px; left: 10px;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(92,255,160,0.4);
    color: #5CFFA0;
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    padding: 5px 10px; border-radius: 3px;
    display: flex; align-items: center; gap: 6px;
    text-transform: uppercase;
    z-index: 5;
  }
  .fn-modal-stock-tag .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #5CFFA0; box-shadow: 0 0 6px #5CFFA0;
    animation: fnDotPulse 1.6s ease-in-out infinite;
  }
  .fn-modal-stock-tag.out { border-color: rgba(255,90,90,0.4); color: #FF6B6B; }
  .fn-modal-stock-tag.out .dot { background: #FF6B6B; box-shadow: 0 0 6px #FF6B6B; }
  @keyframes fnDotPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .fn-modal-thumbs { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 2px; }
  .fn-modal-thumbs::-webkit-scrollbar { height: 4px; }
  .fn-modal-thumbs::-webkit-scrollbar-thumb { background: var(--ff-border); border-radius: 2px; }
  .fn-modal-thumb {
    width: 54px; height: 54px; flex-shrink: 0;
    border: 1px solid var(--ff-border);
    border-radius: 3px;
    overflow: hidden;
    cursor: pointer;
    opacity: 0.55;
    transition: var(--transition);
  }
  .fn-modal-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .fn-modal-thumb:hover { opacity: 0.9; }
  .fn-modal-thumb.active { border-color: var(--ff-primary); opacity: 1; box-shadow: 0 0 8px rgba(255,176,0,0.35); }

  .fn-modal-info { width: 54%; display: flex; flex-direction: column; padding: 30px 32px 22px; }
  .fn-modal-info-scroll { flex: 1; overflow-y: auto; padding-right: 8px; margin-bottom: 18px; }
  .fn-modal-info-scroll::-webkit-scrollbar { width: 4px; }
  .fn-modal-info-scroll::-webkit-scrollbar-thumb { background: var(--ff-border); border-radius: 2px; }

  .fn-modal-tag {
    display: inline-block; font-size: 11px; letter-spacing: 2px;
    color: var(--ff-primary); text-transform: uppercase; font-weight: 700;
    margin-bottom: 8px; opacity: 0.9;
  }
  .fn-modal-title {
    font-family: var(--ff-font-header); font-size: 28px;
    text-transform: uppercase; margin: 0 0 8px 0; line-height: 1.08;
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .fn-modal-title.loaded { opacity: 1; transform: translateY(0); }
  .fn-modal-stars { color: var(--ff-primary); font-size: 13px; margin-bottom: 14px; }
  .fn-modal-stars span { color: #666; font-family: var(--ff-font-body); }

  .fn-modal-price-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
  .fn-modal-price { font-size: 25px; font-weight: 800; color: #fff; }
  .fn-modal-compare { font-size: 15px; color: #666; text-decoration: line-through; }
  .fn-modal-discount {
    font-size: 11px; font-weight: 700; background: rgba(255,51,51,0.15);
    color: #FF6B6B; padding: 3px 8px; border-radius: 3px; text-transform: uppercase;
  }

  .fn-modal-divider { height: 1px; background: linear-gradient(90deg, var(--ff-border), transparent); margin-bottom: 16px; }
  .fn-modal-desc { color: #9a9a9d; font-size: 14px; line-height: 1.7; margin-bottom: 18px; }

  .fn-modal-option-group { margin-bottom: 16px; }
  .fn-modal-option-label {
    font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
    color: #888; margin-bottom: 8px; display: block; font-weight: 700;
  }
  .fn-modal-option-values { display: flex; flex-wrap: wrap; gap: 8px; }
  .fn-opt-btn {
    border: 1px solid #3a3a3d; background: transparent; color: #ccc;
    padding: 6px 14px; font-size: 13px; font-weight: 600;
    cursor: pointer; border-radius: 3px; transition: var(--transition);
    font-family: var(--ff-font-body);
  }
  .fn-opt-btn:hover { border-color: var(--ff-primary); color: var(--ff-primary); }
  .fn-opt-btn.active { border-color: var(--ff-primary); background: rgba(255,176,0,0.12); color: var(--ff-primary); }
  .fn-opt-btn:disabled { opacity: 0.3; cursor: not-allowed; text-decoration: line-through; }

  .fn-opt-color {
    width: 26px; height: 26px; border-radius: 50%;
    border: 2px solid #333; cursor: pointer; transition: var(--transition);
  }
  .fn-opt-color:hover { transform: scale(1.1); }
  .fn-opt-color.active { border-color: var(--ff-primary); box-shadow: 0 0 10px var(--ff-primary); }

  .fn-modal-qty-row { display: flex; align-items: center; justify-content: space-between; margin-top: 4px; }
  .fn-modal-label { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: #888; font-weight: 700; }
  .fn-qty-stepper { display: flex; align-items: center; border: 1px solid #3a3a3d; border-radius: 4px; overflow: hidden; }
  .fn-qty-btn {
    width: 34px; height: 34px; background: transparent; border: none;
    color: #ccc; font-size: 16px; cursor: pointer; transition: var(--transition);
  }
  .fn-qty-btn:hover { background: var(--ff-primary); color: #111; }
  .fn-qty-stepper input {
    width: 44px; height: 34px; background: #1a1a1c;
    border: none; border-left: 1px solid #3a3a3d; border-right: 1px solid #3a3a3d;
    color: #fff; text-align: center; font-weight: 700; font-family: var(--ff-font-body);
  }

  .fn-modal-add {
    position: relative; overflow: hidden;
    background: var(--ff-primary); color: #111; border: none;
    padding: 16px; font-size: 15px; font-weight: 800; letter-spacing: 1px;
    text-transform: uppercase; cursor: pointer;
    clip-path: polygon(14px 0, 100% 0, 100% calc(100% - 14px), calc(100% - 14px) 100%, 0 100%, 0 14px);
    transition: var(--transition);
  }
  .fn-modal-add:hover:not(:disabled) { box-shadow: 0 0 20px rgba(255,176,0,0.4); }
  .fn-modal-add:disabled { background: #3a3a3d; color: #777; cursor: not-allowed; }
  .fn-modal-add-text { position: relative; z-index: 2; }
  .fn-modal-add-progress {
    position: absolute; top: 0; left: 0; height: 100%; width: 0%;
    background: rgba(0,0,0,0.15); transition: width 0.4s ease; z-index: 1;
  }
  .fn-modal-add.loading .fn-modal-add-progress { width: 100%; }

  /* --- TOAST --- */
  .fn-toast {
    position: fixed !important; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(50px);
    background: #111; border: 1px solid var(--ff-primary); color: #fff;
    padding: 12px 25px; border-radius: 30px; font-weight: bold;
    opacity: 0; visibility: hidden; transition: var(--transition); z-index: 10000;
  }
  .fn-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; visibility: visible; }

  /* --- FIRE SPARK (subtle) --- */
  .fn-fire-sparks { position: absolute; bottom: 0; left: 0; width: 100%; height: 220px; overflow: hidden; pointer-events: none; z-index: 1; }
  .fn-spark {
    position: absolute; bottom: -10px; border-radius: 50%;
    background: radial-gradient(circle, #fff6c8 0%, var(--ff-primary) 45%, transparent 80%);
    box-shadow: 0 0 5px 1px rgba(255,140,0,0.4);
    opacity: 0;
    animation-name: fnSparkRise;
    animation-timing-function: ease-in;
    animation-iteration-count: infinite;
  }
  @keyframes fnSparkRise {
    0% { transform: translateY(0) translateX(0) scale(0.6); opacity: 0; }
    15% { opacity: 0.9; }
    100% { transform: translateY(-220px) translateX(var(--drift)) scale(1); opacity: 0; }
  }
  .fn-fire-glowline {
    position: absolute; bottom: 0; left: 0; width: 100%; height: 2px;
    background: linear-gradient(90deg, transparent, #ff6a00, var(--ff-primary), #ff6a00, transparent);
    filter: blur(4px);
    animation: fnGlowPulse 3.2s ease-in-out infinite;
    z-index: 2;
  }
  @keyframes fnGlowPulse { 0%, 100% { opacity: 0.35; } 50% { opacity: 0.85; } }

  /* --- MOBILE --- */
  .fn-mobile-filter-btn { display: none; }
  @media (max-width: 1200px) { .fn-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 990px) {
    .fn-container { flex-direction: column; }
    .fn-sidebar { display: none; }
    .fn-mobile-filter-btn {
      display: inline-block; background: var(--ff-panel); border: 1px solid var(--ff-primary); color: white;
      padding: 10px 20px; border-radius: 6px; margin-bottom: 20px; cursor: pointer; width: 100%;
      transition: var(--transition);
    }
    .fn-sidebar.open {
      display: block; position: fixed; top: 0; left: 0; width: 300px; height: 100%;
      background: #111; z-index: 999; padding: 20px; overflow-y: auto; border-right: 1px solid var(--ff-primary);
    }
    .fn-hero { height: 320px; }
    .fn-hero h1 { font-size: var(--ff-hero-title-mb); }
    .fn-modal-box { flex-direction: column; overflow-y: auto; }
    .fn-modal-media, .fn-modal-info { width: 100%; }
    .fn-modal-media { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .fn-modal-frame { --mcut: 18px; }
  }
  @media (max-width: 768px) {
    .fn-hero-wrapper { padding: 15px 4% 5px; }
    .fn-hero { border-radius: 12px; }
    .fn-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .fn-card-frame { --cut: 12px; }
    .fn-card-inner { padding: 10px; }
    .fn-card-title { font-size: var(--ff-card-title-mb); }
    .fn-price { font-size: var(--ff-price-mb); }
    .fn-cart-btn { width: 34px; height: 34px; }
    .fn-fire-sparks { height: 140px; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }
</style>

<div class="fn-section-{{ section.id }}">

  {%- if section.settings.section_bg_image != blank -%}
    <div class="fn-section-bg-image" style="background-image: url('{{ section.settings.section_bg_image | image_url: width: 1920 }}');"></div>
  {%- endif -%}

  <!-- HERO BANNER (CARD) -->
  <div class="fn-hero-wrapper">
    <div class="fn-hero {% if section.settings.banner_image == blank %}fn-hero-noimg{% endif %}"
      {% if section.settings.banner_image != blank %}
        style="background-image: url('{{ section.settings.banner_image | image_url: width: 1800 }}');"
      {% endif %}>
      <div class="fn-hero-shine"></div>
      <div class="fn-hero-content">
        <div class="fn-hero-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13h-13L12 6.5z"/></svg>
          Our Collection
        </div>
        <h1>{{ section.settings.heading_highlight }} <span>{{ section.settings.heading_main }}</span></h1>
        <p>{{ section.settings.subtitle }}</p>
      </div>
    </div>
  </div>

  <div class="fn-container">

    <button class="fn-mobile-filter-btn" onclick="document.getElementById('fn-sidebar').classList.toggle('open')">Toggle Filters</button>

    <!-- SIDEBAR (NATIVE SHOPIFY FILTERS) -->
    <aside class="fn-sidebar" id="fn-sidebar">
      <form class="fn-filter-form" id="fn-filter-form">
        {%- for filter in target_collection.filters -%}
          <div class="fn-filter-widget">
            <h3 class="fn-filter-title">{{ filter.label }}</h3>
            {%- case filter.type -%}
              {%- when 'list' -%}
                {%- if filter.label == 'Color' or filter.label == 'Colour' -%}
                  <div class="fn-color-swatches">
                    {%- for value in filter.values -%}
                      <label title="{{ value.label }}">
                        <input type="checkbox" class="fn-filter-checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %}>
                        <div class="fn-color-box" style="background-color: {{ value.label | downcase }};"></div>
                      </label>
                    {%- endfor -%}
                  </div>
                {%- elsif filter.label == 'Size' -%}
                  <div class="fn-size-swatches">
                    {%- for value in filter.values -%}
                      <label>
                        <input type="checkbox" class="fn-filter-checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %}>
                        <div class="fn-size-box">{{ value.label }}</div>
                      </label>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <ul class="fn-filter-list">
                    {%- for value in filter.values -%}
                      <li>
                        <label class="fn-filter-label">
                          <span>{{ value.label }}</span>
                          <span>{{ value.count }}</span>
                          <input type="checkbox" class="fn-filter-checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %}>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              {%- when 'price_range' -%}
                <div style="display: flex; gap: 10px; align-items: center;">
                  <span style="color:var(--ff-primary);">$</span>
                  <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}" placeholder="Min" style="width:100%; background:#222; border:1px solid #444; color:#fff; padding:5px; border-radius:4px;">
                  <span>-</span>
                  <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}" placeholder="Max" style="width:100%; background:#222; border:1px solid #444; color:#fff; padding:5px; border-radius:4px;">
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}
        {% if target_collection.filters.size > 0 %}
          <button type="submit" style="display:none;">Apply</button>
          <button type="button" onclick="window.location.href='{{ target_collection.url }}'" style="width:100%; background:transparent; border:1px solid #444; color:#ccc; padding:10px; border-radius:4px; cursor:pointer; text-transform:uppercase; transition: var(--transition);">Clear All</button>
        {% endif %}
      </form>
    </aside>

    <!-- MAIN AREA -->
    <main class="fn-main">
      {%- paginate target_collection.products by section.settings.products_per_page -%}

      <div class="fn-toolbar">
        <div class="fn-toolbar-count">
          Showing {{ paginate.current_offset | plus: 1 }} - {% if paginate.next %}{{ paginate.current_offset | plus: section.settings.products_per_page }}{% else %}{{ paginate.items }}{% endif %} of {{ paginate.items }} Products
        </div>
        <div class="fn-toolbar-actions">
          <span style="color:#888; font-size:14px; text-transform:uppercase;">Sort By:</span>
          <select id="fn-sort-select" class="fn-select">
            <option value="manual">Featured</option>
            <option value="best-selling">Best Selling</option>
            <option value="title-ascending">Alphabetically, A-Z</option>
            <option value="price-ascending">Price, low to high</option>
            <option value="price-descending">Price, high to low</option>
            <option value="created-descending">Date, new to old</option>
          </select>
        </div>
      </div>

      <!-- Product Grid -->
      <div class="fn-grid">
        {%- for product in target_collection.products -%}
          {% assign badge_class = "" %}
          {% assign badge_text = "" %}
          {% if product.tags contains 'New' %}
            {% assign badge_class = "bg-purple" %}{% assign badge_text = "NEW" %}
          {% elsif product.tags contains 'Limited' %}
            {% assign badge_class = "bg-blue" %}{% assign badge_text = "LIMITED" %}
          {% elsif product.tags contains 'Hot' %}
            {% assign badge_class = "bg-orange" %}{% assign badge_text = "HOT" %}
          {% elsif product.compare_at_price > product.price %}
            {% assign badge_class = "bg-red" %}
            {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
            {% assign badge_text = "-" | append: discount | append: "%" %}
          {% endif %}

          {% assign delay_idx = forloop.index0 | modulo: 4 %}

          <div class="fn-card-frame" style="transition-delay: {{ delay_idx | times: 0.07 }}s;" onclick="cardClick(event, '{{ product.handle }}')">
            <div class="fn-card-inner">
              {% if badge_text != "" %}
                <div class="fn-card-badge {{ badge_class }}">{{ badge_text }}</div>
              {% endif %}
              <span class="fn-card-id">#{{ forloop.index }}</span>

              <div class="fn-card-img-wrap">
                <div class="fn-corner fn-corner-tl"></div>
                <div class="fn-corner fn-corner-br"></div>
                <div class="fn-scan-line"></div>
                {%- if product.featured_image != blank -%}
                  <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" class="fn-card-img" loading="lazy">
                {%- else -%}
                  <div class="fn-no-image"><span>No Image</span></div>
                {%- endif -%}
              </div>

              <h3 class="fn-card-title">{{ product.title }}</h3>
              <div class="fn-card-stars">★★★★★ <span>(128)</span></div>
              <div class="fn-card-divider"></div>

              <div class="fn-card-bottom">
                <div class="fn-card-price-wrap">
                  <span class="fn-price">{{ product.price | money }}</span>
                  {% if product.compare_at_price > product.price %}
                    <span class="fn-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
                <button class="fn-cart-btn" onclick="event.stopPropagation(); addIconToCart(event, {{ product.variants.first.id }})" aria-label="Add to cart">
                  <svg class="cart-icon" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
                  <svg class="spinner-icon" viewBox="0 0 50 50" style="display:none;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="80" stroke-dashoffset="60"/></svg>
                  <svg class="check-icon" viewBox="0 0 24 24" style="display:none;"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                </button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="display:flex; justify-content:center; gap:10px; margin-top:40px;">
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" style="background:#222; padding:10px 15px; color:white; text-decoration:none; border-radius:4px; transition: var(--transition);">{{ part.title }}</a>
            {%- else -%}
              <span style="background:var(--ff-primary); color:#111; padding:10px 15px; border-radius:4px; font-weight:bold;">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- endpaginate -%}
    </main>
  </div>

  {%- if section.settings.enable_fire_effect -%}
    <div class="fn-fire-glowline"></div>
    <div class="fn-fire-sparks" id="fn-fire-sparks"></div>
  {%- endif -%}
</div>

<!-- QUICK VIEW MODAL (UNIQUE HUD DESIGN) -->
<div class="fn-modal-overlay" id="fn-quickview">
  <div class="fn-modal-frame">
    <div class="fn-modal-box">
      <button class="fn-modal-close" onclick="closeQuickView()">✕</button>

      <div class="fn-modal-media">
        <div class="fn-modal-media-frame" id="qv-img-wrap">
          <div class="fn-corner fn-corner-tl"></div>
          <div class="fn-corner fn-corner-br"></div>
          <div class="fn-modal-stock-tag" id="qv-stock"><span class="dot"></span><span id="qv-stock-text">IN STOCK</span></div>
          <img id="qv-img" src="" alt="">
        </div>
        <div class="fn-modal-thumbs" id="qv-thumbs"></div>
      </div>

      <div class="fn-modal-info">
        <div class="fn-modal-info-scroll">
          <span class="fn-modal-tag" id="qv-vendor">LOADOUT ITEM</span>
          <h2 class="fn-modal-title" id="qv-title">Loading Drop...</h2>
          <div class="fn-modal-stars">★★★★★ <span>(128 Reviews)</span></div>

          <div class="fn-modal-price-row">
            <span class="fn-modal-price" id="qv-price"></span>
            <span class="fn-modal-compare" id="qv-compare"></span>
            <span class="fn-modal-discount" id="qv-discount" style="display:none;"></span>
          </div>

          <div class="fn-modal-divider"></div>
          <div class="fn-modal-desc" id="qv-desc"></div>

          <div class="fn-modal-options" id="qv-options"></div>

          <div class="fn-modal-qty-row">
            <span class="fn-modal-label">Quantity</span>
            <div class="fn-qty-stepper">
              <button type="button" class="fn-qty-btn" id="qv-qty-minus">−</button>
              <input type="number" id="qv-qty" value="1" min="1" readonly>
              <button type="button" class="fn-qty-btn" id="qv-qty-plus">+</button>
            </div>
          </div>
        </div>

        <button class="fn-modal-add" id="qv-add-btn" onclick="addFromModal()">
          <span class="fn-modal-add-text" id="qv-add-text">ADD TO INVENTORY</span>
          <span class="fn-modal-add-progress"></span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="fn-toast" id="fn-toast">✔ Successfully added to inventory</div>

<script>
  /* ================= SOUND FX (Web Audio API — no files needed) ================= */
  const SoundFX = (function() {
    const enabled = {{ section.settings.enable_sound_effects | json }};
    let ctx;
    function getCtx() {
      if (!ctx) ctx = new (window.AudioContext || window.webkitAudioContext)();
      if (ctx.state === 'suspended') ctx.resume();
      return ctx;
    }
    function tone(freq, duration, type, volume, delay) {
      if (!enabled) return;
      try {
        const context = getCtx();
        const startTime = context.currentTime + (delay || 0);
        const osc = context.createOscillator();
        const gain = context.createGain();
        osc.type = type || 'sine';
        osc.frequency.setValueAtTime(freq, startTime);
        gain.gain.setValueAtTime(volume || 0.08, startTime);
        gain.gain.exponentialRampToValueAtTime(0.001, startTime + duration);
        osc.connect(gain);
        gain.connect(context.destination);
        osc.start(startTime);
        osc.stop(startTime + duration);
      } catch (e) {}
    }
    return {
      click: () => tone(520, 0.08, 'triangle', 0.06),
      open: () => { tone(300, 0.09, 'sine', 0.07); tone(500, 0.12, 'sine', 0.06, 0.05); },
      close: () => tone(220, 0.1, 'sine', 0.05),
      addToCart: () => { tone(600, 0.08, 'sine', 0.08); tone(950, 0.14, 'sine', 0.08, 0.09); },
      error: () => tone(150, 0.2, 'sawtooth', 0.06)
    };
  })();

  document.addEventListener('DOMContentLoaded', () => {
    const sortSelect = document.getElementById('fn-sort-select');
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('sort_by')) sortSelect.value = urlParams.get('sort_by');

    sortSelect.addEventListener('change', function() {
      urlParams.set('sort_by', this.value);
      window.location.search = urlParams.toString();
    });

    const filterForm = document.getElementById('fn-filter-form');
    if (filterForm) {
      filterForm.querySelectorAll('input').forEach(input => {
        input.addEventListener('change', () => { filterForm.submit(); });
      });
    }

    const cards = document.querySelectorAll('.fn-card-frame');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      cards.forEach(card => observer.observe(card));
    } else {
      cards.forEach(card => card.classList.add('is-visible'));
    }

    createFireSparks();

    // Quantity Stepper
    const qtyInput = document.getElementById('qv-qty');
    document.getElementById('qv-qty-minus').addEventListener('click', () => {
      let val = parseInt(qtyInput.value) || 1;
      if (val > 1) qtyInput.value = val - 1;
      SoundFX.click();
    });
    document.getElementById('qv-qty-plus').addEventListener('click', () => {
      let val = parseInt(qtyInput.value) || 1;
      qtyInput.value = val + 1;
      SoundFX.click();
    });
  });

  function createFireSparks() {
    const container = document.getElementById('fn-fire-sparks');
    if (!container) return;
    const count = window.innerWidth < 768 ? 14 : 26;
    for (let i = 0; i < count; i++) {
      const spark = document.createElement('span');
      spark.className = 'fn-spark';
      const left = Math.random() * 100;
      const size = (Math.random() * 3.5 + 2).toFixed(1);
      const duration = (Math.random() * 3 + 3.5).toFixed(2);
      const delay = (Math.random() * 6).toFixed(2);
      const drift = (Math.random() * 50 - 25).toFixed(0) + 'px';
      spark.style.left = left + '%';
      spark.style.width = size + 'px';
      spark.style.height = size + 'px';
      spark.style.animationDuration = duration + 's';
      spark.style.animationDelay = delay + 's';
      spark.style.setProperty('--drift', drift);
      container.appendChild(spark);
    }
  }

  /* ================= CARD CLICK -> OPEN QUICK VIEW ================= */
  function cardClick(event, handle) {
    SoundFX.click();
    openQuickView(handle);
  }

  /* ================= AJAX ADD TO CART (CARD ICON) ================= */
  function addIconToCart(event, variantId) {
    const btn = event.currentTarget;
    const cartIcon = btn.querySelector('.cart-icon');
    const spinnerIcon = btn.querySelector('.spinner-icon');
    const checkIcon = btn.querySelector('.check-icon');

    cartIcon.style.display = 'none';
    spinnerIcon.style.display = 'block';

    let formData = { 'items': [{ 'id': variantId, 'quantity': 1 }] };

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    })
    .then(res => res.json())
    .then(data => {
      spinnerIcon.style.display = 'none';
      checkIcon.style.display = 'block';
      SoundFX.addToCart();
      showToast();
      document.dispatchEvent(new CustomEvent('cart:build'));
      setTimeout(() => {
        checkIcon.style.display = 'none';
        cartIcon.style.display = 'block';
      }, 2000);
    })
    .catch(() => {
      SoundFX.error();
      alert("Error adding item to cart.");
      spinnerIcon.style.display = 'none';
      cartIcon.style.display = 'block';
    });
  }

  /* ================= QUICK VIEW MODAL LOGIC ================= */
  const modal = document.getElementById('fn-quickview');
  let currentProduct = null;
  let currentVariant = null;
  let selectedOptions = [];

  function openQuickView(handle) {
    modal.classList.add('active');
    SoundFX.open();
    document.body.style.overflow = 'hidden';

    const titleEl = document.getElementById('qv-title');
    titleEl.classList.remove('loaded');
    titleEl.innerText = "Loading Drop...";
    document.getElementById('qv-price').innerText = "";
    document.getElementById('qv-compare').innerText = "";
    document.getElementById('qv-discount').style.display = 'none';
    document.getElementById('qv-desc').innerHTML = "";
    document.getElementById('qv-options').innerHTML = "";
    document.getElementById('qv-thumbs').innerHTML = "";
    document.getElementById('qv-qty').value = 1;
    document.getElementById('qv-img').src = "";

    fetch(`/products/${handle}.js`)
      .then(res => res.json())
      .then(product => {
        currentProduct = product;
        renderModalProduct(product);
      })
      .catch(err => console.error("Error fetching product data", err));
  }

  function renderModalProduct(product) {
    document.getElementById('qv-vendor').innerText = product.vendor || 'LOADOUT ITEM';
    const titleEl = document.getElementById('qv-title');
    titleEl.innerText = product.title;
    titleEl.classList.add('loaded');

    let cleanDesc = (product.description || '').replace(/(<([^>]+)>)/gi, "");
    document.getElementById('qv-desc').innerHTML = cleanDesc || 'No description available.';

    const thumbWrap = document.getElementById('qv-thumbs');
    thumbWrap.innerHTML = "";
    const images = product.images && product.images.length ? product.images : (product.featured_image ? [product.featured_image] : []);
    images.forEach((imgSrc, idx) => {
      const thumb = document.createElement('div');
      thumb.className = 'fn-modal-thumb' + (idx === 0 ? ' active' : '');
      thumb.innerHTML = `<img src="${imgSrc}" alt="">`;
      thumb.onclick = () => {
        document.getElementById('qv-img').src = imgSrc;
        thumbWrap.querySelectorAll('.fn-modal-thumb').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
        SoundFX.click();
      };
      thumbWrap.appendChild(thumb);
    });

    const defaultVariant = product.variants.find(v => v.available) || product.variants[0];
    selectedOptions = [defaultVariant.option1, defaultVariant.option2, defaultVariant.option3].filter(Boolean);

    document.getElementById('qv-img').src = defaultVariant.featured_image ? defaultVariant.featured_image.src : (images[0] || '');

    renderOptions(product);
    updateVariantDisplay(defaultVariant);
  }

  function renderOptions(product) {
    const wrap = document.getElementById('qv-options');
    wrap.innerHTML = "";

    const hasRealOptions = !(product.options.length === 1 && product.options[0] === 'Title');
    if (!hasRealOptions) return;

    product.options.forEach((optionName, index) => {
      const values = [...new Set(product.variants.map(v => v['option' + (index + 1)]))];
      const isColor = /color|colour/i.test(optionName);

      const group = document.createElement('div');
      group.className = 'fn-modal-option-group';
      group.innerHTML = `<span class="fn-modal-option-label">${optionName}</span>`;

      const valuesWrap = document.createElement('div');
      valuesWrap.className = 'fn-modal-option-values';

      values.forEach(val => {
        const isActive = selectedOptions[index] === val;
        const btn = document.createElement(isColor ? 'div' : 'button');
        btn.type = 'button';
        btn.className = (isColor ? 'fn-opt-color' : 'fn-opt-btn') + (isActive ? ' active' : '');
        if (isColor) {
          btn.style.backgroundColor = val.toLowerCase();
          btn.title = val;
        } else {
          btn.innerText = val;
        }
        btn.addEventListener('click', () => {
          SoundFX.click();
          selectedOptions[index] = val;
          renderOptions(product);
          const match = product.variants.find(v =>
            [v.option1, v.option2, v.option3].filter(Boolean).every((o, i) => o === selectedOptions[i])
          );
          if (match) updateVariantDisplay(match);
        });
        valuesWrap.appendChild(btn);
      });

      group.appendChild(valuesWrap);
      wrap.appendChild(group);
    });
  }

  function updateVariantDisplay(variant) {
    currentVariant = variant;

    document.getElementById('qv-price').innerText = "$" + (variant.price / 100).toFixed(2);

    const compareEl = document.getElementById('qv-compare');
    const discountEl = document.getElementById('qv-discount');
    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      compareEl.innerText = "$" + (variant.compare_at_price / 100).toFixed(2);
      const discount = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
      discountEl.innerText = "-" + discount + "%";
      discountEl.style.display = 'inline-block';
    } else {
      compareEl.innerText = "";
      discountEl.style.display = 'none';
    }

    const stockTag = document.getElementById('qv-stock');
    const stockText = document.getElementById('qv-stock-text');
    const addBtn = document.getElementById('qv-add-btn');
    const addText = document.getElementById('qv-add-text');

    if (variant.available) {
      stockTag.classList.remove('out');
      stockText.innerText = 'IN STOCK';
      addBtn.disabled = false;
      addText.innerText = 'ADD TO INVENTORY';
    } else {
      stockTag.classList.add('out');
      stockText.innerText = 'OUT OF STOCK';
      addBtn.disabled = true;
      addText.innerText = 'UNAVAILABLE';
    }

    if (variant.featured_image && variant.featured_image.src) {
      document.getElementById('qv-img').src = variant.featured_image.src;
    }
  }

  function closeQuickView() {
    modal.classList.remove('active');
    document.body.style.overflow = '';
    SoundFX.close();
  }

  function addFromModal() {
    if (!currentVariant || !currentVariant.available) return;

    const qty = document.getElementById('qv-qty').value;
    const btn = document.getElementById('qv-add-btn');
    const addText = document.getElementById('qv-add-text');
    const ogText = addText.innerText;

    btn.classList.add('loading');
    addText.innerText = "EQUIPPING...";

    let formData = { 'items': [{ 'id': currentVariant.id, 'quantity': parseInt(qty) }] };

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    })
    .then(() => {
      addText.innerText = "EQUIPPED!";
      SoundFX.addToCart();
      showToast();
      document.dispatchEvent(new CustomEvent('cart:build'));
      setTimeout(() => {
        closeQuickView();
        btn.classList.remove('loading');
        addText.innerText = ogText;
      }, 900);
    })
    .catch(() => {
      SoundFX.error();
      btn.classList.remove('loading');
      addText.innerText = ogText;
    });
  }

  function showToast() {
    const toast = document.getElementById('fn-toast');
    toast.classList.add('show');
    setTimeout(() => { toast.classList.remove('show'); }, 3000);
  }
</script>

