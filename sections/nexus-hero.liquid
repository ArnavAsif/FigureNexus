  .ff-badge {
    position: absolute; z-index: 7; font-weight: 700; letter-spacing: 0.5px;
    font-size: 10px; padding: 5px 10px; border-radius: 16px; text-transform: uppercase;
    line-height: 1;
  }
  .ff-badge-hot {
