    font-size: 0.88rem; color: #777; line-height: 1.7; margin-bottom: 28px;
  }
  .nexus-modal__qty-row {
    display: flex; align-items: center; gap: 16px; margin-bottom: 28px;
  }
  .nexus-modal__qty-label {
    font-family: 'Poppins', 'Montserrat', sans-serif;
    font-size: 0.75rem; font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; color: #999;
  }
  .nexus-modal__qty {
    display: flex; align-items: center; border: 2px solid #eee;
    border-radius: 10px; overflow: hidden;
  }
  .nexus-modal__qty-btn {
    width: 38px; height: 38px; border: none; background: #f8f8f8;
    font-size: 1.1rem; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
