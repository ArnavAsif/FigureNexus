    text-decoration: line-through;
  }
  .ff-price-now {
    font-family: 'Orbitron', sans-serif; font-size: 22px; font-weight: 900;
    color: #ffe08a; animation: ffPriceGlow 2.4s ease-in-out infinite;
    letter-spacing: 0.2px;
