  .nx-sf-size-box:hover { border-color: var(--nx-gold); color: var(--nx-gold); }
  .nx-sf-fc:checked + .nx-sf-size-box { border-color: var(--nx-gold); color: var(--nx-gold); background: rgba(255,176,0,0.08); }

  .nx-sf-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

  .nx-sf-card { --cut: 18px; clip-path: polygon(var(--cut) 0, 100% 0, 100% calc(100% - var(--cut)), calc(100% - var(--cut)) 100%, 0 100%, 0 var(--cut)); background: var(--nx-glass-border); padding: 1px; cursor: pointer; transition: background 0.35s ease, transform 0.35s ease; position: relative; }
  .nx-sf-card:hover { background: linear-gradient(135deg, var(--nx-gold), rgba(255,176,0,0.15)); transform: translateY(-6px); }
  .nx-sf-card-inner { clip-path: polygon(var(--cut) 0, 100% 0, 100% calc(100% - var(--cut)), calc(100% - var(--cut)) 100%, 0 100%, 0 var(--cut)); background: var(--nx-bg-elevated); padding: 14px; height: 100%; display: flex; flex-direction: column; }
  .nx-sf-card-id { position: absolute; top: 10px; right: 14px; font-size: 10px; color: #555; letter-spacing: 1px; font-weight: 700; z-index: 2; }
  .nx-sf-badge-tag { position: absolute; top: 12px; left: 0; font-size: 10px; font-weight: bold; padding: 4px 14px 4px 10px; z-index: 3; text-transform: uppercase; clip-path: polygon(0 0, 100% 0, 82% 100%, 0% 100%); }
  .nx-sf-bg-purple { background: #8000FF; color: white; }
  .nx-sf-bg-red { background: #FF3333; color: white; }
  .nx-sf-bg-orange { background: #FF6600; color: white; }
  .nx-sf-bg-blue { background: #0055FF; color: white; }

  .nx-sf-card-img-wrap { width: 100%; aspect-ratio: 1/1; margin-bottom: 14px; overflow: hidden; position: relative; background: linear-gradient(135deg, #1c1c1f, #0c0c0d); }
  .nx-sf-card-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease, filter 0.5s ease; }
  .nx-sf-card:hover .nx-sf-card-img { transform: scale(1.06); filter: brightness(0.8) saturate(1.1); }
  .nx-sf-no-image { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1c1c1f, #0c0c0d); }
  .nx-sf-no-image span { color: #555; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }
  .nx-sf-corner { position: absolute; width: 16px; height: 16px; border-color: rgba(255,255,255,0.18); transition: border-color 0.35s ease; z-index: 2; }
  .nx-sf-corner-tl { top: 6px; left: 6px; border-top: 2px solid; border-left: 2px solid; }
  .nx-sf-corner-br { bottom: 6px; right: 6px; border-bottom: 2px solid; border-right: 2px solid; }
  .nx-sf-card:hover .nx-sf-corner { border-color: var(--nx-gold); }
  .nx-sf-scanline { position: absolute; left: 0; top: -10%; width: 100%; height: 2px; background: linear-gradient(90deg, transparent, var(--nx-gold), transparent); opacity: 0; z-index: 2; }
  .nx-sf-card:hover .nx-sf-scanline { animation: fnScan 1.4s linear infinite; }

  .nx-sf-card-title { font-size: 16px; color: #fff; margin: 0 0 6px 0; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .nx-sf-card-stars { color: var(--nx-gold); font-size: 12px; margin-bottom: 10px; }
  .nx-sf-card-stars span { color: #666; }
  .nx-sf-card-divider { height: 1px; width: 30%; background: var(--nx-glass-border); margin-bottom: 12px; position: relative; overflow: hidden; }
  .nx-sf-card-divider::after { content: ''; position: absolute; top: 0; left: 0; height: 100%; width: 0%; background: var(--nx-gold); transition: width 0.45s ease; }
  .nx-sf-card:hover .nx-sf-card-divider::after { width: 100%; }

  .nx-sf-card-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
  .nx-sf-price-wrap { display: flex; align-items: center; gap: 8px; }
  .nx-sf-price { font-size: 20px; font-weight: bold; color: #fff; }
  .nx-sf-compare { font-size: 14px; color: #666; text-decoration: line-through; }
  .nx-sf-cart-btn { width: 42px; height: 42px; border: none; background: rgba(255,176,0,0.08); clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%); color: var(--nx-gold); display: flex; justify-content: center; align-items: center; cursor: pointer; z-index: 5; }
  .nx-sf-cart-btn:hover { background: var(--nx-gold); color: #111; transform: scale(1.08); }
  .nx-sf-cart-btn svg { width: 17px; fill: currentColor; }
  .nx-sf-spinner { animation: spin 1s linear infinite; }

  /* Quick View Modal */
  .nx-sf-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.82); backdrop-filter: blur(8px); z-index: 10001; display: flex; justify-content: center; align-items: center; padding: 20px; opacity: 0; visibility: hidden; transition: opacity 0.3s ease, visibility 0.3s ease; }
  .nx-sf-modal-overlay.active { opacity: 1; visibility: visible; }
  .nx-sf-modal-frame { --mcut: 26px; position: relative; width: 960px; max-width: 100%; clip-path: polygon(var(--mcut) 0, 100% 0, 100% calc(100% - var(--mcut)), calc(100% - var(--mcut)) 100%, 0 100%, 0 var(--mcut)); background: linear-gradient(135deg, var(--nx-gold), rgba(255,255,255,0.06) 45%, var(--nx-gold) 100%); padding: 1.5px; transform: scale(0.94) translateY(10px); opacity: 0; transition: transform 0.35s cubic-bezier(.2,.8,.2,1), opacity 0.3s ease; }
  .nx-sf-modal-overlay.active .nx-sf-modal-frame { transform: scale(1) translateY(0); opacity: 1; }
  .nx-sf-modal-box { clip-path: polygon(var(--mcut) 0, 100% 0, 100% calc(100% - var(--mcut)), calc(100% - var(--mcut)) 100%, 0 100%, 0 var(--mcut)); background: #111113; display: flex; max-height: 88vh; overflow: hidden; }
  .nx-sf-modal-close { position: absolute; top: 16px; right: 16px; width: 38px; height: 38px; background: rgba(255,255,255,0.06); clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%); border: none; color: #fff; font-size: 15px; cursor: pointer; z-index: 20; display: flex; align-items: center; justify-content: center; transition: all 0.28s; }
  .nx-sf-modal-close:hover { background: var(--nx-gold); color: #111; transform: scale(1.08); }
  .nx-sf-modal-media { width: 46%; background: #0a0a0b; display: flex; flex-direction: column; gap: 12px; padding: 22px; border-right: 1px solid rgba(255,255,255,0.06); }
  .nx-sf-modal-media-frame { position: relative; flex: 1; min-height: 260px; overflow: hidden; border-radius: 4px; background: linear-gradient(135deg, #1c1c1f, #0c0c0d); }
  .nx-sf-modal-media-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .nx-sf-modal-media-frame .nx-sf-corner { border-color: rgba(255,176,0,0.5); }
  .nx-sf-stock-tag { position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.65); backdrop-filter: blur(4px); border: 1px solid rgba(92,255,160,0.4); color: #5CFFA0; font-size: 10px; font-weight: 700; letter-spacing: 1px; padding: 5px 10px; border-radius: 3px; display: flex; align-items: center; gap: 6px; text-transform: uppercase; z-index: 5; }
  .nx-sf-stock-dot { width: 6px; height: 6px; border-radius: 50%; background: #5CFFA0; box-shadow: 0 0 6px #5CFFA0; }
  .nx-sf-modal-thumbs { display: flex; gap: 8px; overflow-x: auto; }
  .nx-sf-modal-thumb { width: 54px; height: 54px; flex-shrink: 0; border: 1px solid var(--nx-glass-border); border-radius: 3px; overflow: hidden; cursor: pointer; opacity: 0.55; transition: all 0.28s; }
  .nx-sf-modal-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .nx-sf-modal-thumb:hover { opacity: 0.9; }
  .nx-sf-modal-thumb.active { border-color: var(--nx-gold); opacity: 1; box-shadow: 0 0 8px rgba(255,176,0,0.35); }
  .nx-sf-modal-info { width: 54%; display: flex; flex-direction: column; padding: 30px 32px 22px; }
  .nx-sf-modal-info-scroll { flex: 1; overflow-y: auto; padding-right: 8px; margin-bottom: 18px; }
  .nx-sf-modal-tag { display: inline-block; font-size: 11px; letter-spacing: 2px; color: var(--nx-gold); text-transform: uppercase; font-weight: 700; margin-bottom: 8px; }
  .nx-sf-modal-title { font-family: 'Orbitron', sans-serif; font-size: 28px; text-transform: uppercase; margin: 0 0 8px 0; line-height: 1.08; }
  .nx-sf-modal-stars { color: var(--nx-gold); font-size: 13px; margin-bottom: 14px; }
  .nx-sf-modal-stars span { color: #666; }
  .nx-sf-modal-price-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
  .nx-sf-modal-price { font-size: 25px; font-weight: 800; color: #fff; }
  .nx-sf-modal-compare { font-size: 15px; color: #666; text-decoration: line-through; }
  .nx-sf-modal-discount { font-size: 11px; font-weight: 700; background: rgba(255,51,51,0.15); color: #FF6B6B; padding: 3px 8px; border-radius: 3px; text-transform: uppercase; }
  .nx-sf-modal-divider { height: 1px; background: linear-gradient(90deg, var(--nx-glass-border), transparent); margin-bottom: 16px; }
  .nx-sf-modal-desc { color: #9a9a9d; font-size: 14px; line-height: 1.7; margin-bottom: 18px; }
  .nx-sf-modal-option-group { margin-bottom: 16px; }
  .nx-sf-modal-option-label { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: #888; margin-bottom: 8px; display: block; font-weight: 700; }
  .nx-sf-modal-option-values { display: flex; flex-wrap: wrap; gap: 8px; }
  .nx-sf-opt-btn { border: 1px solid #3a3a3d; background: transparent; color: #ccc; padding: 6px 14px; font-size: 13px; font-weight: 600; cursor: pointer; border-radius: 3px; transition: all 0.28s; }
  .nx-sf-opt-btn:hover { border-color: var(--nx-gold); color: var(--nx-gold); }
  .nx-sf-opt-color { width: 26px; height: 26px; border-radius: 50%; border: 2px solid #333; cursor: pointer; transition: all 0.28s; }
  .nx-sf-opt-color:hover { transform: scale(1.1); }
  .nx-sf-modal-qty-row { display: flex; align-items: center; justify-content: space-between; margin-top: 4px; }
  .nx-sf-modal-label { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: #888; font-weight: 700; }
  .nx-sf-qty-stepper { display: flex; align-items: center; border: 1px solid #3a3a3d; border-radius: 4px; overflow: hidden; }
  .nx-sf-qty-btn { width: 34px; height: 34px; background: transparent; border: none; color: #ccc; font-size: 16px; cursor: pointer; }
  .nx-sf-qty-btn:hover { background: var(--nx-gold); color: #111; }
  .nx-sf-qty-stepper input { width: 44px; height: 34px; background: #1a1a1c; border: none; border-left: 1px solid #3a3a3d; border-right: 1px solid #3a3a3d; color: #fff; text-align: center; font-weight: 700; }
  .nx-sf-modal-add { background: var(--nx-gold); color: #111; border: none; padding: 16px; font-size: 15px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; clip-path: polygon(14px 0, 100% 0, 100% calc(100% - 14px), calc(100% - 14px) 100%, 0 100%, 0 14px); }
  .nx-sf-modal-add:hover:not(:disabled) { box-shadow: 0 0 20px rgba(255,176,0,0.4); }
  .nx-sf-modal-add:disabled { background: #3a3a3d; color: #777; cursor: not-allowed; }
  .nx-sf-toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(50px); background: #111; border: 1px solid var(--nx-gold); color: #fff; padding: 12px 25px; border-radius: 30px; font-weight: bold; opacity: 0; visibility: hidden; transition: all 0.28s; z-index: 10002; }
  .nx-sf-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; visibility: visible; }
  .nx-sf-sparks { position: absolute; bottom: 0; left: 0; width: 100%; height: 220px; overflow: hidden; pointer-events: none; z-index: 1; }
  .nx-sf-spark { position: absolute; bottom: -10px; border-radius: 50%; background: radial-gradient(circle, #fff6c8 0%, var(--nx-gold) 45%, transparent 80%); box-shadow: 0 0 5px 1px rgba(255,140,0,0.4); opacity: 0; animation: fnSparkRise ease-in infinite; }
  .nx-sf-glowline { position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background: linear-gradient(90deg, transparent, #ff6a00, var(--nx-gold), #ff6a00, transparent); filter: blur(4px); z-index: 2; }
  .nx-sf-mobile-filter { display: none; background: var(--nx-bg-card); border: 1px solid var(--nx-gold); color: white; padding: 10px 20px; border-radius: 6px; margin-bottom: 20px; cursor: pointer; width: 100%; }

  @media (max-width: 1200px) { .nx-sf-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 990px) {
    .nx-sf-container { flex-direction: column; }
    .nx-sf-sidebar { display: none; }
    .nx-sf-mobile-filter { display: block; }
    .nx-sf-sidebar.open { display: block; position: fixed; top: 0; left: 0; width: 300px; height: 100%; background: #111; z-index: 999; padding: 20px; overflow-y: auto; border-right: 1px solid var(--nx-gold); }
    .nx-sf-hero { height: 280px; }
    .nx-sf-modal-box { flex-direction: column; overflow-y: auto; }
    .nx-sf-modal-media, .nx-sf-modal-info { width: 100%; }
