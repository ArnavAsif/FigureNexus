    box-shadow: 0 8px 30px rgba(255,90,0,0.4);
  }
  @media (max-width: 640px) {
    .nexus-modal { flex-direction: column; max-height: 90vh; border-radius: 20px; }
    .nexus-modal__left { flex: none; height: 240px; }
