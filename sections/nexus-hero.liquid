  .ff-content { position: relative; padding: 14px 16px 16px; z-index: 2; }

  .ff-title {
    margin: 0 0 4px; font-family: 'Poppins', sans-serif; font-size: 15px;
    font-weight: 700; color: #f4f1ea; letter-spacing: 0.2px; line-height: 1.3;
