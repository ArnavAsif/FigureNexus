{%- comment -%}
  NEXUS LOBBY — Premium Gaming Lobby Hero Section
  Each card is a block with full customization
{%- endcomment -%}

{%- assign nexus_id = section.id | replace: '_', '-' -%}

{%- if section.settings.loading_image != blank -%}
  {%- assign loading_img_url = section.settings.loading_image | image_url: width: 1920 -%}
{%- endif -%}
{%- if section.settings.bg_image != blank -%}
  {%- assign bg_url = section.settings.bg_image | image_url: width: 1920 -%}
{%- endif -%}
{%- if section.settings.center_character != blank -%}
  {%- assign char_url = section.settings.center_character | image_url: width: 1200 -%}
{%- endif -%}

{%- if request.page_type == 'index' -%}
<style id="nexus-lock-homepage">
  html, body {
    overflow: hidden !important;
    height: 100vh !important;
    max-height: 100vh !important;
    position: fixed !important;
    width: 100% !important;
    top: 0 !important;
    left: 0 !important;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
  }
  html::-webkit-scrollbar, body::-webkit-scrollbar,
  html::-webkit-scrollbar-thumb, body::-webkit-scrollbar-track {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }
  .shopify-section {
    overflow: hidden !important;
    height: 100vh !important;
    max-height: 100vh !important;
  }
  .shopify-section-group-header-group,
  .shopify-section-group-footer-group,
  .header-group, .footer-group {
    display: none !important;
  }
  .skip-to-content-link,
  #web-pixels-manager-sandbox-container {
    display: none !important;
    visibility: hidden !important;
    width: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
    position: absolute !important;
    left: -9999px !important;
    pointer-events: none !important;
    z-index: -99999 !important;
  }
</style>
{%- endif -%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap');

  :root {
    --nx-primary: {{ section.settings.primary_color | default: '#FFC72C' }};
    --nx-accent: {{ section.settings.accent_color | default: '#FF7A00' }};
    --nx-bg-dark: #050608;
    --nx-bg-secondary: #0B0F17;
    --nx-bg-elevated: #121826;
    --nx-bg-card: #161D2D;
    --nx-surface: rgba(255,255,255,0.05);
    --nx-glass: rgba(255,255,255,0.08);
    --nx-glass-border: rgba(255,255,255,0.10);
    --nx-border: rgba(255,255,255,0.10);
    --nx-text-primary: #FFFFFF;
    --nx-text-body: #F2F4F8;
    --nx-text-secondary: #D2D7E2;
    --nx-text-muted: #7D8798;
    --nx-gold: #FFC72C;
    --nx-orange: #FF7A00;
    --nx-purple: #FF7A00;
    --nx-blue: #FFC72C;
    --nx-red: #FF7A00;
    --nx-green: #FFC72C;
  }

  .nexus-lobby * { margin: 0; padding: 0; box-sizing: border-box; }
  .nexus-lobby {
    position: relative; width: 100%; height: 100vh;
    overflow: hidden; background: var(--nx-bg-dark);
    font-family: 'Inter', sans-serif; color: var(--nx-text-primary);
  }

  /* ======== LOADING ======== */
  .nexus-loader {
    position: fixed; inset: 0; display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    background: #050608; z-index: 10000; overflow: hidden;
    transition: opacity 1s ease, visibility 1s;
  }
  .nexus-loader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
  .nexus-loader__bg {
    position: absolute; inset: 0; background-size: cover; background-position: center; z-index: -1;
  }
  .nexus-loader__video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -1;
  }
  .nexus-loader__content {
    position: absolute; z-index: 2; text-align: center;
    bottom: 40px; left: 50%; transform: translateX(-50%);
    width: min(90vw, 600px);
  }
  .nexus-loader__title {
    font-family: 'Orbitron', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2.8rem);
    font-weight: 900; letter-spacing: 8px; text-transform: uppercase;
    color: #FFFFFF; margin-bottom: 0.5rem;
    text-shadow: 0 0 30px rgba(255,199,44,0.5), 0 0 60px rgba(255,122,0,0.2);
  }
  .nexus-loader__subtitle {
    font-size: clamp(0.7rem, 1.2vw, 0.9rem); color: #7D8798;
    letter-spacing: 6px; text-transform: uppercase; margin-bottom: 1.5rem;
  }
  .nexus-loader__counter {
    font-family: 'Orbitron', sans-serif; font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900; color: #FFFFFF; line-height: 1; margin-bottom: 1rem;
    text-shadow: 0 0 40px rgba(255,199,44,0.6), 0 0 80px rgba(255,122,0,0.3);
  }
  .nexus-loader__bar-wrapper {
    width: 100%; height: 3px; background: rgba(255,255,255,0.08);
    border-radius: 2px; overflow: hidden; margin-bottom: 1rem;
  }
  .nexus-loader__bar {
    height: 100%; width: 0%; border-radius: 2px; position: relative;
    background: linear-gradient(90deg, #FFC72C, #FF7A00);
    transition: width 0.1s linear;
    box-shadow: 0 0 12px rgba(255,199,44,0.5), 0 0 24px rgba(255,122,0,0.25);
  }
  .nexus-loader__bar::after {
    content: ''; position: absolute; top: 0; left: -60px; width: 60px; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
    animation: barStreak 1.5s ease-in-out infinite;
  }
  @keyframes barStreak { 0% { left: -60px; } 100% { left: 100%; } }
  .nexus-loader__status {
    font-size: 0.75rem; color: rgba(255,255,255,0.5);
    letter-spacing: 4px; text-transform: uppercase; margin-bottom: 0.5rem;
  }
  .nexus-loader__japanese {
    font-size: 1rem; color: var(--nx-gold); letter-spacing: 8px; opacity: 0.5;
  }

  /* ======== BACKGROUND ======== */
  .nexus-bg-wrap {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; overflow: hidden;
    pointer-events: none;
  }
  .nexus-bg-wrap video {
    position: absolute; top: 50%; left: 50%; min-width: 100%; min-height: 100%;
    transform: translate(-50%, -50%); object-fit: cover;
  }
  .nexus-bg-wrap--image { background-size: cover; background-position: center; }
  .nexus-bg-wrap::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, transparent 0%, rgba(6,7,12,0.25) 75%);
  }

  /* ======== PARTICLES ======== */
  .nexus-particles-canvas {
    position: absolute; inset: 0; width: 100%; height: 100%; z-index: 7; pointer-events: none;
  }
  .nexus-dust {
    position: absolute; inset: 0; z-index: 6; pointer-events: none; overflow: hidden;
  }
  .nexus-dust__particle {
    position: absolute; width: 2px; height: 2px;
    background: rgba(255,199,44,0.4); border-radius: 50%;
    animation: dustFloat linear infinite;
  }
  @keyframes dustFloat {
    0% { transform: translateY(100vh) translateX(0); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-20vh) translateX(40px); opacity: 0; }
  }

  /* ======== NAVIGATION ======== */
  .nexus-nav {
    position: fixed; top: 0; left: 0; width: 100%; padding: 20px 4%;
    display: flex; justify-content: space-between; align-items: center;
    z-index: 1000; color: #fff;
    background: transparent;
    transition: background 0.35s ease, backdrop-filter 0.35s ease, box-shadow 0.35s ease, padding 0.35s ease;
  }
  .nexus-nav.scrolled {
    background: rgba(5, 6, 8, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    padding: 14px 4%;
  }
  .nexus-nav__left { display: flex; align-items: center; gap: 20px; }
  .nexus-nav__brand {
    display: flex; align-items: center; gap: 12px;
    text-decoration: none; color: #fff;
  }
  .nexus-nav__logo {
    width: var(--nx-logo-size, 36px); height: auto;
    background: var(--nx-purple); border-radius: 50%;
    display: flex; justify-content: center; align-items: center;
    box-shadow: 0 0 15px var(--nx-purple);
    overflow: hidden; flex-shrink: 0;
  }
  .nexus-nav__logo svg { width: 18px; height: 18px; fill: #fff; }
  .nexus-nav__logo img {
    width: 100%; height: 100%; object-fit: contain;
    border-radius: inherit;
  }
  .nexus-nav__logo--full {
    border-radius: var(--nx-logo-radius, 8px);
    background: transparent; box-shadow: none;
  }
  .nexus-nav__brand-text {
    font-family: 'Orbitron', sans-serif; font-size: 1.1rem; font-weight: 900;
    letter-spacing: 2px; line-height: 1.1;
  }
  .nexus-nav__right { display: flex; gap: 16px; align-items: center; }
  .nexus-nav__currency {
    display: flex; align-items: center; gap: 6px;
    font-family: 'Orbitron', sans-serif; font-size: 0.8rem; font-weight: 700;
    color: var(--nx-blue);
  }
  .nexus-nav__currency svg { width: 16px; height: 16px; fill: var(--nx-blue); }
  .nexus-nav__icon {
    position: relative; color: #fff; text-decoration: none; padding: 8px;
    background: none; border: none; transition: transform 0.3s; cursor: pointer;
  }
  .nexus-nav__icon:hover { transform: scale(1.1); }
  .nexus-nav__icon svg { width: 20px; height: 20px; fill: currentColor; }
  .nexus-nav__badge {
    position: absolute; top: -6px; right: -8px; background: var(--nx-purple); color: #fff;
    font-size: 0.65rem; font-weight: bold; width: 16px; height: 16px;
    display: flex; justify-content: center; align-items: center;
    border-radius: 50%; box-shadow: 0 0 8px var(--nx-purple);
  }

  /* ======== BACK BUTTON ======== */
  .nexus-nav__back {
    display: none; visibility: hidden; width: 0; height: 0; overflow: hidden;
    align-items: center; gap: 8px; color: #fff; text-decoration: none;
    font-size: 0.85rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    padding: 8px 16px; border: 1px solid rgba(255,255,255,0.2);
    background: rgba(10,6,20,0.8); backdrop-filter: blur(10px);
    cursor: pointer; transition: all 0.3s; border-radius: 6px;
    opacity: 0; pointer-events: none; position: absolute; left: -9999px;
  }
  .nexus-nav__back:hover { border-color: var(--nx-primary); box-shadow: 0 0 15px rgba(255,122,0,0.4); }
  .nexus-nav__back svg { width: 14px; height: 14px; fill: currentColor; }
  .nexus-lobby.view-active .nexus-nav__back {
    display: flex; visibility: visible; width: auto; height: auto;
    overflow: visible; opacity: 1; pointer-events: auto;
    position: relative; left: auto;
  }

  /* ======== VIEWS ======== */
  .nexus-view {
    position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
    opacity: 0; visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s;
    overflow-y: auto; overflow-x: hidden;
    z-index: 100; background: var(--nx-bg-dark);
    padding-top: 80px;
  }
  .nexus-view.active { opacity: 1; visibility: visible; }
  .nexus-view::-webkit-scrollbar { width: 4px; }
  .nexus-view::-webkit-scrollbar-track { background: transparent; }
  .nexus-view::-webkit-scrollbar-thumb { background: #ff7a00; border-radius: 2px; }

  /* ======== LOBBY CHARACTER ======== */
  .nexus-lobby__character {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    height: 100vh; max-height: 850px; z-index: 12; pointer-events: none;
    animation: characterBreath 4s ease-in-out infinite; overflow: hidden;
  }
  .nexus-lobby__character img {
    height: 100%; width: auto; object-fit: contain;
  }
  @keyframes characterBreath {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-4px); }
  }
  .nexus-lobby__aura {
    position: absolute; top: 35%; left: 50%; transform: translate(-50%, -50%);
    width: min(800px, 90vw); height: min(800px, 90vw);
    background: radial-gradient(circle, rgba(255,122,0,0.12) 0%, rgba(255,199,44,0.04) 30%, transparent 60%);
    border-radius: 50%; z-index: 11; animation: pulseAura 4s infinite alternate ease-in-out;
    pointer-events: none;
  }
  @keyframes pulseAura {
    0% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.4; }
    100% { transform: translate(-50%, -50%) scale(1.05); opacity: 0.8; }
  }

  /* ======== LOBBY CARDS ======== */
  .nexus-lobby__card-strip { display: contents; }
  .nexus-lobby__left, .nexus-lobby__right {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 20;
    display: flex; flex-direction: column; gap: 20px;
  }
  .nexus-lobby__left { left: 3%; width: 25%; }
  .nexus-lobby__right { right: 3%; width: 25%; }

  .nexus-lobby-card {
    position: relative; display: flex; align-items: center; overflow: hidden;
    border-radius: 14px; cursor: pointer; height: 170px;
    border: 1px solid var(--card-color, rgba(255,255,255,0.12));
    background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .nexus-lobby-card:hover {
    transform: scale(1.03);
    border-color: var(--card-color, var(--nx-gold));
    box-shadow: 0 0 25px color-mix(in srgb, var(--card-color) 40%, transparent);
  }
  @media (max-width: 768px) {
    .nexus-lobby-card:hover { transform: none; }
    .nexus-lobby-card:active { transform: scale(0.97); }
  }
  .nexus-lobby-card__glass {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%, rgba(255,255,255,0.05) 100%);
    z-index: 0;
  }
  .nexus-lobby-card__img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    filter: drop-shadow(4px 4px 12px rgba(0,0,0,0.8));
  }
  .nexus-lobby-card__content { position: relative; z-index: 2; padding: 16px 20px; }
  .nexus-lobby-card__badge {
    display: inline-block; padding: 3px 10px; border-radius: 4px;
    font-size: 0.9rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .nexus-lobby-card__title {
    font-family: 'Orbitron', sans-serif; font-size: 1.4rem; font-weight: 800;
    letter-spacing: 3px; text-transform: uppercase; color: #fff; margin-bottom: 10px;
  }
  .nexus-lobby-card__subtitle {
    font-size: 0.75rem; color: rgba(255,255,255,0.6); letter-spacing: 2px;
    text-transform: uppercase;
  }
  .nexus-scanline {
    position: absolute; width: 100%; height: 2px; z-index: 3; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.5) 2px, rgba(255,255,255,0.5) 4px);
    opacity: 0.03;
  }

  /* ======== CTA ======== */
  .nexus-lobby__cta {
    position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%);
    z-index: 20; text-align: center;
  }
  .nexus-lobby__tagline {
    font-family: 'Orbitron', sans-serif; font-size: clamp(1rem, 2.5vw, 1.8rem);
    font-weight: 900; letter-spacing: 4px; text-transform: uppercase;
    color: #fff; margin-bottom: 6px;
  }
  .nexus-lobby__tagline span { color: var(--nx-gold); }
  .nexus-lobby__tagline-sub {
    font-size: 0.8rem; color: var(--nx-text-muted);
    letter-spacing: 4px; text-transform: uppercase; margin-bottom: 16px;
  }
  .nexus-lobby__cta-btn {
    position: relative; display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 32px; min-width: 200px; height: 48px;
    background: linear-gradient(135deg, #FFE66D 0%, #FFC72C 40%, #FF9A00 100%);
    border: 1px solid rgba(255,255,255,0.35); border-radius: 999px;
    font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase; color: #FFFFFF;
    cursor: pointer; text-decoration: none; overflow: hidden;
    box-shadow: 0 12px 35px rgba(255,199,44,0.35), 0 0 40px rgba(255,199,44,0.45);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s;
  }
  .nexus-lobby__cta-btn:hover {
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 16px 45px rgba(255,122,0,0.5), 0 0 60px rgba(255,199,44,0.6);
    border-color: rgba(255,255,255,0.5);
  }
  .nexus-lobby__cta-btn::after {
    content: ''; position: absolute; top: 0; left: -100%; width: 60px; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    animation: ctaShine 4s ease-in-out infinite;
  }
  @keyframes ctaShine { 0%, 80%, 100% { left: -100%; } 40% { left: 150%; } }
  .nexus-lobby__cta-btn svg { width: 16px; height: 16px; fill: #fff; transition: transform 0.3s; }
  .nexus-lobby__cta-btn:hover svg { transform: translateX(4px); }
  .nexus-lobby__cta::before {
    content: ''; position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 300px; height: 100px;
    background: radial-gradient(ellipse, rgba(255,199,44,0.2) 0%, transparent 70%);
    border-radius: 50%; animation: ctaGlowPulse 3s ease-in-out infinite alternate;
    pointer-events: none; z-index: -1;
  }
  @keyframes ctaGlowPulse {
    0% { opacity: 0.5; transform: translate(-50%, -50%) scale(0.9); }
    100% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
  }

  /* ======== BOTTOM BAR ======== */
  .nexus-lobby__bottom {
    position: absolute; bottom: 0; left: 0; width: 100%;
    padding: 14px 4%; display: flex; justify-content: space-between; align-items: center;
    z-index: 20;
    background: linear-gradient(to top, rgba(5,6,8,0.95) 0%, rgba(5,6,8,0.6) 60%, transparent 100%);
  }
  .nexus-lobby__bottom-left, .nexus-lobby__bottom-right {
    display: flex; align-items: center; gap: 16px;
  }
  .nexus-lobby__bottom-btn {
    display: flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px; padding: 6px 12px; color: #fff; font-size: 0.7rem;
    font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    cursor: pointer; transition: all 0.3s; text-decoration: none;
  }
  .nexus-lobby__bottom-btn:hover {
    border-color: var(--nx-primary); background: rgba(255,122,0,0.1);
  }
  .nexus-lobby__bottom-btn svg { width: 14px; height: 14px; fill: currentColor; }
  .nexus-lobby__social { display: flex; align-items: center; gap: 10px; }
  .nexus-lobby__social-label {
    font-size: 0.65rem; color: var(--nx-text-muted);
    letter-spacing: 3px; text-transform: uppercase;
  }
  .nexus-lobby__social-icon {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    display: flex; justify-content: center; align-items: center;
    color: #fff; transition: all 0.3s; cursor: pointer; text-decoration: none;
  }
  .nexus-lobby__social-icon:hover {
    border-color: var(--nx-primary); color: #fff; transform: scale(1.1);
    background: rgba(255,122,0,0.1);
  }
  .nexus-lobby__social-icon svg { width: 14px; height: 14px; fill: currentColor; }

  /* ======== CONTENT VIEWS ======== */
  .nexus-content-view {
    position: relative; width: 100%; padding: 40px 4% 60px;
    min-height: calc(100vh - 80px);
  }
  .nexus-content-view__bg {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-size: cover; background-position: center;
    background-repeat: no-repeat;
    background-color: #0C0A06;
    z-index: 0;
  }
  .nexus-content-view__bg::after {
    content: ''; position: absolute; inset: 0;
    background: rgba(5,6,8,0.45);
  }
  .nexus-content-view > *:not(.nexus-content-view__bg) { position: relative; z-index: 1; }
  
  .nexus-content-view__title {
    font-family: 'Orbitron', sans-serif; font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 900; letter-spacing: 4px; text-transform: uppercase;
    margin-bottom: 6px; color: #FFC72C;
  }
  .nexus-content-view__subtitle {
    font-size: 0.85rem; color: rgba(255,255,255,0.5);
    letter-spacing: 3px; text-transform: uppercase;
  }

  /* Grid */
  .nexus-content-view__grid {
    display: grid; gap: 22px; max-width: 1500px; margin: 0 auto;
    grid-template-columns: repeat(4, 1fr);
    padding: 10px 0 40px;
  }
  @media (max-width: 1024px) {
    .nexus-content-view__grid { grid-template-columns: repeat(3, 1fr); gap: 18px; max-width: 720px; }
  }
  @media (max-width: 640px) {
    .nexus-content-view { padding: 24px 0 40px; }
    .nexus-content-view__grid {
      display: grid; grid-template-columns: 1fr; gap: 18px;
      max-width: 400px; margin: 0 auto; padding: 0 4% 40px;
    }
  }
  @keyframes npcFadeIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ======== PRODUCT CARD — Gaming Style ======== */
  @property --ff-angle {
    syntax: '<angle>';
    inherits: false;
    initial-value: 0deg;
  }
  @keyframes ffRotateBorder { to { --ff-angle: 360deg; } }
  @keyframes ffFloatArt {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @keyframes ffShineSweep {
    0% { left: -60%; }
    35% { left: 130%; }
    100% { left: 130%; }
  }
  @keyframes ffBtnShine {
    0% { left: -40%; }
    45% { left: 120%; }
    100% { left: 120%; }
  }
  @keyframes ffBtnGradient {
    0%,100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  @keyframes ffBadgePulse {
    0%,100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  @keyframes ffPriceGlow {
    0%,100% { text-shadow: 0 0 8px rgba(255,201,77,0.35); }
    50% { text-shadow: 0 0 18px rgba(255,201,77,0.75), 0 0 30px rgba(255,91,26,0.3); }
  }
  @keyframes ffLiveBlink {
    0%,100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  @keyframes ffRipple {
    to { transform: scale(3.5); opacity: 0; }
  }

  .nexus-product-card {
    position: relative; width: 100%;
    animation: npcFadeIn 0.5s ease-out both;
  }
  .nexus-product-card:nth-child(2) { animation-delay: 0.06s; }
  .nexus-product-card:nth-child(3) { animation-delay: 0.12s; }
  .nexus-product-card:nth-child(4) { animation-delay: 0.18s; }
  .nexus-product-card:nth-child(5) { animation-delay: 0.24s; }
  .nexus-product-card:nth-child(6) { animation-delay: 0.30s; }

  .ff-card {
    position: relative; width: 100%; border-radius: 18px; padding: 1px;
    transform-style: preserve-3d;
    transition: transform 0.3s cubic-bezier(0.22,0.9,0.32,1), box-shadow 0.3s ease;
    will-change: transform;
    background: linear-gradient(135deg, #2a2e38, transparent 40%, #2a2e38);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5), 0 2px 6px rgba(0,0,0,0.4);
  }
  .ff-card::before {
    content: ""; position: absolute; inset: -1px; border-radius: inherit; padding: 1px;
    background: conic-gradient(from var(--ff-angle,0deg), #ff5b1a, #ffc94d, #ff8a2b, transparent 30%, #ff5b1a);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    animation: ffRotateBorder 6s linear infinite; opacity: 0.7; z-index: 1; pointer-events: none;
  }
  .ff-card:hover::before { opacity: 1; }
  .ff-card:hover {
    box-shadow: 0 16px 40px rgba(255,91,26,0.2), 0 4px 12px rgba(0,0,0,0.4);
  }

  .ff-card-inner {
    position: relative; border-radius: 17px;
    background: linear-gradient(180deg, #1c1f27 0%, #15171d 60%, #101218 100%);
    overflow: hidden; z-index: 2;
  }

  .ff-cursor-glow {
    position: absolute; width: 260px; height: 260px; left: 0; top: 0;
    background: radial-gradient(circle, rgba(255,138,43,0.2), transparent 65%);
    transform: translate(-130px,-130px); pointer-events: none; opacity: 0;
    transition: opacity 0.3s ease; z-index: 5; mix-blend-mode: screen;
  }
  .ff-card:hover .ff-cursor-glow { opacity: 1; }

  .ff-hud { position: absolute; width: 18px; height: 18px; border-color: rgba(255,201,77,0.45); border-style: solid; z-index: 6; opacity: 0.7; pointer-events: none; transition: opacity 0.3s; }
  .ff-card:hover .ff-hud { opacity: 1; border-color: rgba(255,201,77,0.65); }
  .ff-hud.tl { top: 8px; left: 8px; border-width: 1.5px 0 0 1.5px; border-radius: 5px 0 0 0; }
  .ff-hud.tr { top: 8px; right: 8px; border-width: 1.5px 1.5px 0 0; border-radius: 0 5px 0 0; }
  .ff-hud.bl { bottom: 8px; left: 8px; border-width: 0 0 1.5px 1.5px; border-radius: 0 0 0 5px; }
  .ff-hud.br { bottom: 8px; right: 8px; border-width: 0 1.5px 1.5px 0; border-radius: 0 0 5px 0; }

  .ff-media {
    position: relative; height: 200px;
    display: flex; align-items: center; justify-content: center;
    background: radial-gradient(circle at 50% 30%, rgba(255,91,26,0.18), transparent 60%), linear-gradient(180deg,#1a1d24,#101218);
    overflow: hidden;
  }
  .ff-media::after {
    content: ""; position: absolute; inset: 0;
    background: repeating-linear-gradient(-45deg, rgba(255,255,255,0.015) 0 12px, transparent 12px 24px);
    pointer-events: none;
  }
  .ff-media-shine {
    position: absolute; top: 0; left: -60%; width: 40%; height: 100%;
    background: linear-gradient(115deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: skewX(-18deg); animation: ffShineSweep 4s ease-in-out infinite;
    pointer-events: none; z-index: 3;
  }
  .ff-media-img {
    width: 150px; height: 150px; position: relative;
