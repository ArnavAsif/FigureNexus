    background: linear-gradient(135deg, #ffe08a, #ff5b1a);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.2) inset, 0 4px 12px rgba(255,110,20,0.5);
    animation: ffBadgePulse 2s ease-in-out infinite;
  }
  .ff-badge-level {
    top: 12px; left: 12px; color: #ffe08a;
