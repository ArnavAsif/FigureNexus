  .nx-sf-hero::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,0,0,0.92), rgba(0,0,0,0.45) 50%, transparent); z-index: 1; }
  .nx-sf-hero-shine { position: absolute; top: 0; left: -60%; width: 35%; height: 100%; background: linear-gradient(115deg, transparent, rgba(255,255,255,0.06), transparent); transform: skewX(-20deg); z-index: 2; }
