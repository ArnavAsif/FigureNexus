<script>
  (function () {
    if (!document.body.classList.contains('template-index')) return;
    var removeElements = document.querySelectorAll(
      '.shopify-section-group-header-group, .shopify-section-group-footer-group, .header-group, .footer-group'
    );
    removeElements.forEach(function (el) {
      el.remove();
    });
    var skipLink = document.querySelector('.skip-to-content-link');
    if (skipLink) skipLink.remove();

    ['scroll', 'wheel', 'touchmove', 'mousewheel', 'keydown'].forEach(function (evt) {
      window.addEventListener(
        evt,
        function (e) {
          if (evt === 'keydown') {
            var blocked = [32, 33, 34, 35, 36, 38, 40];
            if (blocked.indexOf(e.keyCode) !== -1) {
              e.preventDefault();
            }
            return;
          }
          e.preventDefault();
        },
        { passive: false }
      );
    });
  })();
</script>
<script>
  (function () {
    'use strict';
    var id = '{{ nexus_id }}';

    /* ===== SOUND ===== */
    var NexusSound = {
      ctx: null,
      init: function () {
        try {
          this.ctx = new (window.AudioContext || window.webkitAudioContext)();
        } catch (e) {}
      },
      play: function (type) {
        if (!this.ctx) return;
        if (this.ctx.state === 'suspended') this.ctx.resume();
        var osc = this.ctx.createOscillator();
        var gain = this.ctx.createGain();
        osc.connect(gain);
        gain.connect(this.ctx.destination);
        var now = this.ctx.currentTime;
        if (type === 'hover') {
          osc.type = 'sine';
          osc.frequency.setValueAtTime(800, now);
          osc.frequency.exponentialRampToValueAtTime(1200, now + 0.08);
          gain.gain.setValueAtTime(0.06, now);
          gain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
          osc.start(now);
          osc.stop(now + 0.1);
        } else if (type === 'click') {
          osc.type = 'square';
          osc.frequency.setValueAtTime(400, now);
          osc.frequency.exponentialRampToValueAtTime(800, now + 0.05);
          osc.frequency.exponentialRampToValueAtTime(200, now + 0.1);
          gain.gain.setValueAtTime(0.08, now);
          gain.gain.exponentialRampToValueAtTime(0.001, now + 0.12);
          osc.start(now);
          osc.stop(now + 0.12);
        }
      },
    };
    NexusSound.init();

    /* ===== LOADER ===== */
    var NexusLoader = {
      init: function () {
        var counter = document.getElementById('nexus-counter-' + id);
        var bar = document.getElementById('nexus-bar-' + id);
        var status = document.getElementById('nexus-status-' + id);
        var loader = document.getElementById('nexus-loader-' + id);
        if (!counter) return;
        var statuses = [
          'LOADING ASSETS...',
          'PREPARING SQUAD...',
          'INITIALIZING ARENA...',
          'LOADING TERRAIN...',
          'READY TO DROP',
        ];
        var progress = 0;
        var interval = setInterval(function () {
          progress += 1.5;
          if (progress > 100) progress = 100;
          var r = Math.floor(progress);
          counter.textContent = r + '%';
          bar.style.width = r + '%';
          status.textContent = statuses[Math.min(Math.floor(r / 25), 4)];
          if (r >= 100) {
            clearInterval(interval);
            setTimeout(function () {
              loader.style.transition = 'opacity 1s ease-out, visibility 1s';
              loader.classList.add('hidden');
            }, 600);
          }
        }, 30);
      },
    };

    /* ===== CART ===== */
    var NexusCart = {
      init: function () {
        var overlay = document.getElementById('nexus-cart-overlay-' + id);
        var sidebar = document.getElementById('nexus-cart-sidebar-' + id);
        var self = this;
        document.getElementById('nexus-cart-toggle-' + id).addEventListener('click', function () {
          NexusSound.play('click');
          self.open();
        });
        document.getElementById('nexus-cart-close-' + id).addEventListener('click', function () {
          NexusSound.play('click');
          self.close();
        });
        overlay.addEventListener('click', function () {
          self.close();
        });
        this.fetchCart();
      },
      open: function () {
        document.getElementById('nexus-cart-overlay-' + id).classList.add('open');
        document.getElementById('nexus-cart-sidebar-' + id).classList.add('open');
      },
      close: function () {
        document.getElementById('nexus-cart-overlay-' + id).classList.remove('open');
        document.getElementById('nexus-cart-sidebar-' + id).classList.remove('open');
      },
      fetchCart: function () {
        var self = this;
        fetch('/cart.js')
          .then(function (r) {
            return r.json();
          })
          .then(function (cart) {
            self.renderCart(cart);
          })
          .catch(function () {});
      },
      renderCart: function (cart) {
        var itemsEl = document.getElementById('nexus-cart-items-' + id);
        var totalEl = document.getElementById('nexus-cart-total-' + id);
        var countEl = document.getElementById('nexus-cart-count-' + id);
        if (countEl) countEl.textContent = cart.item_count;
        if (totalEl) totalEl.textContent = '$' + (cart.total_price / 100).toFixed(2);
        if (!itemsEl) return;
        if (cart.items.length === 0) {
          itemsEl.innerHTML =
            '<div style="text-align:center;padding:60px 20px;"><svg viewBox="0 0 24 24" style="width:48px;height:48px;fill:#ddd;margin-bottom:16px;"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg><p style="font-family:Poppins,sans-serif;font-size:0.9rem;color:#999;margin:0;">Your cart is empty</p></div>';
          return;
        }
        itemsEl.innerHTML = cart.items
          .map(function (item) {
            return (
              '<div class="nexus-cart-item" data-key="' +
              item.key +
              '">' +
              '<img src="' +
              item.image +
              '" alt="" width="70" height="70">' +
              '<div class="nexus-cart-item-info">' +
              '<p class="nexus-cart-item-title">' +
              item.title +
              '</p>' +
              '<p class="nexus-cart-item-price">$' +
              (item.price / 100).toFixed(2) +
              '</p>' +
              '<div class="nexus-cart-item-qty">' +
              '<button class="nexus-cart-item-qty-btn" onclick="nexusUpdateCart(\'' +
              item.key +
              "'," +
              (item.quantity - 1) +
              ')">-</button>' +
              '<span class="nexus-cart-item-qty-val">' +
              item.quantity +
              '</span>' +
              '<button class="nexus-cart-item-qty-btn" onclick="nexusUpdateCart(\'' +
              item.key +
              "'," +
              (item.quantity + 1) +
              ')">+</button>' +
              '</div>' +
              '</div>' +
              '<button class="nexus-cart-item-remove" onclick="nexusRemoveCartItem(\'' +
              item.key +
              '\')" aria-label="Remove">' +
              '<svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>' +
              '</button>' +
              '</div>'
            );
          })
          .join('');
      },
    };

    /* ===== CART UPDATE/REMOVE ===== */
    window.nexusUpdateCart = function (key, qty) {
      if (qty < 1) {
        window.nexusRemoveCartItem(key);
        return;
      }
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty }),
      })
        .then(function (r) {
          return r.json();
        })
        .then(function (cart) {
          NexusCart.renderCart(cart);
        })
        .catch(function () {});
    };

    window.nexusRemoveCartItem = function (key) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 }),
      })
        .then(function (r) {
          return r.json();
        })
        .then(function (cart) {
          NexusCart.renderCart(cart);
        })
        .catch(function () {});
    };

    /* ===== NAVIGATION ===== */
    var lobby = document.getElementById('nexus-' + id);
    var lobbyView = document.getElementById('nexus-view-lobby-' + id);

    function goToView(viewName) {
      NexusSound.play('click');
      var current = document.querySelector('.nexus-view.active');
      if (current) current.classList.remove('active');
      var target = document.querySelector('.nexus-view[data-view="' + viewName + '"]');
      if (target) {
        target.classList.add('active');
        lobby.classList.add('view-active');
        target.scrollTop = 0;
        if (nexusNav) nexusNav.classList.remove('scrolled');
      }
    }

    function goBack() {
      NexusSound.play('click');
      var current = document.querySelector('.nexus-view.active');
      if (current) {
        current.classList.remove('active');
        current.scrollTop = 0;
      }
      lobbyView.classList.add('active');
      lobby.classList.remove('view-active');
      if (nexusNav) nexusNav.classList.remove('scrolled');
    }

    document.querySelectorAll('.nexus-lobby-card[data-view]').forEach(function (card) {
      card.addEventListener('click', function () {
        goToView(this.getAttribute('data-view'));
      });
      card.addEventListener('mouseenter', function () {
        NexusSound.play('hover');
      });
    });

    var backBtn = document.getElementById('nexus-back-' + id);
    if (backBtn) backBtn.addEventListener('click', goBack);

    /* ===== PARTICLES ===== */
    var canvas = document.getElementById('nexus-particles-' + id);
    if (canvas) {
      var ctx = canvas.getContext('2d');
      var particles = [];
      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      function Particle() {
        this.x = Math.random() * canvas.width;
        this.y = canvas.height + Math.random() * 100;
        this.size = Math.random() * 2.5 + 0.5;
        this.speedY = -(Math.random() * 0.8 + 0.2);
        this.speedX = (Math.random() - 0.5) * 0.4;
        this.opacity = Math.random() * 0.7 + 0.3;
        this.color = Math.random() > 0.5 ? '#FFC72C' : '#FF7A00';
        this.life = 0;
        this.maxLife = Math.random() * 300 + 200;
      }
      Particle.prototype.update = function () {
        this.x += this.speedX;
        this.y += this.speedY;
        this.life++;
        if (this.life > this.maxLife * 0.8) this.opacity -= 0.01;
        if (this.y < -20 || this.opacity <= 0) {
          this.x = Math.random() * canvas.width;
          this.y = canvas.height + 10;
          this.opacity = Math.random() * 0.7 + 0.3;
          this.life = 0;
        }
      };
      Particle.prototype.draw = function () {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = this.color;
        ctx.globalAlpha = this.opacity;
        ctx.fill();
        ctx.globalAlpha = 1;
      };
      for (var i = 0; i < 40; i++) {
        var p = new Particle();
        p.y = Math.random() * canvas.height;
        p.life = Math.random() * 200;
        particles.push(p);
      }
      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(function (p) {
          p.update();
          p.draw();
        });
        requestAnimationFrame(animate);
      }
      animate();
    }

    /* ===== PRODUCT MODAL ===== */
    var NexusModal = {
      el: null,
      qtyVal: null,
      currentProduct: null,
      init: function () {
        var self = this;
        this.el = document.getElementById('nexus-modal-' + id);
        this.qtyVal = document.getElementById('nexus-modal-qty-val-' + id);
        document.getElementById('nexus-modal-close-' + id).addEventListener('click', function () {
          self.close();
        });
        this.el.addEventListener('click', function (e) {
          if (e.target === self.el) self.close();
        });
        document.getElementById('nexus-modal-qty-minus-' + id).addEventListener('click', function () {
          var v = parseInt(self.qtyVal.value);
          if (v > 1) self.qtyVal.value = v - 1;
        });
        document.getElementById('nexus-modal-qty-plus-' + id).addEventListener('click', function () {
          var v = parseInt(self.qtyVal.value);
          if (v < 99) self.qtyVal.value = v + 1;
        });
        document.getElementById('nexus-modal-add-' + id).addEventListener('click', function () {
          if (!self.currentProduct || !self.currentProduct.id) return;
          var qty = parseInt(self.qtyVal.value);
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id: parseInt(self.currentProduct.id), quantity: qty }] }),
          })
            .then(function (r) {
              return r.json();
            })
            .then(function () {
              self.close();
              NexusSound.play('click');
              NexusCart.fetchCart();
              NexusCart.open();
            })
            .catch(function () {});
        });
        document.querySelectorAll('.nexus-product-card[data-product]').forEach(function (card) {
          card.addEventListener('click', function (e) {
            if (e.target.closest('.npc__cta') || e.target.closest('.npc__wish')) return;
            var data = JSON.parse(this.getAttribute('data-product'));
            self.open(data);
          });
        });
      },
      open: function (product) {
        this.currentProduct = product;
        this.qtyVal.value = 1;
        document.getElementById('nexus-modal-img-' + id).src = product.img || '';
        document.getElementById('nexus-modal-title-' + id).textContent = product.title || '';
        document.getElementById('nexus-modal-price-' + id).textContent = '$' + ((product.price || 0) / 100).toFixed(2);
        document.getElementById('nexus-modal-desc-' + id).textContent = product.desc || '';
        this.el.classList.add('open');
      },
      close: function () {
        this.el.classList.remove('open');
        this.currentProduct = null;
      },
    };

    /* ===== WISHLIST TOGGLE ===== */
    document.querySelectorAll('.npc__wish').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        this.classList.toggle('active');
      });
    });

    /* ===== ADD TO CART ===== */
    window.nexusAddToCart = function (variantId, btn) {
      if (!variantId) return;
      btn.disabled = true;
      btn.classList.add('added');
      var originalText = btn.innerHTML;
      btn.innerHTML =
        '<svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg> ADDED!';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] }),
      })
        .then(function (r) {
          return r.json();
        })
        .then(function () {
          NexusCart.fetchCart();
          NexusCart.open();
          setTimeout(function () {
            btn.innerHTML = originalText;
            btn.classList.remove('added');
            btn.disabled = false;
          }, 1800);
        })
        .catch(function () {
          btn.innerHTML = originalText;
          btn.classList.remove('added');
          btn.disabled = false;
        });
    };

    /* ===== CARD TILT + CURSOR GLOW ===== */
    document.querySelectorAll('.ff-card').forEach(function (card) {
      var glow = card.querySelector('.ff-cursor-glow');
      var targetRX = 0,
        targetRY = 0,
        curRX = 0,
        curRY = 0,
        ticking = false;

      card.addEventListener('mousemove', function (e) {
        var rect = card.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var px = x / rect.width;
        var py = y / rect.height;
        targetRY = (px - 0.5) * 8;
        targetRX = (0.5 - py) * 6;
        if (glow) glow.style.transform = 'translate(' + (x - 130) + 'px,' + (y - 130) + 'px)';
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(animateTilt);
        }
      });

      card.addEventListener('mouseleave', function () {
        targetRX = 0;
        targetRY = 0;
        if (glow) glow.style.opacity = '0';
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(animateTilt);
        }
      });

      card.addEventListener('mouseenter', function () {
        if (glow) glow.style.opacity = '1';
      });

      function animateTilt() {
        curRX += (targetRX - curRX) * 0.1;
        curRY += (targetRY - curRY) * 0.1;
        card.style.transform = 'perspective(800px) rotateX(' + curRX + 'deg) rotateY(' + curRY + 'deg) translateZ(0)';
        if (Math.abs(curRX - targetRX) > 0.02 || Math.abs(curRY - targetRY) > 0.02) {
          requestAnimationFrame(animateTilt);
        } else {
          ticking = false;
        }
      }
    });

    /* ===== BUY BUTTON RIPPLE ===== */
    document.querySelectorAll('.ff-buy-btn').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        var btnRect = btn.getBoundingClientRect();
        var size = Math.max(btnRect.width, btnRect.height);
        var ripple = document.createElement('span');
        ripple.className = 'ff-ripple';
        ripple.style.width = ripple.style.height = size + 'px';
        ripple.style.left = e.clientX - btnRect.left - size / 2 + 'px';
        ripple.style.top = e.clientY - btnRect.top - size / 2 + 'px';
        btn.appendChild(ripple);
        setTimeout(function () {
          ripple.remove();
        }, 650);
      });
    });

    /* ===== NAVBAR SCROLL ===== */
    var nexusNav = document.getElementById('nexus-nav-' + id);
    if (nexusNav) {
      function checkNavScroll() {
        var activeView = document.querySelector('.nexus-view.active');
        var scrollPos = activeView ? activeView.scrollTop : window.scrollY;
        if (scrollPos > 50) {
          nexusNav.classList.add('scrolled');
        } else {
          nexusNav.classList.remove('scrolled');
        }
      }
      document.querySelectorAll('.nexus-view').forEach(function (view) {
        view.addEventListener('scroll', checkNavScroll, { passive: true });
      });
      window.addEventListener('scroll', checkNavScroll, { passive: true });
      window.addEventListener('popstate', function () {
        setTimeout(function () {
          nexusNav.classList.remove('scrolled');
          var lobbyActive = document.querySelector('.nexus-view[data-view="lobby"].active');
          if (lobbyActive) lobbyActive.scrollTop = 0;
        }, 50);
      });
      nexusNav.classList.remove('scrolled');
    }

    /* ===== INIT ===== */
    if (lobbyView) lobbyView.classList.add('active');
    window.NexusCart = NexusCart;
    NexusLoader.init();
    NexusCart.init();
    NexusModal.init();
  })();
</script>

