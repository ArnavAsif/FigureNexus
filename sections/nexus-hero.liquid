  .ff-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
  .ff-chip {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: 'Poppins', sans-serif; font-size: 10.5px; font-weight: 600;
    color: #888e9a; background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07); padding: 5px 10px;
    border-radius: 16px; cursor: default; transition: all 0.3s;
  }
  .ff-chip:hover {
    color: #f4f1ea; border-color: rgba(255,138,43,0.5);
    background: rgba(255,91,26,0.08); box-shadow: 0 0 12px rgba(255,110,20,0.25);
    transform: translateY(-1px);
  }

  .ff-buy-btn {
    position: relative; width: 100%; border: none; outline: none; cursor: pointer;
    padding: 12px 16px; border-radius: 12px;
    background: linear-gradient(135deg, #ff5b1a, #ff8a2b 55%, #ffc94d);
    background-size: 180% 180%; color: #1a0c02;
    font-family: 'Orbitron', sans-serif; font-size: 13px; font-weight: 900;
    letter-spacing: 0.5px; text-transform: uppercase;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    overflow: hidden; isolation: isolate;
    box-shadow: 0 6px 16px rgba(255,91,26,0.3), 0 0 0 1px rgba(255,201,77,0.35) inset;
    transition: transform 0.25s, box-shadow 0.25s;
    animation: ffBtnGradient 4s ease-in-out infinite;
  }
  .ff-buy-btn::after {
    content: ""; position: absolute; top: 0; left: -40%; width: 30%; height: 100%;
    background: linear-gradient(115deg, transparent, rgba(255,255,255,0.5), transparent);
    transform: skewX(-20deg); animation: ffBtnShine 3s ease-in-out infinite; z-index: 1;
  }
  .ff-buy-btn:hover {
    transform: translateY(-2px) scale(1.015);
    box-shadow: 0 10px 24px rgba(255,110,20,0.45), 0 0 0 1px rgba(255,224,138,0.5) inset;
  }
  .ff-buy-btn:active { transform: translateY(0) scale(0.99); }
  .ff-buy-btn .ff-btn-label { z-index: 2; }
  .ff-buy-btn .ff-btn-arrow { display: inline-flex; transition: transform 0.3s; z-index: 2; }
  .ff-buy-btn:hover .ff-btn-arrow { transform: translateX(4px); }

  .ff-footer-strip {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 10px; padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.04);
    font-family: 'Poppins', sans-serif; font-size: 9.5px;
    color: #5a5f6d; letter-spacing: 0.4px; text-transform: uppercase;
  }
  .ff-footer-live { display: flex; align-items: center; gap: 5px; }
  .ff-live-dot {
    width: 5px; height: 5px; border-radius: 50%; background: #2be07a;
    box-shadow: 0 0 6px #2be07a; animation: ffLiveBlink 1.4s ease-in-out infinite;
  }

  .ff-ripple {
    position: absolute; border-radius: 50%; background: rgba(255,255,255,0.5);
    transform: scale(0); animation: ffRipple 0.6s ease-out forwards;
    pointer-events: none; z-index: 0;
  }

  /* Wishlist heart */
  .npc__wish {
    position: absolute; top: 12px; right: 12px; z-index: 10;
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(15,17,22,0.7); border: 1px solid rgba(255,201,77,0.4);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.3s;
  }
  .npc__wish:hover { transform: scale(1.1); background: rgba(255,91,26,0.15); border-color: #ff5b1a; }
  .npc__wish svg { width: 14px; height: 14px; fill: rgba(255,201,77,0.45); transition: fill 0.3s; }
  .npc__wish:hover svg { fill: #ff5b1a; }
  .npc__wish.active svg { fill: #ff5b1a; }

  @media (max-width: 640px) {
