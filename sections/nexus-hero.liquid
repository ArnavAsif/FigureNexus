  /* ======== PRODUCT MODAL ======== */
  .nexus-modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    z-index: 10000; display: none; align-items: center; justify-content: center;
    backdrop-filter: blur(6px);
  }
  .nexus-modal-overlay.open { display: flex; }
  .nexus-modal {
    position: relative; width: min(90vw, 820px); max-height: 85vh;
    background: #fff; border-radius: 28px; overflow: hidden;
    display: flex; box-shadow: 0 40px 100px rgba(0,0,0,0.35);
    animation: modalIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.88) translateY(30px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .nexus-modal__close {
    position: absolute; top: 16px; right: 16px; z-index: 10;
    width: 40px; height: 40px; border-radius: 50%; border: none;
    background: rgba(255,255,255,0.15); backdrop-filter: blur(8px);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, transform 0.2s;
  }
  .nexus-modal__close:hover { background: rgba(255,255,255,0.3); transform: scale(1.1); }
  .nexus-modal__close svg { width: 18px; height: 18px; fill: #fff; }
  .nexus-modal__left {
    flex: 0 0 45%; background: linear-gradient(145deg, #FFC72C 0%, #FFB300 100%);
    display: flex; align-items: center; justify-content: center;
    padding: 40px; position: relative; overflow: hidden;
  }
  .nexus-modal__left::before {
    content: ''; position: absolute; width: 240px; height: 240px;
    border: 2.5px solid rgba(255,255,255,0.15); border-radius: 50%;
    top: 8%; left: -12%;
  }
  .nexus-modal__left::after {
    content: ''; position: absolute; width: 120px; height: 120px;
    border: 2px solid rgba(255,255,255,0.1); border-radius: 50%;
    bottom: 15%; right: 10%;
  }
  .nexus-modal__left img {
    max-width: 100%; max-height: 340px; object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.25));
