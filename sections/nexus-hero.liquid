{%- comment -%}
  NEXUS LOBBY â€” Premium Gaming Lobby Hero Section
  Each card is a block with full customization
{%- endcomment -%}

{%- assign nexus_id = section.id | replace: '_', '-' -%}

{%- if section.settings.loading_image != blank -%}
  {%- assign loading_img_url = section.settings.loading_image | image_url: width: 1920 -%}
{%- endif -%}
{%- if section.settings.bg_image != blank -%}
  {%- assign bg_url = section.settings.bg_image | image_url: width: 1920 -%}
{%- endif -%}
{%- if section.settings.center_character != blank -%}
  {%- assign char_url = section.settings.center_character | image_url: width: 1200 -%}
{%- endif -%}

{%- if request.page_type == 'index' -%}
<style id="nexus-lock-homepage">
  html, body {
    overflow: hidden !important;
    height: 100vh !important;
    max-height: 100vh !important;
    position: fixed !important;
    width: 100% !important;
    top: 0 !important;
    left: 0 !important;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
  }
  html::-webkit-scrollbar, body::-webkit-scrollbar,
  html::-webkit-scrollbar-thumb, body::-webkit-scrollbar-track {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }
  .shopify-section {
    overflow: hidden !important;
    height: 100vh !important;
    max-height: 100vh !important;
  }
  .shopify-section-group-header-group,
  .shopify-section-group-footer-group,
  .header-group, .footer-group {
    display: none !important;
  }
  .skip-to-content-link,
  #web-pixels-manager-sandbox-container {
    display: none !important;
    visibility: hidden !important;
    width: 0 !important;
    height: 0 !important;
    overflow: hidden !important;
    position: absolute !important;
    left: -9999px !important;
    pointer-events: none !important;
    z-index: -99999 !important;
  }
</style>
{%- endif -%}

<link rel="stylesheet" href="{{ 'nexus-hero.css' | asset_url }}">
<style>
  :root {
    --nx-primary: {{ section.settings.primary_color | default: '#FFC72C' }};
    --nx-accent: {{ section.settings.accent_color | default: '#FF7A00' }};
    --nx-bg-dark: #050608;
    --nx-bg-secondary: #0B0F17;
    --nx-bg-elevated: #121826;
    --nx-bg-card: #161D2D;
    --nx-surface: rgba(255,255,255,0.05);
    --nx-glass: rgba(255,255,255,0.08);
    --nx-glass-border: rgba(255,255,255,0.10);
    --nx-border: rgba(255,255,255,0.10);
    --nx-text-primary: #FFFFFF;
    --nx-text-body: #F2F4F8;
    --nx-text-secondary: #D2D7E2;
    --nx-text-muted: #7D8798;
    --nx-gold: #FFC72C;
    --nx-orange: #FF7A00;
    --nx-purple: #FF7A00;
    --nx-blue: #FFC72C;
    --nx-red: #FF7A00;
    --nx-green: #FFC72C;
  }

</style>


<div class="nexus-lobby" id="nexus-{{ nexus_id }}">
  <!-- LOADING -->
  <div class="nexus-loader" id="nexus-loader-{{ nexus_id }}">
    {%- if section.settings.loading_video != blank -%}
      <video class="nexus-loader__video" autoplay muted loop playsinline>
        <source src="{{ section.settings.loading_video }}" type="video/mp4">
      </video>
    {%- elsif loading_img_url != blank -%}
      <div class="nexus-loader__bg" style="background-image: url('{{ loading_img_url }}');"></div>
    {%- endif -%}
    <div class="nexus-loader__content">
      <h1 class="nexus-loader__title">{{ section.settings.loading_title | default: 'LOADING' }}</h1>
      <p class="nexus-loader__subtitle">
        {{ section.settings.loading_subtitle | default: 'ENTERING THE BATTLEFIELD' }}
      </p>
      <div class="nexus-loader__counter" id="nexus-counter-{{ nexus_id }}">0%</div>
      <div class="nexus-loader__bar-wrapper"><div class="nexus-loader__bar" id="nexus-bar-{{ nexus_id }}"></div></div>
      <p class="nexus-loader__status" id="nexus-status-{{ nexus_id }}">LOADING ASSETS...</p>
      <p class="nexus-loader__japanese">{{ section.settings.loading_japanese | default: 'ãƒ­ãƒ¼ãƒ‰ä¸­...' }}</p>
    </div>
  </div>

  <!-- NAV -->
  <nav class="nexus-nav" id="nexus-nav-{{ nexus_id }}">
    <div class="nexus-nav__left">
      <button class="nexus-nav__back" id="nexus-back-{{ nexus_id }}">
        <svg viewBox="0 0 24 24">
          <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
        </svg>
        BACK
      </button>
      <a href="/" class="nexus-nav__brand">
        <div class="nexus-nav__logo{% if section.settings.logo_full %} nexus-nav__logo--full{% endif %}"
             style="--nx-logo-size: {{ section.settings.logo_size_pc | default: 36 }}px; --nx-logo-size-mb: {{ section.settings.logo_size_mb | default: 32 }}px; --nx-logo-radius: {{ section.settings.logo_border_radius | default: 8 }}px;">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 200 }}"
              alt="Logo"
            >
          {%- else -%}
            <svg viewBox="0 0 24 24">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          {%- endif -%}
        </div>
        <span class="nexus-nav__brand-text">{{ section.settings.brand_name  }}</span>
      </a>
    </div>
    <div class="nexus-nav__right">
      <div class="nexus-nav__currency">
        <svg viewBox="0 0 24 24">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        {{ section.settings.currency_amount | default: '4,250' }}
      </div>
      <button class="nexus-nav__icon nexus-cart-toggle" aria-label="Cart" id="nexus-cart-toggle-{{ nexus_id }}">
        <svg viewBox="0 0 24 24">
          <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
        </svg>
        <span class="nexus-nav__badge" id="nexus-cart-count-{{ nexus_id }}">0</span>
      </button>
      <button class="nexus-nav__icon" aria-label="Account">
        <svg viewBox="0 0 24 24">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- LOBBY VIEW -->
  <div class="nexus-view" id="nexus-view-lobby-{{ nexus_id }}" data-view="lobby">
    {%- if section.settings.bg_video != blank -%}
      <div class="nexus-bg-wrap">
        <video autoplay muted loop playsinline><source src="{{ section.settings.bg_video }}" type="video/mp4"></video>
      </div>
    {%- elsif bg_url != blank -%}
      <div class="nexus-bg-wrap nexus-bg-wrap--image" style="background-image: url('{{ bg_url }}');"></div>
    {%- endif -%}

    <canvas class="nexus-particles-canvas" id="nexus-particles-{{ nexus_id }}"></canvas>

    <div class="nexus-dust">
      {%- for i in (1..12) -%}
        <div class="nexus-dust__particle"></div>
      {%- endfor -%}
    </div>

    <div class="nexus-lobby__aura"></div>
    {%- if char_url != blank -%}
      <div class="nexus-lobby__character"><img src="{{ char_url }}" alt="Hero Character" loading="eager"></div>
    {%- endif -%}

    <!-- LOBBY CARDS (left + right) -->
    <div class="nexus-lobby__card-strip">
      <!-- LEFT CARDS -->
      <div class="nexus-lobby__left">
        {%- for block in section.blocks -%}
          {%- if block.settings.position == 'left' -%}
            <div
              class="nexus-lobby-card"
              style="--card-color: {{ block.settings.glow_color | default: '#FF7A00' }};"
              data-view="view-{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="nexus-lobby-card__glass"></div>
              <div class="nexus-scanline"></div>
              {%- if block.settings.card_image != blank -%}
                <img
                  src="{{ block.settings.card_image | image_url: width: 400 }}"
                  class="nexus-lobby-card__img"
                  alt=""
                  loading="lazy"
                >
              {%- endif -%}
              <div class="nexus-lobby-card__content">
                <span
                  class="nexus-lobby-card__badge"
                  style="background: {{ block.settings.glow_color | default: '#FF7A00' }};"
                >
                  {{- block.settings.badge | default: 'FEATURED' -}}
                </span>
                <h3 class="nexus-lobby-card__title">{{ block.settings.title }}</h3>
                <p class="nexus-lobby-card__subtitle">{{ block.settings.subtitle }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- RIGHT CARDS -->
      <div class="nexus-lobby__right">
        {%- for block in section.blocks -%}
          {%- if block.settings.position == 'right' -%}
            <div
              class="nexus-lobby-card"
              style="--card-color: {{ block.settings.glow_color | default: '#FFC72C' }};"
              data-view="view-{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="nexus-lobby-card__glass"></div>
              <div class="nexus-scanline"></div>
              {%- if block.settings.card_image != blank -%}
                <img
                  src="{{ block.settings.card_image | image_url: width: 400 }}"
                  class="nexus-lobby-card__img"
                  alt=""
                  loading="lazy"
                >
              {%- endif -%}
              <div class="nexus-lobby-card__content">
                <span
                  class="nexus-lobby-card__badge"
                  style="background: {{ block.settings.glow_color | default: '#FFC72C' }}; color: #111;"
                >
                  {{- block.settings.badge | default: 'BOOYAH!' -}}
                </span>
                <h3 class="nexus-lobby-card__title">{{ block.settings.title }}</h3>
                <p class="nexus-lobby-card__subtitle">{{ block.settings.subtitle }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- CTA -->
    <div class="nexus-lobby__cta">
      <p class="nexus-lobby__tagline">
        {{ section.settings.tagline | default: 'GEAR UP. SURVIVE. <span>BOOYAH!</span>' }}
      </p>
      <p class="nexus-lobby__tagline-sub">
        {{ section.settings.tagline_sub | default: 'OFFICIAL FREE FIRE MERCH STORE' }}
      </p>
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="nexus-lobby__cta-btn">
        {{ section.settings.cta_text | default: 'EXPLORE NOW' }}
        <svg viewBox="0 0 24 24">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </a>
    </div>

    <!-- BOTTOM BAR -->
    <div class="nexus-lobby__bottom">
      <div class="nexus-lobby__bottom-left">
        <a href="/pages/events" class="nexus-lobby__bottom-btn">
          <svg viewBox="0 0 24 24">
            <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
          </svg>
          <span>EVENTS</span>
        </a>
        <a href="/pages/missions" class="nexus-lobby__bottom-btn">
          <svg viewBox="0 0 24 24">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
          </svg>
          <span>DAILY MISSIONS</span>
        </a>
      </div>
      <div class="nexus-lobby__bottom-right">
        <span class="nexus-lobby__social-label">FOLLOW US</span>
        <div class="nexus-lobby__social">
          {%- if section.settings.social_facebook != blank -%}
            <a
              href="{{ section.settings.social_facebook }}"
              class="nexus-lobby__social-icon"
              target="_blank"
              rel="noopener"
            >
              <svg viewBox="0 0 24 24">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_instagram != blank -%}
            <a
              href="{{ section.settings.social_instagram }}"
              class="nexus-lobby__social-icon"
              target="_blank"
              rel="noopener"
            >
              <svg viewBox="0 0 24 24">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" fill="none" stroke="currentColor" stroke-width="2"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="currentColor" stroke-width="2"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_youtube != blank -%}
            <a
              href="{{ section.settings.social_youtube }}"
              class="nexus-lobby__social-icon"
              target="_blank"
              rel="noopener"
            >
              <svg viewBox="0 0 24 24">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#050608"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_tiktok != blank -%}
            <a
              href="{{ section.settings.social_tiktok }}"
              class="nexus-lobby__social-icon"
              target="_blank"
              rel="noopener"
            >
              <svg viewBox="0 0 24 24">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.87a8.16 8.16 0 0 0 3.77.92V6.69z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <!-- BLOCK CONTENT VIEWS -->
  {%- for block in section.blocks -%}
    {%- assign section_bg = block.settings.section_bg -%}
    {%- assign section_bg_color = block.settings.section_bg_color -%}
    <div class="nexus-view" id="nexus-view-{{ block.id }}-{{ nexus_id }}" data-view="view-{{ block.id }}">
      <div class="nexus-content-view">
        <div
          class="nexus-content-view__bg"
          {%- if section_bg != blank -%}
            style="background-image: url('{{ section_bg | image_url: width: 1920 }}');"
          {%- else -%}
            style="background-color: {{ section_bg_color | default: '#0C0A06' }};"
          {%- endif -%}
        ></div>

        {%- case block.type -%}
          {%- when 'card_products' -%}
            {%- assign sf_collection = block.settings.collection -%}
            {%- assign target_collection = sf_collection | default: collections.all -%}

            <div class="nx-sf-{{ block.id }}">
              {%- if block.settings.sf_hero_image != blank -%}
                <div
                  class="nx-sf-bg"
                  style="background-image: url('{{ block.settings.sf_hero_image | image_url: width: 1920 }}');"
                ></div>
              {%- endif -%}

              <div class="nx-sf-hero">
                <div class="nx-sf-hero-shine"></div>
                <div class="nx-sf-hero-content">
                  <div class="nx-sf-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13h-13L12 6.5z"/>
                    </svg>
                    Our Collection
                  </div>
                  <h1>
                    {{ block.settings.sf_heading | default: 'GEAR UP,' }}
                    <span>{{ block.settings.heading_accent | default: 'BOOYAH!' }}</span>
                  </h1>
                  <p>
                    {{
                      block.settings.sf_subtitle
                      | default: 'Explore our exclusive Free Fire inspired collection. Limited drops, legendary style!'
                    }}
                  </p>
                </div>
              </div>

              <div class="nx-sf-container">
                <button class="nx-sf-mobile-filter" onclick="this.nextElementSibling.classList.toggle('open')">
                  Toggle Filters
                </button>

                <aside class="nx-sf-sidebar">
                  <form class="nx-sf-filter-form" id="nx-sf-form-{{ block.id }}">
                    {%- for filter in target_collection.filters -%}
                      <div class="nx-sf-filter-widget">
                        <h3 class="nx-sf-filter-title">{{ filter.label }}</h3>
                        {%- case filter.type -%}
                          {%- when 'list' -%}
                            {%- if filter.label == 'Color' or filter.label == 'Colour' -%}
                              <div class="nx-sf-color-swatches">
                                {%- for value in filter.values -%}
                                  <label title="{{ value.label }}">
                                    <input
                                      type="checkbox"
                                      class="nx-sf-fc"
                                      name="{{ value.param_name }}"
                                      value="{{ value.value }}"
                                      {% if value.active %}
                                        checked
                                      {% endif %}
                                    >
                                    <div
                                      class="nx-sf-color-box"
                                      style="background-color: {{ value.label | downcase }};"
                                    ></div>
                                  </label>
                                {%- endfor -%}
                              </div>
                            {%- elsif filter.label == 'Size' -%}
                              <div class="nx-sf-size-swatches">
                                {%- for value in filter.values -%}
                                  <label>
                                    <input
                                      type="checkbox"
                                      class="nx-sf-fc"
                                      name="{{ value.param_name }}"
                                      value="{{ value.value }}"
                                      {% if value.active %}
                                        checked
                                      {% endif %}
                                    >
                                    <div class="nx-sf-size-box">{{ value.label }}</div>
                                  </label>
                                {%- endfor -%}
                              </div>
                            {%- else -%}
                              <ul class="nx-sf-filter-list">
                                {%- for value in filter.values -%}
                                  <li>
                                    <label class="nx-sf-filter-label">
                                      <span>{{ value.label }}</span>
                                      <span>{{ value.count }}</span>
                                      <input
                                        type="checkbox"
                                        class="nx-sf-fc"
                                        name="{{ value.param_name }}"
                                        value="{{ value.value }}"
                                        {% if value.active %}
                                          checked
                                        {% endif %}
                                      >
                                    </label>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          {%- when 'price_range' -%}
                            <div style="display: flex; gap: 10px; align-items: center;">
                              <span style="color:var(--nx-gold);">$</span>
                              <input
                                type="number"
                                name="{{ filter.min_value.param_name }}"
                                value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                                placeholder="Min"
                                style="width:100%; background:#222; border:1px solid #444; color:#fff; padding:5px; border-radius:4px;"
                              >
                              <span>-</span>
                              <input
                                type="number"
                                name="{{ filter.max_value.param_name }}"
                                value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                                placeholder="Max"
                                style="width:100%; background:#222; border:1px solid #444; color:#fff; padding:5px; border-radius:4px;"
                              >
                            </div>
                        {%- endcase -%}
                      </div>
                    {%- endfor -%}
                    {% if target_collection.filters.size > 0 %}
                      <button type="submit" style="display:none;">Apply</button>
                      <button
                        type="button"
                        onclick="window.location.href='{{ target_collection.url }}'"
                        style="width:100%; background:transparent; border:1px solid #444; color:#ccc; padding:10px; border-radius:4px; cursor:pointer; text-transform:uppercase;"
                      >
                        Clear All
                      </button>
                    {% endif %}
                  </form>
                </aside>

                <main class="nx-sf-main">
                  {%- paginate target_collection.products by block.settings.sf_products_per_page -%}
                    <div class="nx-sf-toolbar">
                      <div class="nx-sf-count">
                        Showing {{ paginate.current_offset | plus: 1 }} -
                        {% if paginate.next -%}
                          {{- paginate.current_offset | plus: block.settings.sf_products_per_page -}}
                        {%- else -%}
                          {{- paginate.items -}}
                        {%- endif %}
                        of {{ paginate.items }}
                      </div>
                      <select class="nx-sf-sort" id="nx-sf-sort-{{ block.id }}">
                        <option value="manual">Featured</option>
                        <option value="best-selling">Best Selling</option>
                        <option value="title-ascending">A-Z</option>
                        <option value="price-ascending">Price Low-High</option>
                        <option value="price-descending">Price High-Low</option>
                        <option value="created-descending">Newest</option>
                      </select>
                    </div>

                    <div class="nx-sf-grid">
                      {%- for product in target_collection.products -%}
                        {% assign badge_class = '' %}
                        {% assign badge_text = '' %}
                        {% if product.tags contains 'New' -%}
                          {%- assign badge_class = 'nx-sf-bg-purple' -%}
                          {%- assign badge_text = 'NEW' %}
                        {% elsif product.tags contains 'Limited' -%}
                          {%- assign badge_class = 'nx-sf-bg-blue' -%}
                          {%- assign badge_text = 'LIMITED' %}
                        {% elsif product.tags contains 'Hot' -%}
                          {%- assign badge_class = 'nx-sf-bg-orange' -%}
                          {%- assign badge_text = 'HOT' %}
                        {% elsif product.compare_at_price > product.price %}
                          {% assign badge_class = 'nx-sf-bg-red' %}
                          {% assign discount = product.compare_at_price
                            | minus: product.price
                            | times: 100.0
                            | divided_by: product.compare_at_price
                            | round
                          %}
                          {% assign badge_text = '-' | append: discount | append: '%' %}
                        {% endif %}

                        {%- assign vid = product.selected_or_first_available_variant.id -%}
                        <div class="nx-sf-card" data-handle="{{ product.handle }}">
                          {% if badge_text != '' %}
                            <div class="nx-sf-badge-tag {{ badge_class }}">{{ badge_text }}</div>
                          {% endif %}
                          <span class="nx-sf-card-id">#{{ forloop.index }}</span>
                          <div class="nx-sf-card-img-wrap">
                            <div class="nx-sf-corner nx-sf-corner-tl"></div>
                            <div class="nx-sf-corner nx-sf-corner-br"></div>
                            <div class="nx-sf-scanline"></div>
                            {%- if product.featured_image != blank -%}
                              <img
                                src="{{ product.featured_image | image_url: width: 500 }}"
                                alt="{{ product.title | escape }}"
                                class="nx-sf-card-img"
                                loading="lazy"
                              >
                            {%- else -%}
                              <div class="nx-sf-no-image"><span>No Image</span></div>
                            {%- endif -%}
                          </div>
                          <h3 class="nx-sf-card-title">{{ product.title }}</h3>
                          <div class="nx-sf-card-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128)</span></div>
                          <div class="nx-sf-card-divider"></div>
                          <div class="nx-sf-card-bottom">
                            <div class="nx-sf-price-wrap">
                              <span class="nx-sf-price">{{ product.price | money }}</span>
                              {% if product.compare_at_price > product.price -%}
                                <span class="nx-sf-compare">{{ product.compare_at_price | money }}</span>
                              {%- endif %}
                            </div>
                            <button
                              class="nx-sf-cart-btn"
                              onclick="event.stopPropagation(); nxSFAddToCart(event, {{ vid }}, '{{ block.id }}')"
                              aria-label="Add to cart"
                            >
                              <svg class="nx-sf-cart-icon" viewBox="0 0 24 24">
                                <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
                              </svg>
                              <svg class="nx-sf-spinner" viewBox="0 0 50 50" style="display:none;">
                                <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="80" stroke-dashoffset="60"/>
                              </svg>
                              <svg class="nx-sf-check" viewBox="0 0 24 24" style="display:none;">
                                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                              </svg>
                            </button>
                          </div>
                        </div>
                      {%- endfor -%}
                    </div>

                    {%- if paginate.pages > 1 -%}
                      <div style="display:flex; justify-content:center; gap:10px; margin-top:40px;">
                        {%- for part in paginate.parts -%}
                          {%- if part.is_link -%}
                            <a
                              href="{{ part.url }}"
                              style="background:#222; padding:10px 15px; color:white; text-decoration:none; border-radius:4px;"
                            >
                              {{- part.title -}}
                            </a>
                          {%- else -%}
                            <span style="background:var(--nx-gold); color:#111; padding:10px 15px; border-radius:4px; font-weight:bold;">
                              {{- part.title -}}
                            </span>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endpaginate -%}
                </main>
              </div>

              {%- if block.settings.enable_fire_effect -%}
                <div class="nx-sf-glowline"></div>
                <div class="nx-sf-sparks" id="nx-sf-sparks-{{ block.id }}"></div>
              {%- endif -%}
            </div>

            <!-- QUICK VIEW MODAL -->
            <div class="nx-sf-modal-overlay" id="nx-sf-modal-{{ block.id }}">
              <div class="nx-sf-modal-frame">
                <div class="nx-sf-modal-box">
                  <button class="nx-sf-modal-close" onclick="nxSFCloseQV('{{ block.id }}')">&times;</button>
                  <div class="nx-sf-modal-media">
                    <div class="nx-sf-modal-media-frame">
                      <div class="nx-sf-corner nx-sf-corner-tl"></div>
                      <div class="nx-sf-corner nx-sf-corner-br"></div>
                      <div class="nx-sf-stock-tag" id="nx-sf-stock-{{ block.id }}">
                        <span class="nx-sf-stock-dot"></span><span id="nx-sf-stock-text-{{ block.id }}">IN STOCK</span>
                      </div>
                      <img id="nx-sf-img-{{ block.id }}" src="" alt="">
                    </div>
                    <div class="nx-sf-modal-thumbs" id="nx-sf-thumbs-{{ block.id }}"></div>
                  </div>
                  <div class="nx-sf-modal-info">
                    <div class="nx-sf-modal-info-scroll">
                      <span class="nx-sf-modal-tag" id="nx-sf-vendor-{{ block.id }}">LOADOUT ITEM</span>
                      <h2 class="nx-sf-modal-title" id="nx-sf-title-{{ block.id }}">Loading Drop...</h2>
                      <div class="nx-sf-modal-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128 Reviews)</span></div>
                      <div class="nx-sf-modal-price-row">
                        <span class="nx-sf-modal-price" id="nx-sf-price-{{ block.id }}"></span>
                        <span class="nx-sf-modal-compare" id="nx-sf-compare-{{ block.id }}"></span>
                        <span
                          class="nx-sf-modal-discount"
                          id="nx-sf-discount-{{ block.id }}"
                          style="display:none;"
                        ></span>
                      </div>
                      <div class="nx-sf-modal-divider"></div>
                      <div class="nx-sf-modal-desc" id="nx-sf-desc-{{ block.id }}"></div>
                      <div class="nx-sf-modal-options" id="nx-sf-options-{{ block.id }}"></div>
                      <div class="nx-sf-modal-qty-row">
                        <span class="nx-sf-modal-label">Quantity</span>
                        <div class="nx-sf-qty-stepper">
                          <button type="button" class="nx-sf-qty-btn" onclick="nxSFQty('{{ block.id }}', -1)">-</button>
                          <input type="number" id="nx-sf-qty-{{ block.id }}" value="1" min="1" readonly>
                          <button type="button" class="nx-sf-qty-btn" onclick="nxSFQty('{{ block.id }}', 1)">+</button>
                        </div>
                      </div>
                    </div>
                    <button
                      class="nx-sf-modal-add"
                      id="nx-sf-add-btn-{{ block.id }}"
                      onclick="nxSFAddFromModal('{{ block.id }}')"
                    >
                      <span id="nx-sf-add-text-{{ block.id }}">ADD TO INVENTORY</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <div class="nx-sf-toast" id="nx-sf-toast-{{ block.id }}">âœ” Successfully added to inventory</div>

            <script>
              (function () {
                var bid = '{{ block.id }}';
                var currentVariant = null;

                // Sort
                var sortEl = document.getElementById('nx-sf-sort-' + bid);
                if (sortEl) {
                  var urlParams = new URLSearchParams(window.location.search);
                  if (urlParams.has('sort_by')) sortEl.value = urlParams.get('sort_by');
                  sortEl.addEventListener('change', function () {
                    urlParams.set('sort_by', this.value);
                    window.location.search = urlParams.toString();
                  });
                }

                // Filter form
                var form = document.getElementById('nx-sf-form-' + bid);
                if (form)
                  form.querySelectorAll('input').forEach(function (inp) {
                    inp.addEventListener('change', function () {
                      form.submit();
                    });
                  });

                // Fire sparks
                var sparks = document.getElementById('nx-sf-sparks-' + bid);
                if (sparks) {
                  var c = window.innerWidth < 768 ? 14 : 26;
                  for (var i = 0; i < c; i++) {
                    var s = document.createElement('span');
                    s.className = 'nx-sf-spark';
                    s.style.left = Math.random() * 100 + '%';
                    s.style.width = s.style.height = (Math.random() * 3.5 + 2).toFixed(1) + 'px';
                    s.style.animationDuration = (Math.random() * 3 + 3.5).toFixed(2) + 's';
                    s.style.animationDelay = (Math.random() * 6).toFixed(2) + 's';
                    s.style.setProperty('--drift', (Math.random() * 50 - 25).toFixed(0) + 'px');
                    sparks.appendChild(s);
                  }
                }

                // Card click -> Quick View
                document.querySelectorAll('.nx-sf-{{ block.id }} .nx-sf-card[data-handle]').forEach(function (card) {
                  card.addEventListener('click', function (e) {
                    if (e.target.closest('.nx-sf-cart-btn')) return;
                    nxSFOpenQV(bid, this.getAttribute('data-handle'));
                  });
                });

                // Add to cart from card
                window.nxSFAddToCart = function (event, variantId, blockId) {
                  if (blockId !== bid) return;
                  var btn = event.currentTarget;
                  var ci = btn.querySelector('.nx-sf-cart-icon');
                  var sp = btn.querySelector('.nx-sf-spinner');
                  var ck = btn.querySelector('.nx-sf-check');
                  ci.style.display = 'none';
                  sp.style.display = 'block';
                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] }),
                  })
                    .then(function (r) {
                      return r.json();
                    })
                    .then(function () {
                      sp.style.display = 'none';
                      ck.style.display = 'block';
                      document.dispatchEvent(new CustomEvent('cart:build'));
                      nxSFShowToast(bid);
                      setTimeout(function () {
                        ck.style.display = 'none';
                        ci.style.display = 'block';
                      }, 2000);
                    })
                    .catch(function () {
                      sp.style.display = 'none';
                      ci.style.display = 'block';
                    });
                };

                // Open Quick View
                window.nxSFOpenQV = function (blockId, handle) {
                  if (blockId !== bid) return;
                  var modal = document.getElementById('nx-sf-modal-' + bid);
                  modal.classList.add('active');
                  document.body.style.overflow = 'hidden';
                  document.getElementById('nx-sf-title-' + bid).innerText = 'Loading Drop...';
                  document.getElementById('nx-sf-price-' + bid).innerText = '';
                  document.getElementById('nx-sf-compare-' + bid).innerText = '';
                  document.getElementById('nx-sf-discount-' + bid).style.display = 'none';
                  document.getElementById('nx-sf-desc-' + bid).innerHTML = '';
                  document.getElementById('nx-sf-options-' + bid).innerHTML = '';
                  document.getElementById('nx-sf-thumbs-' + bid).innerHTML = '';
                  document.getElementById('nx-sf-qty-' + bid).value = 1;
                  document.getElementById('nx-sf-img-' + bid).src = '';

                  fetch('/products/' + handle + '.js')
                    .then(function (r) {
                      return r.json();
                    })
                    .then(function (product) {
                      document.getElementById('nx-sf-vendor-' + bid).innerText = product.vendor || 'LOADOUT ITEM';
                      var t = document.getElementById('nx-sf-title-' + bid);
                      t.innerText = product.title;
                      t.classList.add('loaded');
                      document.getElementById('nx-sf-desc-' + bid).innerHTML =
                        (product.description || '').replace(/(<([^>]+)>)/gi, '') || 'No description available.';

                      var tw = document.getElementById('nx-sf-thumbs-' + bid);
                      tw.innerHTML = '';
                      var imgs =
                        product.images && product.images.length
                          ? product.images
                          : product.featured_image
                          ? [product.featured_image]
                          : [];
                      imgs.forEach(function (src, idx) {
                        var th = document.createElement('div');
                        th.className = 'nx-sf-modal-thumb' + (idx === 0 ? ' active' : '');
                        th.innerHTML = '<img src="' + src + '" alt="">';
                        th.onclick = function () {
                          document.getElementById('nx-sf-img-' + bid).src = src;
                          tw.querySelectorAll('.nx-sf-modal-thumb').forEach(function (t) {
                            t.classList.remove('active');
                          });
                          th.classList.add('active');
                        };
                        tw.appendChild(th);
                      });

                      currentVariant =
                        product.variants.find(function (v) {
                          return v.available;
                        }) || product.variants[0];
                      document.getElementById('nx-sf-img-' + bid).src = currentVariant.featured_image
                        ? currentVariant.featured_image.src
                        : imgs[0] || '';
                      nxSFRenderOptions(bid, product);
                      nxSFUpdateVariant(bid, currentVariant);
                    });
                };

                function nxSFRenderOptions(bid, product) {
                  var w = document.getElementById('nx-sf-options-' + bid);
                  w.innerHTML = '';
                  if (product.options.length === 1 && product.options[0] === 'Title') return;
                  product.options.forEach(function (optName, idx) {
                    var vals = [];
                    product.variants.forEach(function (v) {
                      var val = v['option' + (idx + 1)];
                      if (vals.indexOf(val) === -1) vals.push(val);
                    });
                    var isColor = /color|colour/i.test(optName);
                    var grp = document.createElement('div');
                    grp.className = 'nx-sf-modal-option-group';
                    grp.innerHTML = '<span class="nx-sf-modal-option-label">' + optName + '</span>';
                    var vw = document.createElement('div');
                    vw.className = 'nx-sf-modal-option-values';
                    vals.forEach(function (val) {
                      var btn = document.createElement(isColor ? 'div' : 'button');
                      btn.type = 'button';
                      btn.className = isColor ? 'nx-sf-opt-color' : 'nx-sf-opt-btn';
                      if (isColor) {
                        btn.style.backgroundColor = val.toLowerCase();
                        btn.title = val;
                      } else {
                        btn.innerText = val;
                      }
                      btn.addEventListener('click', function () {
                        nxSFRenderOptions(bid, product);
                        var match = product.variants.find(function (v) {
                          return [v.option1, v.option2, v.option3].filter(Boolean).every(function (o, i) {
                            return o === val;
                          });
                        });
                        if (match) {
                          currentVariant = match;
                          nxSFUpdateVariant(bid, match);
                        }
                      });
                      vw.appendChild(btn);
                    });
                    grp.appendChild(vw);
                    w.appendChild(grp);
                  });
                }

                function nxSFUpdateVariant(bid, v) {
                  document.getElementById('nx-sf-price-' + bid).innerText = '$' + (v.price / 100).toFixed(2);
                  var ce = document.getElementById('nx-sf-compare-' + bid);
                  var de = document.getElementById('nx-sf-discount-' + bid);
                  if (v.compare_at_price && v.compare_at_price > v.price) {
                    ce.innerText = '$' + (v.compare_at_price / 100).toFixed(2);
                    de.innerText = '-' + Math.round(((v.compare_at_price - v.price) / v.compare_at_price) * 100) + '%';
                    de.style.display = 'inline-block';
                  } else {
                    ce.innerText = '';
                    de.style.display = 'none';
                  }
                  var st = document.getElementById('nx-sf-stock-' + bid);
                  var stt = document.getElementById('nx-sf-stock-text-' + bid);
                  var ab = document.getElementById('nx-sf-add-btn-' + bid);
                  var at = document.getElementById('nx-sf-add-text-' + bid);
                  if (v.available) {
                    stt.innerText = 'IN STOCK';
                    ab.disabled = false;
                    at.innerText = 'ADD TO INVENTORY';
                  } else {
                    stt.innerText = 'OUT OF STOCK';
                    ab.disabled = true;
                    at.innerText = 'UNAVAILABLE';
                  }
                  if (v.featured_image && v.featured_image.src)
                    document.getElementById('nx-sf-img-' + bid).src = v.featured_image.src;
                }

                // Close
                window.nxSFCloseQV = function (bid) {
                  document.getElementById('nx-sf-modal-' + bid).classList.remove('active');
                  document.body.style.overflow = '';
                  currentVariant = null;
                };
                document.getElementById('nx-sf-modal-' + bid).addEventListener('click', function (e) {
                  if (e.target === this) nxSFCloseQV(bid);
                });

                // Qty
                window.nxSFQty = function (bid, d) {
                  var inp = document.getElementById('nx-sf-qty-' + bid);
                  var v = parseInt(inp.value) || 1;
                  v = Math.max(1, v + d);
                  inp.value = v;
                };

                // Add from modal
                window.nxSFAddFromModal = function (bid) {
                  if (!currentVariant || !currentVariant.available) return;
                  var qty = document.getElementById('nx-sf-qty-' + bid).value;
                  var btn = document.getElementById('nx-sf-add-btn-' + bid);
                  var at = document.getElementById('nx-sf-add-text-' + bid);
                  var orig = at.innerText;
                  at.innerText = 'EQUIPPING...';
                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: [{ id: currentVariant.id, quantity: parseInt(qty) }] }),
                  })
                    .then(function () {
                      at.innerText = 'EQUIPPED!';
                      document.dispatchEvent(new CustomEvent('cart:build'));
                      setTimeout(function () {
                        nxSFCloseQV(bid);
                        at.innerText = orig;
                      }, 900);
                    })
                    .catch(function () {
                      at.innerText = orig;
                    });
                };

                // Toast
                window.nxSFShowToast = function (bid) {
                  var t = document.getElementById('nx-sf-toast-' + bid);
                  t.classList.add('show');
                  setTimeout(function () {
                    t.classList.remove('show');
                  }, 3000);
                };
              })();
            </script>

          {%- when 'card_collections' -%}
            {%- comment -%} Build collection entries array from settings {%- endcomment -%}
            {%- assign coll_entries = '' | split: '' -%}
            {%- for i in (1..12) -%}
              {%- assign col_key = 'col_' | append: i -%}
              {%- assign col_collection = block.settings[col_key] -%}
              {%- if col_collection != blank -%}
                {%- assign entry = col_collection | split: '|||' -%}
              {%- endif -%}
            {%- endfor -%}

            <!-- COLLECTION CARDS GRID -->
            <div class="nexus-coll-grid" id="nexus-coll-grid-{{ block.id }}">
              {%- for i in (1..12) -%}
                {%- assign title_key = 'col_' | append: i | append: '_title' -%}
                {%- assign subtitle_key = 'col_' | append: i | append: '_subtitle' -%}
                {%- assign image_key = 'col_' | append: i | append: '_image' -%}
                {%- assign collection_key = 'col_' | append: i -%}
                {%- assign hero_key = 'col_' | append: i | append: '_hero_image' -%}

                {%- assign col_title = block.settings[title_key] -%}
                {%- assign col_subtitle = block.settings[subtitle_key] -%}
                {%- assign col_image = block.settings[image_key] -%}
                {%- assign col_collection = block.settings[collection_key] -%}
                {%- assign col_hero = block.settings[hero_key] -%}

                {%- if col_collection != blank -%}
                  {%- assign coll_handle = col_collection.handle -%}
                  {%- assign coll_products_count = col_collection.products_count -%}
                  {%- assign img_url = '' -%}
                  {%- if col_image != blank -%}
                    {%- assign img_url = col_image | image_url: width: 500 -%}
                  {%- elsif col_collection.image != blank -%}
                    {%- assign img_url = col_collection.image | image_url: width: 500 -%}
                  {%- endif -%}
                  {%- assign hero_url = '' -%}
                  {%- if col_hero != blank -%}
                    {%- assign hero_url = col_hero | image_url: width: 1800 -%}
                  {%- elsif col_collection.image != blank -%}
                    {%- assign hero_url = col_collection.image | image_url: width: 1800 -%}
                  {%- endif -%}

                  <div class="nexus-coll-card"
                       data-collection="{{ coll_handle }}"
                       data-hero="{{ hero_url }}"
                       data-coll-title="{{ col_title | default: col_collection.title | escape }}"
                       data-coll-subtitle="{{ col_subtitle | escape }}">
                    <div class="nexus-coll-card-media">
                      <span class="nexus-coll-card-badge">COLLECTION</span>
                      <span class="nexus-coll-card-count-tag">{{ coll_products_count }} ITEMS</span>
                      {%- if img_url != '' -%}
                        <img src="{{ img_url }}" alt="{{ col_title | default: col_collection.title }}" class="nexus-coll-card-img" loading="lazy">
                      {%- else -%}
                        <div class="nexus-coll-card-noimg">
                          <svg viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                        </div>
                      {%- endif -%}
                    </div>
                    <div class="nexus-coll-card-content">
                      <h3 class="nexus-coll-card-title">{{ col_title | default: col_collection.title }}</h3>
                      <p class="nexus-coll-card-subtitle">{{ col_subtitle | default: 'Browse this collection' }}</p>
                      <div class="nexus-coll-card-divider"></div>
                      <div class="nexus-coll-card-bottom">
                        <div>
                          <span class="nexus-coll-card-count">{{ coll_products_count }}</span>
                          <span class="nexus-coll-card-count-label">items</span>
                        </div>
                        <div class="nexus-coll-card-arrow">
                          <svg viewBox="0 0 24 24"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
                        </div>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>

            <!-- STOREFRONT VIEW (hidden by default) -->
            <div class="nexus-coll-storeview" id="nexus-coll-storeview-{{ block.id }}">
              {%- assign coll_section_bg = block.settings.section_bg -%}
              {%- if coll_section_bg != blank -%}
                <div class="nexus-coll-storeview-bg" style="background-image: url('{{ coll_section_bg | image_url: width: 1920 }}'); opacity: {{ block.settings.section_bg_opacity | default: 15 | times: 1.0 | divided_by: 100 }};"></div>
              {%- endif -%}
              <button class="nexus-coll-back" id="nexus-coll-back-{{ block.id }}">
                <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                BACK TO COLLECTIONS
              </button>

              <div class="fn-hero-wrapper">
                <div class="fn-hero" id="nexus-coll-hero-{{ block.id }}">
                  <div class="fn-hero-shine"></div>
                  <div class="fn-hero-content">
                    <div class="fn-hero-badge">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13h-13L12 6.5z"/>
                      </svg>
                      <span id="nexus-coll-badge-text-{{ block.id }}">Collection</span>
                    </div>
                    <h1 id="nexus-coll-hero-title-{{ block.id }}">Collection</h1>
                    <p id="nexus-coll-hero-sub-{{ block.id }}"></p>
                  </div>
                </div>
              </div>

              <div class="fn-container">
                <main class="fn-main">
                  <div class="fn-toolbar">
                    <div class="fn-toolbar-count" id="nexus-coll-count-{{ block.id }}">Loading...</div>
                    <div class="fn-toolbar-actions">
                      <span style="color:#888; font-size:14px; text-transform:uppercase;">Sort By:</span>
                      <select id="nexus-coll-sort-{{ block.id }}" class="nexus-coll-sort-select">
                        <option value="featured">Featured</option>
                        <option value="best-selling">Best Selling</option>
                        <option value="title-ascending">Alphabetically, A-Z</option>
                        <option value="price-ascending">Price, low to high</option>
                        <option value="price-descending">Price, high to low</option>
                        <option value="created-descending">Date, new to old</option>
                      </select>
                    </div>
                  </div>
                  <div class="fn-grid" id="nexus-coll-products-{{ block.id }}"></div>
                  <div id="nexus-coll-pagination-{{ block.id }}" style="display:flex; justify-content:center; gap:10px; margin-top:40px;"></div>
                </main>
              </div>

              {%- if block.settings.enable_fire_effect -%}
                <div class="fn-fire-glowline"></div>
                <div class="fn-fire-sparks" id="nexus-coll-sparks-{{ block.id }}"></div>
              {%- endif -%}
            </div>

            <!-- QUICK VIEW MODAL -->
            <div class="fn-modal-overlay" id="nexus-coll-qv-{{ block.id }}">
              <div class="fn-modal-frame">
                <div class="fn-modal-box">
                  <button class="fn-modal-close" onclick="nexusCollCloseQV('{{ block.id }}')">&times;</button>
                  <div class="fn-modal-media">
                    <div class="fn-modal-media-frame">
                      <div class="fn-corner fn-corner-tl"></div>
                      <div class="fn-corner fn-corner-br"></div>
                      <div class="fn-modal-stock-tag" id="nexus-coll-qv-stock-{{ block.id }}">
                        <span class="dot"></span><span id="nexus-coll-qv-stock-text-{{ block.id }}">IN STOCK</span>
                      </div>
                      <img id="nexus-coll-qv-img-{{ block.id }}" src="" alt="">
                    </div>
                    <div class="fn-modal-thumbs" id="nexus-coll-qv-thumbs-{{ block.id }}"></div>
                  </div>
                  <div class="fn-modal-info">
                    <div class="fn-modal-info-scroll">
                      <span class="fn-modal-tag" id="nexus-coll-qv-vendor-{{ block.id }}">LOADOUT ITEM</span>
                      <h2 class="fn-modal-title" id="nexus-coll-qv-title-{{ block.id }}">Loading Drop...</h2>
                      <div class="fn-modal-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128 Reviews)</span></div>
                      <div class="fn-modal-price-row">
                        <span class="fn-modal-price" id="nexus-coll-qv-price-{{ block.id }}"></span>
                        <span class="fn-modal-compare" id="nexus-coll-qv-compare-{{ block.id }}"></span>
                        <span class="fn-modal-discount" id="nexus-coll-qv-discount-{{ block.id }}" style="display:none;"></span>
                      </div>
                      <div class="fn-modal-divider"></div>
                      <div class="fn-modal-desc" id="nexus-coll-qv-desc-{{ block.id }}"></div>
                      <div class="fn-modal-options" id="nexus-coll-qv-options-{{ block.id }}"></div>
                      <div class="fn-modal-qty-row">
                        <span class="fn-modal-label">Quantity</span>
                        <div class="fn-qty-stepper">
                          <button type="button" class="fn-qty-btn" id="nexus-coll-qv-minus-{{ block.id }}">-</button>
                          <input type="number" id="nexus-coll-qv-qty-{{ block.id }}" value="1" min="1" readonly>
                          <button type="button" class="fn-qty-btn" id="nexus-coll-qv-plus-{{ block.id }}">+</button>
                        </div>
                      </div>
                    </div>
                    <button class="fn-modal-add" id="nexus-coll-qv-add-{{ block.id }}">
                      <span class="fn-modal-add-text" id="nexus-coll-qv-add-text-{{ block.id }}">ADD TO INVENTORY</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- TOAST -->
            <div class="fn-toast" id="nexus-coll-toast-{{ block.id }}">âœ” Successfully added to inventory</div>

            <script>
              (function () {
                var bid = '{{ block.id }}';
                var perPage = {{ block.settings.sf_products_per_page | default: 16 }};
                var allProducts = [];
                var filteredProducts = [];
                var currentPage = 1;
                var currentSort = 'featured';
                var currentVariant = null;

                /* ===== CARD CLICK ===== */
                document.querySelectorAll('#nexus-coll-grid-' + bid + ' .nexus-coll-card').forEach(function (card) {
                  card.addEventListener('click', function (e) {
                    if (e.target.closest('.nexus-coll-card-arrow')) e.preventDefault();
                    var handle = this.getAttribute('data-collection');
                    var heroUrl = this.getAttribute('data-hero');
                    var collTitle = this.getAttribute('data-coll-title');
                    var collSubtitle = this.getAttribute('data-coll-subtitle');
                    nexusCollOpenStore(handle, heroUrl, collTitle, collSubtitle);
                  });
                });

                /* ===== OPEN STOREFRONT ===== */
                function nexusCollOpenStore(handle, heroUrl, title, subtitle) {
                  var grid = document.getElementById('nexus-coll-grid-' + bid);
                  var store = document.getElementById('nexus-coll-storeview-' + bid);
                  grid.style.display = 'none';
                  store.classList.add('active');

                  var titleParts = title.split(' ');
                  var accentWord = titleParts.pop();
                  var mainTitle = titleParts.length > 0 ? titleParts.join(' ') + ' ' : '';
                  document.getElementById('nexus-coll-hero-title-' + bid).innerHTML = mainTitle + '<span style="color:var(--nx-gold);">' + accentWord + '</span>';
                  document.getElementById('nexus-coll-badge-text-' + bid).textContent = 'Collection';
                  document.getElementById('nexus-coll-hero-sub-' + bid).textContent = subtitle || '';

                  var heroEl = document.getElementById('nexus-coll-hero-' + bid);
                  heroEl.style.backgroundImage = heroUrl ? 'url(' + heroUrl + ')' : '';

                  document.getElementById('nexus-coll-count-' + bid).textContent = 'Loading...';
                  document.getElementById('nexus-coll-products-' + bid).innerHTML = '';
                  document.getElementById('nexus-coll-pagination-' + bid).innerHTML = '';

                  fetch('/collections/' + handle + '/products.json?limit=250')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                      allProducts = data.products || [];
                      filteredProducts = allProducts.slice();
                      currentPage = 1;
                      currentSort = 'featured';
                      document.getElementById('nexus-coll-sort-' + bid).value = 'featured';
                      nexusCollRenderProducts();
                    })
                    .catch(function () {
                      document.getElementById('nexus-coll-count-' + bid).textContent = 'Failed to load products.';
                    });

                  generateFireSparks();
                }

                /* ===== RENDER PRODUCTS ===== */
                function nexusCollRenderProducts() {
                  var grid = document.getElementById('nexus-coll-products-' + bid);
                  var pag = document.getElementById('nexus-coll-pagination-' + bid);
                  var countEl = document.getElementById('nexus-coll-count-' + bid);
                  var total = filteredProducts.length;
                  var start = (currentPage - 1) * perPage;
                  var end = Math.min(start + perPage, total);
                  var pageProducts = filteredProducts.slice(start, end);

                  countEl.textContent = 'Showing ' + (start + 1) + ' - ' + end + ' of ' + total + ' Products';

                  grid.innerHTML = '';
                  pageProducts.forEach(function (product, idx) {
                    var badgeClass = '', badgeText = '';
                    if (product.tags && product.tags.indexOf('New') !== -1) { badgeClass = 'bg-purple'; badgeText = 'NEW'; }
                    else if (product.tags && product.tags.indexOf('Limited') !== -1) { badgeClass = 'bg-blue'; badgeText = 'LIMITED'; }
                    else if (product.tags && product.tags.indexOf('Hot') !== -1) { badgeClass = 'bg-orange'; badgeText = 'HOT'; }
                    else if (product.compare_at_price && product.compare_at_price > product.price) {
                      badgeClass = 'bg-red';
                      var disc = Math.round(((product.compare_at_price - product.price) / product.compare_at_price) * 100);
                      badgeText = '-' + disc + '%';
                    }

                    var variant = product.variants && product.variants[0];
                    var variantId = variant ? variant.id : '';
                    var img = product.images && product.images[0] ? product.images[0].src : '';
                    var price = variant ? '$' + (variant.price / 100).toFixed(2) : '';
                    var comparePrice = (variant && variant.compare_at_price && variant.compare_at_price > variant.price) ? '$' + (variant.compare_at_price / 100).toFixed(2) : '';

                    var delayIdx = idx % 4;
                    var cardHtml = '<div class="fn-card-frame" style="transition-delay:' + (delayIdx * 0.07) + 's;" data-handle="' + product.handle + '">';
                    cardHtml += '<div class="fn-card-inner">';
                    if (badgeText) cardHtml += '<div class="fn-card-badge ' + badgeClass + '">' + badgeText + '</div>';
                    cardHtml += '<span class="fn-card-id">#' + (start + idx + 1) + '</span>';
                    cardHtml += '<div class="fn-card-img-wrap"><div class="fn-corner fn-corner-tl"></div><div class="fn-corner fn-corner-br"></div><div class="fn-scan-line"></div>';
                    if (img) cardHtml += '<img src="' + img + '" alt="' + (product.title || '').replace(/"/g, '&quot;') + '" class="fn-card-img" loading="lazy">';
                    else cardHtml += '<div class="fn-no-image"><span>No Image</span></div>';
                    cardHtml += '</div>';
                    cardHtml += '<h3 class="fn-card-title">' + (product.title || '') + '</h3>';
                    cardHtml += '<div class="fn-card-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128)</span></div>';
                    cardHtml += '<div class="fn-card-divider"></div>';
                    cardHtml += '<div class="fn-card-bottom"><div class="fn-card-price-wrap">';
                    cardHtml += '<span class="fn-price">' + price + '</span>';
                    if (comparePrice) cardHtml += '<span class="fn-compare">' + comparePrice + '</span>';
                    cardHtml += '</div>';
                    cardHtml += '<button class="fn-cart-btn" data-variant="' + variantId + '" aria-label="Add to cart">';
                    cardHtml += '<svg class="cart-icon" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>';
                    cardHtml += '<svg class="spinner-icon" viewBox="0 0 50 50" style="display:none;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="80" stroke-dashoffset="60"/></svg>';
                    cardHtml += '<svg class="check-icon" viewBox="0 0 24 24" style="display:none;"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>';
                    cardHtml += '</button></div></div></div>';

                    grid.innerHTML += cardHtml;
                  });

                  // Card click -> Quick View
                  grid.querySelectorAll('.fn-card-frame[data-handle]').forEach(function (card) {
                    card.addEventListener('click', function (e) {
                      if (e.target.closest('.fn-cart-btn')) return;
                      nexusCollOpenQV(this.getAttribute('data-handle'));
                    });
                  });

                  // Add to cart buttons
                  grid.querySelectorAll('.fn-cart-btn').forEach(function (btn) {
                    btn.addEventListener('click', function (e) {
                      e.stopPropagation();
                      var variantId = parseInt(this.getAttribute('data-variant'));
                      if (!variantId) return;
                      var cartIcon = this.querySelector('.cart-icon');
                      var spinnerIcon = this.querySelector('.spinner-icon');
                      var checkIcon = this.querySelector('.check-icon');
                      cartIcon.style.display = 'none';
                      spinnerIcon.style.display = 'block';
                      var self = this;
                      fetch(window.Shopify.routes.root + 'cart/add.js', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] }),
                      }).then(function (r) { return r.json(); }).then(function () {
                        spinnerIcon.style.display = 'none';
                        checkIcon.style.display = 'block';
                        document.dispatchEvent(new CustomEvent('cart:build'));
                        if (window.NexusCart) { NexusCart.fetchCart(); NexusCart.open(); }
                        nexusCollShowToast();
                        setTimeout(function () { checkIcon.style.display = 'none'; cartIcon.style.display = 'block'; }, 2000);
                      }).catch(function () { spinnerIcon.style.display = 'none'; cartIcon.style.display = 'block'; });
                    });
                  });

                  // Pagination
                  renderPagination(total);
                }

                /* ===== SORTING ===== */
                document.getElementById('nexus-coll-sort-' + bid).addEventListener('change', function () {
                  currentSort = this.value;
                  sortProducts();
                  currentPage = 1;
                  nexusCollRenderProducts();
                });

                function sortProducts() {
                  if (currentSort === 'price-ascending') filteredProducts.sort(function (a, b) { return a.variants[0].price - b.variants[0].price; });
                  else if (currentSort === 'price-descending') filteredProducts.sort(function (a, b) { return b.variants[0].price - a.variants[0].price; });
                  else if (currentSort === 'title-ascending') filteredProducts.sort(function (a, b) { return a.title.localeCompare(b.title); });
                  else if (currentSort === 'best-selling') filteredProducts.sort(function (a, b) { return (b.variants[0].sold_out ? 0 : 1) - (a.variants[0].sold_out ? 0 : 1); });
                  else if (currentSort === 'created-descending') filteredProducts.sort(function (a, b) { return new Date(b.created_at) - new Date(a.created_at); });
                  else filteredProducts = allProducts.slice();
                }

                /* ===== PAGINATION ===== */
                function renderPagination(total) {
                  var pag = document.getElementById('nexus-coll-pagination-' + bid);
                  var totalPages = Math.ceil(total / perPage);
                  if (totalPages <= 1) { pag.innerHTML = ''; return; }
                  var html = '';
                  if (currentPage > 1) html += '<a href="#" class="nexus-coll-pag-btn" data-page="' + (currentPage - 1) + '" style="background:#222; padding:10px 15px; color:white; text-decoration:none; border-radius:4px;">â†</a>';
                  for (var p = 1; p <= totalPages; p++) {
                    if (p === currentPage) html += '<span style="background:var(--ff-primary); color:#111; padding:10px 15px; border-radius:4px; font-weight:bold;">' + p + '</span>';
                    else html += '<a href="#" class="nexus-coll-pag-btn" data-page="' + p + '" style="background:#222; padding:10px 15px; color:white; text-decoration:none; border-radius:4px;">' + p + '</a>';
                  }
                  if (currentPage < totalPages) html += '<a href="#" class="nexus-coll-pag-btn" data-page="' + (currentPage + 1) + '" style="background:#222; padding:10px 15px; color:white; text-decoration:none; border-radius:4px;">â†’</a>';
                  pag.innerHTML = html;
                  pag.querySelectorAll('.nexus-coll-pag-btn').forEach(function (btn) {
                    btn.addEventListener('click', function (e) {
                      e.preventDefault();
                      currentPage = parseInt(this.getAttribute('data-page'));
                      nexusCollRenderProducts();
                    });
                  });
                }

                /* ===== BACK BUTTON ===== */
                document.getElementById('nexus-coll-back-' + bid).addEventListener('click', function () {
                  document.getElementById('nexus-coll-grid-' + bid).style.display = '';
                  document.getElementById('nexus-coll-storeview-' + bid).classList.remove('active');
                  allProducts = [];
                  filteredProducts = [];
                });

                /* ===== QUICK VIEW ===== */
                function nexusCollOpenQV(handle) {
                  var modal = document.getElementById('nexus-coll-qv-' + bid);
                  modal.classList.add('active');
                  document.body.style.overflow = 'hidden';

                  document.getElementById('nexus-coll-qv-title-' + bid).innerText = 'Loading Drop...';
                  document.getElementById('nexus-coll-qv-price-' + bid).innerText = '';
                  document.getElementById('nexus-coll-qv-compare-' + bid).innerText = '';
                  document.getElementById('nexus-coll-qv-discount-' + bid).style.display = 'none';
                  document.getElementById('nexus-coll-qv-desc-' + bid).innerHTML = '';
                  document.getElementById('nexus-coll-qv-options-' + bid).innerHTML = '';
                  document.getElementById('nexus-coll-qv-thumbs-' + bid).innerHTML = '';
                  document.getElementById('nexus-coll-qv-qty-' + bid).value = 1;
                  document.getElementById('nexus-coll-qv-img-' + bid).src = '';

                  fetch('/products/' + handle + '.js')
                    .then(function (r) { return r.json(); })
                    .then(function (product) {
                      document.getElementById('nexus-coll-qv-vendor-' + bid).innerText = product.vendor || 'LOADOUT ITEM';
                      document.getElementById('nexus-coll-qv-title-' + bid).innerText = product.title;
                      document.getElementById('nexus-coll-qv-desc-' + bid).innerHTML = (product.description || '').replace(/(<([^>]+)>)/gi, '') || 'No description available.';

                      var thumbWrap = document.getElementById('nexus-coll-qv-thumbs-' + bid);
                      var images = product.images && product.images.length ? product.images : product.featured_image ? [product.featured_image] : [];
                      images.forEach(function (src, idx) {
                        var thumb = document.createElement('div');
                        thumb.className = 'fn-modal-thumb' + (idx === 0 ? ' active' : '');
                        thumb.innerHTML = '<img src="' + src + '" alt="">';
                        thumb.onclick = function () {
                          document.getElementById('nexus-coll-qv-img-' + bid).src = src;
                          thumbWrap.querySelectorAll('.fn-modal-thumb').forEach(function (t) { t.classList.remove('active'); });
                          thumb.classList.add('active');
                        };
                        thumbWrap.appendChild(thumb);
                      });

                      var defaultVariant = product.variants.find(function (v) { return v.available; }) || product.variants[0];
                      document.getElementById('nexus-coll-qv-img-' + bid).src = defaultVariant.featured_image ? defaultVariant.featured_image.src : images[0] || '';
                      nexusCollRenderQVOptions(product, defaultVariant);
                      nexusCollUpdateQVVariant(defaultVariant);
                    });
                }

                function nexusCollRenderQVOptions(product, selectedVariant) {
                  var wrap = document.getElementById('nexus-coll-qv-options-' + bid);
                  wrap.innerHTML = '';
                  if (product.options.length === 1 && product.options[0] === 'Title') return;
                  product.options.forEach(function (optName, index) {
                    var values = [];
                    product.variants.forEach(function (v) { var val = v['option' + (index + 1)]; if (values.indexOf(val) === -1) values.push(val); });
                    var isColor = /color|colour/i.test(optName);
                    var group = document.createElement('div');
                    group.className = 'fn-modal-option-group';
                    group.innerHTML = '<span class="fn-modal-option-label">' + optName + '</span>';
                    var vw = document.createElement('div');
                    vw.className = 'fn-modal-option-values';
                    values.forEach(function (val) {
                      var isActive = selectedVariant && ['option1','option2','option3'].some(function (o,i) { return index === i && selectedVariant[o] === val; });
                      var btn = document.createElement(isColor ? 'div' : 'button');
                      btn.type = 'button';
                      btn.className = (isColor ? 'fn-opt-color' : 'fn-opt-btn') + (isActive ? ' active' : '');
                      if (isColor) { btn.style.backgroundColor = val.toLowerCase(); btn.title = val; }
                      else btn.innerText = val;
                      btn.addEventListener('click', function () {
                        var match = product.variants.find(function (v) { return [v.option1, v.option2, v.option3].filter(Boolean).every(function (o, i) { return i === index ? o === val : true; }); });
                        if (match) { nexusCollRenderQVOptions(product, match); nexusCollUpdateQVVariant(match); }
                      });
                      vw.appendChild(btn);
                    });
                    group.appendChild(vw);
                    wrap.appendChild(group);
                  });
                }

                function nexusCollUpdateQVVariant(variant) {
                  currentVariant = variant;
                  document.getElementById('nexus-coll-qv-price-' + bid).innerText = '$' + (variant.price / 100).toFixed(2);
                  var ce = document.getElementById('nexus-coll-qv-compare-' + bid);
                  var de = document.getElementById('nexus-coll-qv-discount-' + bid);
                  if (variant.compare_at_price && variant.compare_at_price > variant.price) {
                    ce.innerText = '$' + (variant.compare_at_price / 100).toFixed(2);
                    de.innerText = '-' + Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100) + '%';
                    de.style.display = 'inline-block';
                  } else { ce.innerText = ''; de.style.display = 'none'; }
                  var stt = document.getElementById('nexus-coll-qv-stock-text-' + bid);
                  var ab = document.getElementById('nexus-coll-qv-add-' + bid);
                  var at = document.getElementById('nexus-coll-qv-add-text-' + bid);
                  if (variant.available) { stt.innerText = 'IN STOCK'; ab.disabled = false; at.innerText = 'ADD TO INVENTORY'; }
                  else { stt.innerText = 'OUT OF STOCK'; ab.disabled = true; at.innerText = 'UNAVAILABLE'; }
                  if (variant.featured_image && variant.featured_image.src) document.getElementById('nexus-coll-qv-img-' + bid).src = variant.featured_image.src;
                }

                window.nexusCollCloseQV = function () {
                  document.getElementById('nexus-coll-qv-' + bid).classList.remove('active');
                  document.body.style.overflow = '';
                  currentVariant = null;
                };
                document.getElementById('nexus-coll-qv-' + bid).addEventListener('click', function (e) { if (e.target === this) nexusCollCloseQV(); });

                // Qty
                document.getElementById('nexus-coll-qv-minus-' + bid).addEventListener('click', function () {
                  var inp = document.getElementById('nexus-coll-qv-qty-' + bid);
                  var v = parseInt(inp.value) || 1;
                  if (v > 1) inp.value = v - 1;
                });
                document.getElementById('nexus-coll-qv-plus-' + bid).addEventListener('click', function () {
                  var inp = document.getElementById('nexus-coll-qv-qty-' + bid);
                  inp.value = (parseInt(inp.value) || 1) + 1;
                });

                // Add from modal
                document.getElementById('nexus-coll-qv-add-' + bid).addEventListener('click', function () {
                  if (!currentVariant || !currentVariant.available) return;
                  var qty = document.getElementById('nexus-coll-qv-qty-' + bid).value;
                  var at = document.getElementById('nexus-coll-qv-add-text-' + bid);
                  at.innerText = 'EQUIPPING...';
                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: [{ id: currentVariant.id, quantity: parseInt(qty) }] }),
                  }).then(function () {
                    at.innerText = 'EQUIPPED!';
                    document.dispatchEvent(new CustomEvent('cart:build'));
                    if (window.NexusCart) { NexusCart.fetchCart(); }
                    setTimeout(function () { nexusCollCloseQV(); }, 900);
                  }).catch(function () { at.innerText = 'ADD TO INVENTORY'; });
                });

                function nexusCollShowToast() {
                  var t = document.getElementById('nexus-coll-toast-' + bid);
                  t.classList.add('show');
                  setTimeout(function () { t.classList.remove('show'); }, 3000);
                }

                /* ===== FIRE SPARKS ===== */
                function generateFireSparks() {
                  var sparksContainer = document.getElementById('nexus-coll-sparks-' + bid);
                  if (!sparksContainer) return;
                  sparksContainer.innerHTML = '';
                  var count = window.innerWidth < 768 ? 14 : 26;
                  for (var i = 0; i < count; i++) {
                    var spark = document.createElement('span');
                    spark.className = 'fn-spark';
                    spark.style.left = Math.random() * 100 + '%';
                    spark.style.width = spark.style.height = (Math.random() * 3.5 + 2).toFixed(1) + 'px';
                    spark.style.animationDuration = (Math.random() * 3 + 3.5).toFixed(2) + 's';
                    spark.style.animationDelay = (Math.random() * 6).toFixed(2) + 's';
                    spark.style.setProperty('--drift', (Math.random() * 50 - 25).toFixed(0) + 'px');
                    sparksContainer.appendChild(spark);
                  }
                }
              })();
            </script>

          {%- when 'card_story' -%}
            {%- assign story_bg_opacity = block.settings.story_section_bg_opacity | times: 1.0 | divided_by: 100 -%}
            {%- assign story_primary = block.settings.story_primary_color | default: '#FFC72C' -%}
            {%- assign story_accent = block.settings.story_accent_color | default: '#FF7A00' -%}
            <style>
              .fn-section-{{ block.id }} {
                position: relative;
                overflow: hidden;
                width: 100vw;
                margin-left: calc(-50vw + 50%);
                --story-primary: {{ story_primary }};
                --story-accent: {{ story_accent }};
              }
            </style>
            <div class="fn-section-{{ block.id }}">
              {%- if block.settings.story_section_bg != blank -%}
                <div class="fn-section-bg-image" style="background-image: url('{{ block.settings.story_section_bg | image_url: width: 1920 }}'); opacity: {{ story_bg_opacity }};"></div>
              {%- endif -%}

              <div class="nexus-story-section">
                <!-- HERO -->
              <div class="nexus-story-hero">
                {%- if block.settings.story_hero_bg != blank -%}
                  <div class="nexus-story-hero__bg" style="background-image:url('{{ block.settings.story_hero_bg | image_url: width: 1920 }}');"></div>
                {%- endif -%}
                <div class="nexus-story-hero__content">
                  <div class="nexus-story-hero__tagline">
                    <span class="nexus-story-hero__tagline-line"></span>
                    <span class="nexus-story-hero__tagline-icon">
                      <svg viewBox="0 0 24 24" width="16" height="16"><path d="M7 7l5-5 5 5M7 17l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                    </span>
                    {{ block.settings.story_tagline | default: 'FROM PASSION TO PURPOSE' }}
                    <span class="nexus-story-hero__tagline-icon">
                      <svg viewBox="0 0 24 24" width="16" height="16"><path d="M7 7l5-5 5 5M7 17l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                    </span>
                    <span class="nexus-story-hero__tagline-line"></span>
                  </div>
                  <h2 class="nexus-story-hero__title">{{ block.settings.story_heading | default: 'OUR <span>STORY</span>' }}</h2>
                  {% comment %} <div class="nexus-story-hero__divider">
                    <svg viewBox="0 0 24 24" width="28" height="28"><path d="M12 2L9 9H2l6 4.5L5.5 21 12 16.5 18.5 21 16 13.5 22 9h-7z" fill="currentColor"/></svg>
                  </div> {% endcomment %}
                  <p class="nexus-story-hero__desc">{{ block.settings.story_body | default: 'Booyah! Merchant was born from our love for Free Fire and the community that unites millions of survivors around the world.' }}</p>
                </div>
                {%- if block.settings.story_hero_char != blank -%}
                  <div class="nexus-story-hero__character">
                    <img src="{{ block.settings.story_hero_char | image_url: width: 1200 }}" alt="">
                  </div>
                {%- endif -%}
                
              </div>

              <!-- STORY CARDS -->
              <div class="nexus-story-cards">
                {%- for i in (1..4) -%}
                  {%- assign card_num = i -%}
                  {%- assign ct = 'story_card_' | append: i | append: '_title' -%}
                  {%- assign cd = 'story_card_' | append: i | append: '_desc' -%}
                  {%- assign ci = 'story_card_' | append: i | append: '_image' -%}
                  {%- if block.settings[ct] != blank -%}
                    <div class="nexus-story-card">
                      <div class="nexus-story-card__media">
                        {%- if block.settings[ci] != blank -%}
                          <img src="{{ block.settings[ci] | image_url: width: 600 }}" alt="" loading="lazy">
                        {%- endif -%}
                        <div class="nexus-story-card__glow"></div>
                      </div>
                      <div class="nexus-story-card__content">
                        <span class="nexus-story-card__num">{{ '0' | append: i }}</span>
                        <h3 class="nexus-story-card__title">{{ block.settings[ct] }}</h3>
                        <p class="nexus-story-card__desc">{{ block.settings[cd] }}</p>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <!-- BOTTOM SECTION -->
              <div class="nexus-story-bottom">
                <div class="nexus-story-bottom__left">
                  <div class="nexus-story-bottom__icon">
                    <svg viewBox="0 0 24 24" width="32" height="32"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                  </div>
                  <div>
                    <h5 class="nexus-story-bottom__label">{{ block.settings.bottom_label | default: "WE'RE JUST GETTING STARTED" }}</h5>
                    <p class="nexus-story-bottom__text">{{ block.settings.bottom_text | default: 'The journey continues, and the best is yet to come. Thank you for being part of our story.' }}</p>
                  </div>
                </div>
                {% comment %} <div class="nexus-story-bottom__center">
                  <h3 class="nexus-story-bottom__heading">ONE GAME. ONE COMMUNITY.<br><span>ONE FAMILY.</span></h3>
                  {%- if block.settings.bottom_cta_link != blank -%}
                    <a href="{{ block.settings.bottom_cta_link }}" class="nexus-story-bottom__cta">
                      {{ block.settings.bottom_cta_text | default: 'JOIN OUR JOURNEY' }}
                      <svg viewBox="0 0 24 24" width="16" height="16"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.59 5.59L12 20l8-8z"/></svg>
                    </a>
                  {%- endif -%}
                </div> {% endcomment %}
                {%- if block.settings.bottom_char != blank -%}
                  <div class="nexus-story-bottom__characters">
                    <img src="{{ block.settings.bottom_char | image_url: width: 800 }}" alt="">
                  </div>
                {%- endif -%}
              </div>
            </div>
            </div>

          {%- when 'card_about' -%}
            {%- assign ab_bg_opacity = block.settings.section_bg_opacity | times: 1.0 | divided_by: 100 -%}
            <div class="fn-section-{{ block.id }}">
              {%- if block.settings.section_bg != blank -%}
                <div class="fn-section-bg-image" style="background-image: url('{{ block.settings.section_bg | image_url: width: 1920 }}'); opacity: {{ ab_bg_opacity }};"></div>
              {%- endif -%}

              <div class="ab-section-{{ block.id }}">
              <!-- HERO -->
              <div class="ab-hero">
                {%- if block.settings.hero_bg != blank -%}
                  <div class="ab-hero__bg" style="background-image:url('{{ block.settings.hero_bg | image_url: width: 1920 }}');"></div>
                {%- endif -%}
                <div class="ab-hero__content">
                  <div class="ab-hero__tag">{{ block.settings.hero_tag | default: "MORE THAN MERCH. IT'S A LIFESTYLE." }}</div>
                  <h2 class="ab-hero__title">{{ block.settings.hero_heading | default: 'ABOUT US' | replace: ' ', '<br>' }}</h2>
                  <p class="ab-hero__desc">{{ block.settings.hero_desc | default: "At Booyah! Merchant, we live and breathe Free Fire. We create premium-quality merchandise for true survivors who don't just play the game, they represent it." }}</p>
                  {%- if block.settings.hero_cta_link != blank -%}
                    <a href="{{ block.settings.hero_cta_link }}" class="ab-hero__cta">
                      {{ block.settings.hero_cta_text | default: 'OUR STORY' }}
                      <svg viewBox="0 0 24 24"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.59 5.59L12 20l8-8z"/></svg>
                    </a>
                  {%- endif -%}
                </div>
                {%- if block.settings.hero_characters != blank -%}
                  <div class="ab-hero__characters">
                    <img src="{{ block.settings.hero_characters | image_url: width: 1200 }}" alt="">
                  </div>
                {%- endif -%}
              </div>

              <!-- MISSION BAR -->
              <div class="ab-mission"{% if block.settings.mission_bg != blank %} style="background-image:url('{{ block.settings.mission_bg | image_url: width: 1920 }}');background-size:cover;background-position:center;"{% endif %}>
                <div class="ab-mission__text">
                  <h3>{{ block.settings.mission_title | default: 'OUR MISSION' }}</h3>
                  <p>{{ block.settings.mission_desc | default: 'To deliver high-quality, stylish, and exclusive Free Fire merchandise that lets players express their passion, stand out, and feel like legends in real life.' }}</p>
                </div>
                <div class="ab-mission__cards">
                  {%- for i in (1..4) -%}
                    {%- assign mt = 'mission_' | append: i | append: '_title' -%}
                    {%- assign md = 'mission_' | append: i | append: '_desc' -%}
                    {%- assign mi = 'mission_' | append: i | append: '_icon' -%}
                    {%- if block.settings[mt] != blank -%}
                      <div class="ab-mission-card">
                        <div class="ab-mission-card__icon">
                          {%- if block.settings[mi] != blank -%}
                            <img src="{{ block.settings[mi] | image_url: width: 60 }}" alt="">
                          {%- else -%}
                            <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
                          {%- endif -%}
                        </div>
                        <h4>{{ block.settings[mt] }}</h4>
                        <p>{{ block.settings[md] }}</p>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

              <!-- WHO WE ARE -->
              <div class="ab-who">
                {%- if block.settings.who_image != blank -%}
                  <div class="ab-who__img">
                    <img src="{{ block.settings.who_image | image_url: width: 800 }}" alt="">
                  </div>
                {%- endif -%}
                <div class="ab-who__content">
                  <h3>{{ block.settings.who_heading }}</h3>
                  <p>{{ block.settings.who_desc | default: "We are a team of passionate gamers and creators who understand the Free Fire universe inside out. Every product we craft is inspired by the game, built for quality, and inspired by the spirit of Booyah!" }}</p>
                  <div class="ab-stats">
                    {%- for i in (1..4) -%}
                      {%- assign sn = 'stat_' | append: i | append: '_num' -%}
                      {%- assign sl = 'stat_' | append: i | append: '_label' -%}
                      {%- if block.settings[sn] != blank -%}
                        <div class="ab-stat">
                          <span class="ab-stat__num">{{ block.settings[sn] }}</span>
                          <span class="ab-stat__label">{{ block.settings[sl] }}</span>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.who_cta_link != blank -%}
                    <a href="{{ block.settings.who_cta_link }}" class="ab-who__cta">
                      {{ block.settings.who_cta_text | default: 'JOIN OUR JOURNEY' }}
                      <svg viewBox="0 0 24 24"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.59 5.59L12 20l8-8z"/></svg>
                    </a>
                  {%- endif -%}
                </div>
              </div>

              <!-- WHY CHOOSE + BANNER (shared background) -->
              <div class="ab-why-section">
                {%- if block.settings.why_banner_bg != blank -%}
                  <div class="ab-why-section__bg" style="background-image:url('{{ block.settings.why_banner_bg | image_url: width: 1920 }}');"></div>
                {%- endif -%}

                <div class="ab-why">
                  <h3 class="ab-why__title">{{ block.settings.why_title | default: 'WHY CHOOSE <span>BOOYAH!</span> MERCHANT?' }}</h3>
                  <div class="ab-why__grid">
                    {%- for i in (1..6) -%}
                      {%- assign wt = 'why_' | append: i | append: '_title' -%}
                      {%- assign wd = 'why_' | append: i | append: '_desc' -%}
                      {%- assign wi = 'why_' | append: i | append: '_icon' -%}
                      {%- assign wimg = 'why_' | append: i | append: '_image' -%}
                      {%- if block.settings[wt] != blank -%}
                        <div class="ab-why-card">
                          {%- if block.settings[wimg] != blank -%}
                            <div class="ab-why-card__img">
                              <img src="{{ block.settings[wimg] | image_url: width: 400 }}" alt="">
                              {%- if block.settings[wi] != blank -%}
                                <div class="ab-why-card__icon-badge">
                                  <img src="{{ block.settings[wi] | image_url: width: 60 }}" alt="">
                                </div>
                              {%- else -%}
                                <div class="ab-why-card__icon-badge">
                                  <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                                </div>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          <div class="ab-why-card__content">
                            <h4>{{ block.settings[wt] }}</h4>
                            <p>{{ block.settings[wd] }}</p>
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>

                <!-- BANNER -->
                <div class="ab-banner">
                  {%- if block.settings.banner_char_left != blank or block.settings.banner_char_right != blank -%}
                    <div class="ab-banner__characters">
                      {%- if block.settings.banner_char_left != blank -%}
                        <img src="{{ block.settings.banner_char_left | image_url: width: 600 }}" alt="">
                      {%- endif -%}
                      {%- if block.settings.banner_char_right != blank -%}
                        <img src="{{ block.settings.banner_char_right | image_url: width: 600 }}" alt="">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  <div class="ab-banner__content">
                    <h3>{{ block.settings.banner_tag | default: "WE DON'T JUST FOLLOW THE GAME." }}</h3>
                    <h2>{{ block.settings.banner_heading }} <br> <span>{{ block.settings.banner_accent | default: 'BOOYAH!' }}</span></h2>
                    {%- if block.settings.banner_cta_link != blank -%}
                      <a href="{{ block.settings.banner_cta_link }}" class="ab-banner__cta">
                        {{ block.settings.banner_cta_text | default: 'SHOP LIMITED EDITIONS' }}
                        <svg viewBox="0 0 24 24" style="width:16px;height:16px;fill:currentColor;"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.59 5.59L12 20l8-8z"/></svg>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              </div>

              <!-- BOTTOM BAR -->
              <div class="le-bottom-bar">
                <div class="le-bottom-features">
                  {%- for i in (1..4) -%}
                    {%- assign bt = 'bottom_feat_' | append: i | append: '_title' -%}
                    {%- assign bd = 'bottom_feat_' | append: i | append: '_desc' -%}
                    {%- assign bi = 'bottom_feat_' | append: i | append: '_icon' -%}
                    {%- if block.settings[bt] != blank -%}
                      <div class="le-bottom-feat">
                        <div class="le-bottom-feat__icon">
                          {%- if block.settings[bi] != blank -%}
                            <img src="{{ block.settings[bi] | image_url: width: 60 }}" alt="" style="width:100%;height:100%;object-fit:contain;">
                          {%- else -%}
                            {%- if i == 1 -%}<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                            {%- elsif i == 2 -%}<svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                            {%- elsif i == 3 -%}<svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                            {%- else -%}<svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                            {%- endif -%}
                          {%- endif -%}
                        </div>
                        <div class="le-bottom-feat__text">
                          <h5>{{ block.settings[bt] }}</h5>
                          <p>{{ block.settings[bd] }}</p>
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
            </div>

          {%- when 'card_custom' -%}
            <div class="nexus-about-view">
              {%- if block.settings.custom_heading != blank -%}
                <h2>{{ block.settings.custom_heading }}</h2>
              {%- endif -%}
              {%- if block.settings.custom_body != blank -%}
                <p>{{ block.settings.custom_body }}</p>
              {%- endif -%}
              {%- if block.settings.custom_image != blank -%}
                <img
                  src="{{ block.settings.custom_image | image_url: width: 800 }}"
                  alt=""
                  style="max-width:100%;border-radius:12px;margin-top:24px;"
                >
              {%- endif -%}
            </div>

          {%- when 'card_storefront' -%}
            {%- assign sf_collection = block.settings.sf_collection -%}
            {%- assign target_collection = sf_collection | default: collections.all -%}

            <div class="fn-section-{{ block.id }}">
              {%- if block.settings.sf_hero_image != blank -%}
                <div
                  class="fn-section-bg-image"
                  style="background-image: url('{{ block.settings.sf_hero_image | image_url: width: 1920 }}');"
                ></div>
              {%- endif -%}

              <!-- HERO BANNER -->
              <div class="fn-hero-wrapper">
                <div
                  class="fn-hero"
                  {% if block.settings.sf_hero_image != blank %}
                    style="background-image: url('{{ block.settings.sf_hero_image | image_url: width: 1800 }}');"
                  {% endif %}
                >
                  <div class="fn-hero-shine"></div>
                  <div class="fn-hero-content">
                    <div class="fn-hero-badge">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2L2 22h20L12 2zm0 4.5l6.5 13h-13L12 6.5z"/>
                      </svg>
                      Our Collection
                    </div>
                    <h1>
                      {{ block.settings.sf_heading | default: 'GEAR UP,' }}
                      <span>{{ block.settings.heading_accent | default: 'BOOYAH!' }}</span>
                    </h1>
                    <p>
                      {{
                        block.settings.sf_subtitle
                        | default: 'Explore our exclusive Free Fire inspired collection. Limited drops, legendary style!'
                      }}
                    </p>
                  </div>
                </div>
              </div>

              <div class="fn-container">
                {%- if block.settings.enable_filters -%}
                <button
                  class="fn-mobile-filter-btn"
                  onclick="document.getElementById('fn-sidebar-{{ block.id }}').classList.toggle('open')"
                >
                  Toggle Filters
                </button>

                <!-- SIDEBAR -->
                <aside class="fn-sidebar" id="fn-sidebar-{{ block.id }}">
                  <form class="fn-filter-form" id="fn-filter-form-{{ block.id }}">
                    {%- for filter in target_collection.filters -%}
                      <div class="fn-filter-widget">
                        <h3 class="fn-filter-title">{{ filter.label }}</h3>
                        {%- case filter.type -%}
                          {%- when 'list' -%}
                            {%- if filter.label == 'Color' or filter.label == 'Colour' -%}
                              <div class="fn-color-swatches">
                                {%- for value in filter.values -%}
                                  <label title="{{ value.label }}">
                                    <input
                                      type="checkbox"
                                      class="fn-filter-checkbox"
                                      name="{{ value.param_name }}"
                                      value="{{ value.value }}"
                                      {% if value.active %}
                                        checked
                                      {% endif %}
                                    >
                                    <div
                                      class="fn-color-box"
                                      style="background-color: {{ value.label | downcase }};"
                                    ></div>
                                  </label>
                                {%- endfor -%}
                              </div>
                            {%- elsif filter.label == 'Size' -%}
                              <div class="fn-size-swatches">
                                {%- for value in filter.values -%}
                                  <label>
                                    <input
                                      type="checkbox"
                                      class="fn-filter-checkbox"
                                      name="{{ value.param_name }}"
                                      value="{{ value.value }}"
                                      {% if value.active %}
                                        checked
                                      {% endif %}
                                    >
                                    <div class="fn-size-box">{{ value.label }}</div>
                                  </label>
                                {%- endfor -%}
                              </div>
                            {%- else -%}
                              <ul class="fn-filter-list">
                                {%- for value in filter.values -%}
                                  <li>
                                    <label class="fn-filter-label">
                                      <span>{{ value.label }}</span>
                                      <span>{{ value.count }}</span>
                                      <input
                                        type="checkbox"
                                        class="fn-filter-checkbox"
                                        name="{{ value.param_name }}"
                                        value="{{ value.value }}"
                                        {% if value.active %}
                                          checked
                                        {% endif %}
                                      >
                                    </label>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          {%- when 'price_range' -%}
                            <div style="display: flex; gap: 10px; align-items: center;">
                              <span style="color:var(--ff-primary);">$</span>
                              <input
                                type="number"
                                name="{{ filter.min_value.param_name }}"
                                value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                                placeholder="Min"
                                style="width:100%; background:#222; border:1px solid #444; color:#fff; padding:5px; border-radius:4px;"
                              >
                              <span>-</span>
                              <input
                                type="number"
                                name="{{ filter.max_value.param_name }}"
                                value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                                placeholder="Max"
                                style="width:100%; background:#222; border:1px solid #444; color:#fff; padding:5px; border-radius:4px;"
                              >
                            </div>
                        {%- endcase -%}
                      </div>
                    {%- endfor -%}
                    {% if target_collection.filters.size > 0 %}
                      <button type="submit" style="display:none;">Apply</button>
                      <button
                        type="button"
                        onclick="window.location.href='{{ target_collection.url }}'"
                        style="width:100%; background:transparent; border:1px solid #444; color:#ccc; padding:10px; border-radius:4px; cursor:pointer; text-transform:uppercase;"
                      >
                        Clear All
                      </button>
                    {% endif %}
                  </form>
                </aside>
                {%- endif -%}

                <!-- MAIN AREA -->
                <main class="fn-main">
                  {%- paginate target_collection.products by block.settings.sf_products_per_page -%}
                    <div class="fn-toolbar">
                      <div class="fn-toolbar-count">
                        Showing {{ paginate.current_offset | plus: 1 }} -
                        {% if paginate.next -%}
                          {{- paginate.current_offset | plus: block.settings.sf_products_per_page -}}
                        {%- else -%}
                          {{- paginate.items -}}
                        {%- endif %}
                        of {{ paginate.items }} Products
                      </div>
                      <div class="fn-toolbar-actions">
                        <span style="color:#888; font-size:14px; text-transform:uppercase;">Sort By:</span>
                        <select id="fn-sort-select-{{ block.id }}" class="fn-select">
                          <option value="manual">Featured</option>
                          <option value="best-selling">Best Selling</option>
                          <option value="title-ascending">Alphabetically, A-Z</option>
                          <option value="price-ascending">Price, low to high</option>
                          <option value="price-descending">Price, high to low</option>
                          <option value="created-descending">Date, new to old</option>
                        </select>
                      </div>
                    </div>

                    <div class="fn-grid">
                      {%- for product in target_collection.products -%}
                        {% assign badge_class = '' %}
                        {% assign badge_text = '' %}
                        {% if product.tags contains 'New' %}
                          {% assign badge_class = 'bg-purple' -%}
                          {%- assign badge_text = 'NEW' %}
                        {% elsif product.tags contains 'Limited' %}
                          {% assign badge_class = 'bg-blue' -%}
                          {%- assign badge_text = 'LIMITED' %}
                        {% elsif product.tags contains 'Hot' %}
                          {% assign badge_class = 'bg-orange' -%}
                          {%- assign badge_text = 'HOT' %}
                        {% elsif product.compare_at_price > product.price %}
                          {% assign badge_class = 'bg-red' %}
                          {% assign discount = product.compare_at_price
                            | minus: product.price
                            | times: 100.0
                            | divided_by: product.compare_at_price
                            | round
                          %}
                          {% assign badge_text = '-' | append: discount | append: '%' %}
                        {% endif %}

                        {% assign delay_idx = forloop.index0 | modulo: 4 %}

                        <div
                          class="fn-card-frame"
                          style="transition-delay: {{ delay_idx | times: 0.07 }}s;"
                          onclick="fnCardClick(event, '{{ product.handle }}', '{{ block.id }}')"
                        >
                          <div class="fn-card-inner">
                            {% if badge_text != '' %}
                              <div class="fn-card-badge {{ badge_class }}">{{ badge_text }}</div>
                            {% endif %}
                            <span class="fn-card-id">#{{ forloop.index }}</span>
                            <div class="fn-card-img-wrap">
                              <div class="fn-corner fn-corner-tl"></div>
                              <div class="fn-corner fn-corner-br"></div>
                              <div class="fn-scan-line"></div>
                              {%- if product.featured_image != blank -%}
                                <img
                                  src="{{ product.featured_image | image_url: width: 500 }}"
                                  alt="{{ product.title | escape }}"
                                  class="fn-card-img"
                                  loading="lazy"
                                >
                              {%- else -%}
                                <div class="fn-no-image"><span>No Image</span></div>
                              {%- endif -%}
                            </div>
                            <h3 class="fn-card-title">{{ product.title }}</h3>
                            <div class="fn-card-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128)</span></div>
                            <div class="fn-card-divider"></div>
                            <div class="fn-card-bottom">
                              <div class="fn-card-price-wrap">
                                <span class="fn-price">{{ product.price | money }}</span>
                                {% if product.compare_at_price > product.price %}
                                  <span class="fn-compare">{{ product.compare_at_price | money }}</span>
                                {% endif %}
                              </div>
                              <button
                                class="fn-cart-btn"
                                onclick="event.stopPropagation(); fnAddIconToCart(event, {{ product.variants.first.id }}, '{{ block.id }}')"
                                aria-label="Add to cart"
                              >
                                <svg class="cart-icon" viewBox="0 0 24 24">
                                  <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
                                </svg>
                                <svg class="spinner-icon" viewBox="0 0 50 50" style="display:none;">
                                  <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-dasharray="80" stroke-dashoffset="60"/>
                                </svg>
                                <svg class="check-icon" viewBox="0 0 24 24" style="display:none;">
                                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                                </svg>
                              </button>
                            </div>
                          </div>
                        </div>
                      {%- endfor -%}
                    </div>

                    {%- if paginate.pages > 1 -%}
                      <div style="display:flex; justify-content:center; gap:10px; margin-top:40px;">
                        {%- for part in paginate.parts -%}
                          {%- if part.is_link -%}
                            <a
                              href="{{ part.url }}"
                              style="background:#222; padding:10px 15px; color:white; text-decoration:none; border-radius:4px;"
                            >
                              {{- part.title -}}
                            </a>
                          {%- else -%}
                            <span style="background:var(--ff-primary); color:#111; padding:10px 15px; border-radius:4px; font-weight:bold;">
                              {{- part.title -}}
                            </span>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endpaginate -%}
                </main>
              </div>

              {%- if block.settings.enable_fire_effect -%}
                <div class="fn-fire-glowline"></div>
                <div class="fn-fire-sparks" id="fn-fire-sparks-{{ block.id }}"></div>
              {%- endif -%}
            </div>

            <!-- QUICK VIEW MODAL -->
            <div class="fn-modal-overlay" id="fn-quickview-{{ block.id }}">
              <div class="fn-modal-frame">
                <div class="fn-modal-box">
                  <button class="fn-modal-close" onclick="fnCloseQuickView('{{ block.id }}')">&times;</button>
                  <div class="fn-modal-media">
                    <div class="fn-modal-media-frame" id="qv-img-wrap-{{ block.id }}">
                      <div class="fn-corner fn-corner-tl"></div>
                      <div class="fn-corner fn-corner-br"></div>
                      <div class="fn-modal-stock-tag" id="qv-stock-{{ block.id }}">
                        <span class="dot"></span><span id="qv-stock-text-{{ block.id }}">IN STOCK</span>
                      </div>
                      <img id="qv-img-{{ block.id }}" src="" alt="">
                    </div>
                    <div class="fn-modal-thumbs" id="qv-thumbs-{{ block.id }}"></div>
                  </div>
                  <div class="fn-modal-info">
                    <div class="fn-modal-info-scroll">
                      <span class="fn-modal-tag" id="qv-vendor-{{ block.id }}">LOADOUT ITEM</span>
                      <h2 class="fn-modal-title" id="qv-title-{{ block.id }}">Loading Drop...</h2>
                      <div class="fn-modal-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(128 Reviews)</span></div>
                      <div class="fn-modal-price-row">
                        <span class="fn-modal-price" id="qv-price-{{ block.id }}"></span>
                        <span class="fn-modal-compare" id="qv-compare-{{ block.id }}"></span>
                        <span class="fn-modal-discount" id="qv-discount-{{ block.id }}" style="display:none;"></span>
                      </div>
                      <div class="fn-modal-divider"></div>
                      <div class="fn-modal-desc" id="qv-desc-{{ block.id }}"></div>
                      <div class="fn-modal-options" id="qv-options-{{ block.id }}"></div>
                      <div class="fn-modal-qty-row">
                        <span class="fn-modal-label">Quantity</span>
                        <div class="fn-qty-stepper">
                          <button type="button" class="fn-qty-btn" id="qv-qty-minus-{{ block.id }}">-</button>
                          <input type="number" id="qv-qty-{{ block.id }}" value="1" min="1" readonly>
                          <button type="button" class="fn-qty-btn" id="qv-qty-plus-{{ block.id }}">+</button>
                        </div>
                      </div>
                    </div>
                    <button
                      class="fn-modal-add"
                      id="qv-add-btn-{{ block.id }}"
                      onclick="fnAddFromModal('{{ block.id }}')"
                    >
                      <span class="fn-modal-add-text" id="qv-add-text-{{ block.id }}">ADD TO INVENTORY</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- TOAST -->
            <div class="fn-toast" id="fn-toast-{{ block.id }}">âœ” Successfully added to inventory</div>

            <script>
              (function () {
                var bid = '{{ block.id }}';
                var currentProduct = null;
                var currentVariant = null;
                var selectedOptions = [];

                // Sort
                var sortSelect = document.getElementById('fn-sort-select-' + bid);
                if (sortSelect) {
                  var urlParams = new URLSearchParams(window.location.search);
                  if (urlParams.has('sort_by')) sortSelect.value = urlParams.get('sort_by');
                  sortSelect.addEventListener('change', function () {
                    urlParams.set('sort_by', this.value);
                    window.location.search = urlParams.toString();
                  });
                }

                // Filter form
                var filterForm = document.getElementById('fn-filter-form-' + bid);
                if (filterForm) {
                  filterForm.querySelectorAll('input').forEach(function (input) {
                    input.addEventListener('change', function () {
                      filterForm.submit();
                    });
                  });
                }

                // Fire sparks
                var sparksContainer = document.getElementById('fn-fire-sparks-' + bid);
                if (sparksContainer) {
                  var count = window.innerWidth < 768 ? 14 : 26;
                  for (var i = 0; i < count; i++) {
                    var spark = document.createElement('span');
                    spark.className = 'fn-spark';
                    spark.style.left = Math.random() * 100 + '%';
                    spark.style.width = spark.style.height = (Math.random() * 3.5 + 2).toFixed(1) + 'px';
                    spark.style.animationDuration = (Math.random() * 3 + 3.5).toFixed(2) + 's';
                    spark.style.animationDelay = (Math.random() * 6).toFixed(2) + 's';
                    spark.style.setProperty('--drift', (Math.random() * 50 - 25).toFixed(0) + 'px');
                    sparksContainer.appendChild(spark);
                  }
                }

                // Quantity stepper
                var qtyInput = document.getElementById('qv-qty-' + bid);
                document.getElementById('qv-qty-minus-' + bid).addEventListener('click', function () {
                  var val = parseInt(qtyInput.value) || 1;
                  if (val > 1) qtyInput.value = val - 1;
                });
                document.getElementById('qv-qty-plus-' + bid).addEventListener('click', function () {
                  qtyInput.value = (parseInt(qtyInput.value) || 1) + 1;
                });

                // Card click -> Quick View
                window.fnCardClick = function (event, handle, blockId) {
                  fnOpenQuickView(handle, blockId);
                };

                // Add to cart from card
                window.fnAddIconToCart = function (event, variantId, blockId) {
                  var btn = event.currentTarget;
                  var cartIcon = btn.querySelector('.cart-icon');
                  var spinnerIcon = btn.querySelector('.spinner-icon');
                  var checkIcon = btn.querySelector('.check-icon');
                  cartIcon.style.display = 'none';
                  spinnerIcon.style.display = 'block';

                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] }),
                  })
                    .then(function (res) {
                      return res.json();
                    })
                    .then(function () {
                      spinnerIcon.style.display = 'none';
                      checkIcon.style.display = 'block';
                      fnShowToast(blockId);
                      document.dispatchEvent(new CustomEvent('cart:build'));
                      if (window.NexusCart) { NexusCart.fetchCart(); NexusCart.open(); }
                      setTimeout(function () {
                        checkIcon.style.display = 'none';
                        cartIcon.style.display = 'block';
                      }, 2000);
                    })
                    .catch(function () {
                      spinnerIcon.style.display = 'none';
                      cartIcon.style.display = 'block';
                    });
                };

                // Open Quick View
                window.fnOpenQuickView = function (handle, blockId) {
                  var modal = document.getElementById('fn-quickview-' + blockId);
                  modal.classList.add('active');
                  document.body.style.overflow = 'hidden';

                  document.getElementById('qv-title-' + blockId).innerText = 'Loading Drop...';
                  document.getElementById('qv-price-' + blockId).innerText = '';
                  document.getElementById('qv-compare-' + blockId).innerText = '';
                  document.getElementById('qv-discount-' + blockId).style.display = 'none';
                  document.getElementById('qv-desc-' + blockId).innerHTML = '';
                  document.getElementById('qv-options-' + blockId).innerHTML = '';
                  document.getElementById('qv-thumbs-' + blockId).innerHTML = '';
                  document.getElementById('qv-qty-' + blockId).value = 1;
                  document.getElementById('qv-img-' + blockId).src = '';

                  fetch('/products/' + handle + '.js')
                    .then(function (res) {
                      return res.json();
                    })
                    .then(function (product) {
                      currentProduct = product;
                      fnRenderModalProduct(product, blockId);
                    });
                };

                function fnRenderModalProduct(product, bid) {
                  document.getElementById('qv-vendor-' + bid).innerText = product.vendor || 'LOADOUT ITEM';
                  document.getElementById('qv-title-' + bid).innerText = product.title;
                  document.getElementById('qv-desc-' + bid).innerHTML =
                    (product.description || '').replace(/(<([^>]+)>)/gi, '') || 'No description available.';

                  var thumbWrap = document.getElementById('qv-thumbs-' + bid);
                  var images =
                    product.images && product.images.length
                      ? product.images
                      : product.featured_image
                      ? [product.featured_image]
                      : [];
                  images.forEach(function (imgSrc, idx) {
                    var thumb = document.createElement('div');
                    thumb.className = 'fn-modal-thumb' + (idx === 0 ? ' active' : '');
                    thumb.innerHTML = '<img src="' + imgSrc + '" alt="">';
                    thumb.onclick = function () {
                      document.getElementById('qv-img-' + bid).src = imgSrc;
                      thumbWrap.querySelectorAll('.fn-modal-thumb').forEach(function (t) {
                        t.classList.remove('active');
                      });
                      thumb.classList.add('active');
                    };
                    thumbWrap.appendChild(thumb);
                  });

                  var defaultVariant =
                    product.variants.find(function (v) {
                      return v.available;
                    }) || product.variants[0];
                  selectedOptions = [defaultVariant.option1, defaultVariant.option2, defaultVariant.option3].filter(
                    Boolean
                  );
                  document.getElementById('qv-img-' + bid).src = defaultVariant.featured_image
                    ? defaultVariant.featured_image.src
                    : images[0] || '';
                  fnRenderOptions(product, bid);
                  fnUpdateVariantDisplay(defaultVariant, bid);
                }

                function fnRenderOptions(product, bid) {
                  var wrap = document.getElementById('qv-options-' + bid);
                  wrap.innerHTML = '';
                  if (product.options.length === 1 && product.options[0] === 'Title') return;

                  product.options.forEach(function (optionName, index) {
                    var values = [];
                    product.variants.forEach(function (v) {
                      var val = v['option' + (index + 1)];
                      if (values.indexOf(val) === -1) values.push(val);
                    });
                    var isColor = /color|colour/i.test(optionName);
                    var group = document.createElement('div');
                    group.className = 'fn-modal-option-group';
                    group.innerHTML = '<span class="fn-modal-option-label">' + optionName + '</span>';
                    var valuesWrap = document.createElement('div');
                    valuesWrap.className = 'fn-modal-option-values';

                    values.forEach(function (val) {
                      var isActive = selectedOptions[index] === val;
                      var btn = document.createElement(isColor ? 'div' : 'button');
                      btn.type = 'button';
                      btn.className = (isColor ? 'fn-opt-color' : 'fn-opt-btn') + (isActive ? ' active' : '');
                      if (isColor) {
                        btn.style.backgroundColor = val.toLowerCase();
                        btn.title = val;
                      } else {
                        btn.innerText = val;
                      }
                      btn.addEventListener('click', function () {
                        selectedOptions[index] = val;
                        fnRenderOptions(product, bid);
                        var match = product.variants.find(function (v) {
                          return [v.option1, v.option2, v.option3].filter(Boolean).every(function (o, i) {
                            return o === selectedOptions[i];
                          });
                        });
                        if (match) fnUpdateVariantDisplay(match, bid);
                      });
                      valuesWrap.appendChild(btn);
                    });

                    group.appendChild(valuesWrap);
                    wrap.appendChild(group);
                  });
                }

                function fnUpdateVariantDisplay(variant, bid) {
                  currentVariant = variant;
                  document.getElementById('qv-price-' + bid).innerText = '$' + (variant.price / 100).toFixed(2);
                  var compareEl = document.getElementById('qv-compare-' + bid);
                  var discountEl = document.getElementById('qv-discount-' + bid);
                  if (variant.compare_at_price && variant.compare_at_price > variant.price) {
                    compareEl.innerText = '$' + (variant.compare_at_price / 100).toFixed(2);
                    var discount = Math.round(
                      ((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100
                    );
                    discountEl.innerText = '-' + discount + '%';
                    discountEl.style.display = 'inline-block';
                  } else {
                    compareEl.innerText = '';
                    discountEl.style.display = 'none';
                  }

                  var stockTag = document.getElementById('qv-stock-' + bid);
                  var stockText = document.getElementById('qv-stock-text-' + bid);
                  var addBtn = document.getElementById('qv-add-btn-' + bid);
                  var addText = document.getElementById('qv-add-text-' + bid);
                  if (variant.available) {
                    stockText.innerText = 'IN STOCK';
                    addBtn.disabled = false;
                    addText.innerText = 'ADD TO INVENTORY';
                  } else {
                    stockText.innerText = 'OUT OF STOCK';
                    addBtn.disabled = true;
                    addText.innerText = 'UNAVAILABLE';
                  }

                  if (variant.featured_image && variant.featured_image.src) {
                    document.getElementById('qv-img-' + bid).src = variant.featured_image.src;
                  }
                }

                // Close Quick View
                window.fnCloseQuickView = function (blockId) {
                  document.getElementById('fn-quickview-' + blockId).classList.remove('active');
                  document.body.style.overflow = '';
                  currentProduct = null;
                  currentVariant = null;
                };
                document.getElementById('fn-quickview-' + bid).addEventListener('click', function (e) {
                  if (e.target === this) fnCloseQuickView(bid);
                });

                // Add from modal
                window.fnAddFromModal = function (blockId) {
                  if (!currentVariant || !currentVariant.available) return;
                  var qty = document.getElementById('qv-qty-' + blockId).value;
                  var addText = document.getElementById('qv-add-text-' + blockId);
                  addText.innerText = 'EQUIPPING...';

                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: [{ id: currentVariant.id, quantity: parseInt(qty) }] }),
                  })
                    .then(function () {
                      addText.innerText = 'EQUIPPED!';
                      document.dispatchEvent(new CustomEvent('cart:build'));
                      if (window.NexusCart) { NexusCart.fetchCart(); }
                      setTimeout(function () {
                        fnCloseQuickView(blockId);
                        if (window.NexusCart) { NexusCart.open(); }
                      }, 900);
                    })
                    .catch(function () {
                      addText.innerText = 'ADD TO INVENTORY';
                    });
                };

                // Toast
                window.fnShowToast = function (blockId) {
                  var toast = document.getElementById('fn-toast-' + blockId);
                  toast.classList.add('show');
                  setTimeout(function () {
                    toast.classList.remove('show');
                  }, 3000);
                };
              })();
            </script>

          {%- when 'card_limited' -%}
            {%- assign le_collection = block.settings.collection | default: collections.all -%}
            {%- assign le_limit = block.settings.products_limit | default: 12 -%}
            {%- assign le_bg_opacity = block.settings.section_bg_opacity | times: 1.0 | divided_by: 100 -%}

            <div class="fn-section-{{ block.id }}">
              {%- if block.settings.section_bg != blank -%}
                <div class="fn-section-bg-image" style="background-image: url('{{ block.settings.section_bg | image_url: width: 1920 }}'); opacity: {{ le_bg_opacity }};"></div>
              {%- endif -%}

              <!-- HERO -->
              <div class="le-hero">
                {%- if block.settings.hero_image != blank -%}
                  <div class="le-hero__bg" style="background-image: url('{{ block.settings.hero_image | image_url: width: 1920 }}');"></div>
                {%- endif -%}
                <div class="le-hero__content">
                  <div class="le-hero__badge">{{ block.settings.badge_text | default: 'EXCLUSIVE COLLECTION' }}</div>
                  <h2 class="le-hero__title">{{ block.settings.heading | default: 'LIMITED<br>EDITION' | replace: ' ', '<br>' }}</h2>
                  <p class="le-hero__subtitle">{{ block.settings.hero_subtitle | default: 'RARE GEAR. UNMATCHED STYLE.' }}</p>
                  {%- if block.settings.show_timer -%}
                    <div class="le-hero__timer">
                      <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                      {{ block.settings.timer_text | default: 'AVAILABLE FOR A LIMITED TIME ONLY' }}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.cta_link != blank -%}
                    <a href="{{ block.settings.cta_link }}" class="le-hero__cta">
                      <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      {{ block.settings.cta_text | default: 'WATCH TRAILER' }}
                    </a>
                  {%- endif -%}
                </div>
                <div class="le-features">
                  {%- for i in (1..4) -%}
                    {%- assign ft = 'feature_' | append: i | append: '_title' -%}
                    {%- assign fd = 'feature_' | append: i | append: '_desc' -%}
                    {%- assign fi = 'feature_' | append: i | append: '_icon' -%}
                    {%- if block.settings[ft] != blank -%}
                      <div class="le-feature">
                        <div class="le-feature__icon">
                          {%- if block.settings[fi] != blank -%}
                            <img src="{{ block.settings[fi] | image_url: width: 60 }}" alt="" style="width:100%;height:100%;object-fit:contain;">
                          {%- else -%}
                            {%- if i == 1 -%}<svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
                            {%- elsif i == 2 -%}<svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                            {%- elsif i == 3 -%}<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                            {%- else -%}<svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                            {%- endif -%}
                          {%- endif -%}
                        </div>
                        <div class="le-feature__text">
                          <h4>{{ block.settings[ft] }}</h4>
                          <p>{{ block.settings[fd] }}</p>
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

              {%- if block.settings.shop_link != blank -%}
                <a href="{{ block.settings.shop_link }}" class="le-shop-btn">{{ block.settings.shop_text | default: 'SHOP NOW' }}</a>
              {%- endif -%}

              <!-- CAROUSEL -->
              <div class="le-carousel-wrap">
                <h3 class="le-carousel-title">{{ block.settings.carousel_title | default: 'THE COLLECTION' }}</h3>
                <button class="le-arrow le-arrow--prev" onclick="this.parentNode.querySelector('.le-carousel').scrollBy({left:-280,behavior:'smooth'})">
                  <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
                </button>
                <div class="le-carousel">
                  {%- for product in le_collection.products limit: le_limit -%}
                    {% assign badge_class = '' %}
                    {% assign badge_text = '' %}
                    {% if product.tags contains 'New' %}
                      {% assign badge_class = 'bg-purple' %}{% assign badge_text = 'NEW' %}
                    {% elsif product.tags contains 'Limited' %}
                      {% assign badge_class = 'bg-blue' %}{% assign badge_text = 'LIMITED' %}
                    {% elsif product.tags contains 'Hot' %}
                      {% assign badge_class = 'bg-orange' %}{% assign badge_text = 'HOT' %}
                    {% elsif product.compare_at_price > product.price %}
                      {% assign badge_class = 'bg-red' %}
                      {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                      {% assign badge_text = '-' | append: discount | append: '%' %}
                    {% endif %}

                    <div class="fn-card-frame" onclick="fnCardClick(event, '{{ product.handle }}', '{{ block.id }}')">
                      <div class="fn-card-inner">
                        {% if badge_text != '' %}
